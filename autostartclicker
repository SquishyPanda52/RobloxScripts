-- Draggable frame (mouse + touch)
do
    local dragging = false
    local dragStart = Vector2.new()
    local startPos = UDim2.new()
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = Vector2.new(input.Position.X, input.Position.Y)
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging then
            local mousePos = UserInputService:GetMouseLocation()
            local delta = mousePos - dragStart
            local newX = startPos.X.Offset + delta.X
            local newY = startPos.Y.Offset + delta.Y
            local screenW = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.X or 1280
            local screenH = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.Y or 720
            newX = math.clamp(newX, 0, screenW - frame.AbsoluteSize.X)
            newY = math.clamp(newY, 0, screenH - frame.AbsoluteSize.Y)
            frame.Position = UDim2.new(0, newX, 0, newY)
        end
    end)
end

-- Draggable circle (mouse + touch), constrained to screen
do
    local dragging = false
    local offset = Vector2.new()
    circle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            local mousePos = UserInputService:GetMouseLocation()
            offset = Vector2.new(mousePos.X, mousePos.Y) - Vector2.new(circle.AbsolutePosition.X, circle.AbsolutePosition.Y)
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging then
            local mousePos = UserInputService:GetMouseLocation()
            local newX = mousePos.X - offset.X
            local newY = mousePos.Y - offset.Y
            local screenW = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.X or 1280
            local screenH = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.Y or 720
            newX = math.clamp(newX, 0, screenW - circle.AbsoluteSize.X)
            newY = math.clamp(newY, 0, screenH - circle.AbsoluteSize.Y)
            circle.Position = UDim2.new(0, newX, 0, newY)
        end
    end)
end

-- Commander matching (partial, case-insensitive)
local function isCommander(name)
    if not name or #commanders == 0 then return false end
    local s = string.lower(name)
    for _, token in ipairs(commanders) do
        if token ~= "" and string.find(s, token, 1, true) then
            return true
        end
    end
    return false
end

-- Visual flash when click happens
local function flashCircle()
    flash.Visible = true
    flash.BackgroundTransparency = 0
    flash.Size = UDim2.new(0, 12, 0, 12)
    flash.Position = UDim2.new(0.5, 0, 0.5, 0)
    spawn(function()
        for i = 1, 12 do
            flash.BackgroundTransparency = i/12
            wait(0.02)
        end
        flash.Visible = false
    end)
end

-- Perform single auto-click: activate GUI buttons under circle; raycast and report world hit
local function performAutoClick()
    -- compute center of circle in screen coordinates
    local centerX = circle.AbsolutePosition.X + circle.AbsoluteSize.X/2
    local centerY = circle.AbsolutePosition.Y + circle.AbsoluteSize.Y/2

    -- 1) Activate GUI buttons under the point
    local guiObjects = GuiService:GetGuiObjectsAtPosition(centerX, centerY)
    for _, obj in ipairs(guiObjects) do
        if obj and obj:IsA("GuiButton") then
            pcall(function() obj:Activate() end)
            flashCircle()
            return
        end
    end

    -- 2) Raycast into the world and report hit (client-only)
    local camera = Workspace.CurrentCamera
    if not camera then return end
    local unitRay = camera:ScreenPointToRay(centerX, centerY)
    local origin = unitRay.Origin
    local direction = unitRay.Direction * 1000

    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {player.Character or player}
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist

    local result = Workspace:Raycast(origin, direction, raycastParams)
    if result and result.Instance then
        -- Client-only behavior: highlight the hit part briefly and print info for testing
        local hitPart = result.Instance
        -- Create a temporary highlight (SelectionBox-like) for visual feedback
        local adorn = Instance.new("SelectionBox")
        adorn.Adornee = hitPart
        adorn.LineThickness = 0.02
        adorn.Color3 = Color3.fromRGB(0, 200, 255)
        adorn.Parent = hitPart
        flashCircle()
        spawn(function()
            wait(0.45)
            if adorn and adorn.Parent then
                adorn:Destroy()
            end
        end)
        -- Print/log the hit for debugging
        warn("[AutoStartClick] Raycast hit:", hitPart:GetFullName())
        -- Optionally, if the hit has a ProximityPrompt, show its info (client-only)
        local prompt = hitPart:FindFirstChildOfClass("ProximityPrompt") or hitPart:FindFirstChildWhichIsA("ProximityPrompt", true)
        if prompt then
            warn("[AutoStartClick] Found ProximityPrompt on hit:", prompt.Name)
            -- Note: triggering ProximityPrompt programmatically requires server validation; not attempted here.
        end
    else
        -- Nothing hit
        warn("[AutoStartClick] No world object hit at circle position.")
        flashCircle()
    end
end

-- Chat message handler (TextChatService preferred)
local function handleIncomingMessage(msg)
    -- msg is a TextChatMessage object
    local text = ""
    local senderName = ""
    pcall(function()
        text = msg.Text or ""
        if msg.TextSource then
            -- TextSource may have Name or UserId
            if msg.TextSource.Name then
                senderName = msg.TextSource.Name
            elseif msg.TextSource.UserId then
                local p = Players:GetPlayerByUserId(msg.TextSource.UserId)
                if p then senderName = p.Name end
            end
        end
    end)
    if text and string.lower(text):match("^%.start%s*$") then
        if listenerEnabled and isCommander(senderName) then
            performAutoClick()
        end
    end
end

-- Connect TextChatService.OnIncomingMessage if available
local connected = false
if TextChatService and TextChatService.OnIncomingMessage then
    pcall(function()
        TextChatService.OnIncomingMessage:Connect(handleIncomingMessage)
        connected = true
    end)
end

-- Fallback: Player.Chatted (client-side only; does not reliably receive other players' messages in all chat systems)
if not connected then
    player.Chatted:Connect(function(msg)
        if string.lower(msg):match("^%.start%s*$") then
            -- This fallback only reliably detects the local player's chat in many environments.
            if listenerEnabled and isCommander(player.Name) then
                performAutoClick()
            end
        end
    end)
end

-- Initialize commander list from textbox (empty by default)
commanders = parseCommanders(cmdBox.Text or "")

-- Ensure mobile touch works: touch input handled by InputBegan checks above
