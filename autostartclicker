    listenerEnabled = not listenerEnabled
    toggleBtn.Text = listenerEnabled and "Enabled" or "Disabled"
    toggleBtn.BackgroundColor3 = listenerEnabled and Color3.fromRGB(70,70,70) or Color3.fromRGB(110,30,30)
end)

-- Update commanders on focus lost
