-- State
local expanded = false
local listenerEnabled = true
local commanders = {} -- lowercase partial tokens

-- Parse comma-separated partial names into lowercase tokens
local function parseCommanders(text)
    local out = {}
    if not text then return out end
    for token in string.gmatch(text, "[^,]+") do
        local s = token:match("^%s*(.-)%s*$")
        if s ~= "" then
            out[#out+1] = string.lower(s)
        end
    end
    return out
end

-- Collapse/expand
