    expanded = not expanded
    content.Visible = expanded
    collapseBtn.Text = expanded and "×" or "—"
    if expanded then
        frame.Size = UDim2.new(0, 360, 0, 140)
    else
        frame.Size = UDim2.new(0, 260, 0, 40)
    end
end)

