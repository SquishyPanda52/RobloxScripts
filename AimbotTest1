--------------------------------------------------------------------
-- MULTI‑PLAYER TARGETING SYSTEM
--------------------------------------------------------------------

local function getTargetPlayers(text)
    local results = {}
    local parts = string.split(text, ",")

    for _, raw in ipairs(parts) do
        local partial = raw:lower():gsub("%s+", "")
        if partial ~= "" then
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= localPlayer and plr.Name:lower():find(partial, 1, true) then
                    table.insert(results, plr)
                end
            end
        end
    end

    return results
end

txtUser.FocusLost:Connect(function()
    local list = getTargetPlayers(txtUser.Text)
    if #list > 0 then
        txtUser.BackgroundColor3 = Color3.fromRGB(25, 50, 25)
    else
        txtUser.BackgroundColor3 = Color3.fromRGB(50, 25, 25)
    end
end)

--------------------------------------------------------------------
-- AIMBOT LOOP (closest target wins)
--------------------------------------------------------------------

local function startAimbot()
    if aimConnection then return end

    aimConnection = RunService.RenderStepped:Connect(function()
        if not (aimbotEnabled or predictEnabled) then return end

        local candidates = getTargetPlayers(txtUser.Text)
        if #candidates == 0 then return end

        local myChar = localPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end

        local closestHRP = nil
        local closestDist = math.huge

        for _, plr in ipairs(candidates) do
            if plr.Character then
                local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (hrp.Position - myHRP.Position).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closestHRP = hrp
                    end
                end
            end
        end

        if closestHRP then
            if predictEnabled then
                -- ADVANCED PREDICTION USING SLIDER STRENGTH
                local targetPos = closestHRP.Position
                local targetVel = closestHRP.Velocity

                local rel = targetPos - myHRP.Position
                local dist = rel.Magnitude
                local speed = targetVel.Magnitude

                local basePrediction = predictionStrength -- 0.00 - 1.00 from slider
                local distanceFactor = math.clamp(dist / 60, 0, 2)
                local velocityFactor = math.clamp(speed / 20, 0, 2)

                local predictionTime = basePrediction * (0.5 + 0.5 * distanceFactor + 0.5 * velocityFactor)
                local predictedPos = targetPos + targetVel * predictionTime

                camera.CFrame = CFrame.lookAt(camera.CFrame.Position, predictedPos)
            else
                -- NORMAL SNAPPY AIM
                camera.CFrame = CFrame.lookAt(camera.CFrame.Position, closestHRP.Position)
            end
        end
    end)
end

