local targetRadius = 120

-- Optimization settings
local TARGET_COMPUTE_INTERVAL = 0.05 -- seconds between heavy target computations (20 Hz)
local NPC_SCAN_INTERVAL = 1.0 -- seconds fallback scan for NPCs
local NPC_DESCENDANT_DEBOUNCE = 0.25 -- debounce for descendant changes

--// Helpers
local function round(num, decimals)
    local mult = 10 ^ (decimals or 0)
    return math.floor(num * mult + 0.5) / mult
end

local function trim(s)
    return tostring(s):gsub("^%s+", ""):gsub("%s+$", "")
end

-- Find NPC models in workspace by partial name (case-insensitive)
-- NOTE: This function is used only when resolving names (cached), not every frame.
local function findNPCsByPartial(partial)
    local results = {}
    if not partial or partial == "" then return results end
    partial = partial:lower():gsub("%s+", "")
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name and obj.Name:lower():find(partial, 1, true) then
            -- Skip player characters (we'll handle players separately)
            local owner = Players:GetPlayerFromCharacter(obj)
            if not owner then
                -- Ensure it has a Humanoid or a HumanoidRootPart/PrimaryPart
                local humanoid = obj:FindFirstChildOfClass("Humanoid")
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
                if humanoid or hrp then
                    table.insert(results, obj)
                end
            end
        end
    end
    return results
end

