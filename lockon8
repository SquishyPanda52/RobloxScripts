UserInput.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Q then
        txtUser:CaptureFocus()
    end
    if input.KeyCode == Enum.KeyCode.Return or input.KeyCode == Enum.KeyCode.KeypadEnter then
        if txtUser:IsFocused() then txtUser:ReleaseFocus() end
    end

    if input.KeyCode == Enum.KeyCode.E then
        if autoSelectEnabled then
            if selectedTarget then
                selectedTarget = nil
                lastTargetHRP = nil
                targetFoundLabel.Text = "Unlocked"
                task.delay(0.5, function()
                    if targetFoundLabel and not selectedTarget then
                        targetFoundLabel.Text = ""
                    end
                end)
                markCandidateDirty()
            elseif hoveredTarget then
                selectedTarget = hoveredTarget
                lastTargetHRP = nil
                -- hoveredTarget may be a Player or a Model; both have Name
                targetFoundLabel.Text = "Locked: "..(hoveredTarget.Name or "Target")
                markCandidateDirty()
            end
        end
    end

    if input.KeyCode == Enum.KeyCode.X then toggleLockon() end
    if input.KeyCode == Enum.KeyCode.U then togglePredict() end
end)

--// Commander utilities & command handling
local function isCommander(name)
    local list = string.split(commanderBox.Text or "", ",")
    name = tostring(name or ""):lower()
    for _, raw in ipairs(list) do
        local partial = raw:lower():gsub("%s+", "")
        if partial ~= "" and name:find(partial, 1, true) then
            return true
        end
    end
    return false
end

local function allPlayerNames(excludeCommanders)
    local names = {}
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= localPlayer then
            if excludeCommanders then
                if not isCommander(pl.Name) then
                    table.insert(names, pl.Name)
                end
            else
                table.insert(names, pl.Name)
            end
        end
    end
    return names
end

local function setLastCommander(plr)
    if plr and plr.UserId then
        lastCommanderUserId = plr.UserId
    end
end

local function hardOverridePreviousCommands()
    -- Clear selected target so camera re-evaluates new txtUser
    selectedTarget = nil
    lastTargetHRP = nil
    -- Disable autoSelect if active
    if autoSelectEnabled then autoSelectEnabled = false end
    -- Ensure lockon is enabled and loop started
    if not lockonEnabled then
        lockonEnabled = true
        startLockon()
    end
    markCandidateDirty()
    updateButtons()
end

-- Command parsing: robust and normalized
if TextChatService then
    TextChatService.MessageReceived:Connect(function(msg)
        if not commanderMode then return end
        if not msg then return end

        local source = msg.TextSource
        if not source then return end

        local userId = source.UserId
        if not userId then return end

        local plr = Players:GetPlayerByUserId(userId)
        if not plr then return end

        if not isCommander(plr.Name) then return end

        -- newest commander overrides everything
        setLastCommander(plr)

        local text = tostring(msg.Text or "")
        local cmdRaw, argRaw = text:match("^%.([%w_]+)%s*(.*)$")
        if not cmdRaw then return end

        local cmd = cmdRaw:lower()
        local arg = trim(argRaw or "")

        -- Normalize synonyms
        if cmd == "attack" then cmd = "atk" end
        if cmd == "goto" then cmd = "follow" end

        -- STOP
        if cmd == "stop" then
            txtUser.Text = ""
            lockonEnabled = false
            selectedTarget = nil
            lastTargetHRP = nil
            markCandidateDirty()
            updateButtons()
            return
        end

        -- ATK / ATTACK
        if cmd == "atk" then
            local lowarg = arg:lower()

            -- no arg or "me" -> attack the commander who said it
            if lowarg == "" or lowarg == "me" then
                txtUser.Text = plr.Name
                hardOverridePreviousCommands()
                return
            end

            -- random
            if lowarg == "random" then
                local pool = {}
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= localPlayer and not isCommander(p.Name) then
                        table.insert(pool, p)
                    end
                end
                if #pool > 0 then
                    local choice = pool[math.random(1, #pool)]
                    txtUser.Text = choice.Name
                    hardOverridePreviousCommands()
                end
                return
            end

            -- others -> everyone except commanders
            if lowarg == "others" then
                local names = allPlayerNames(true)
                txtUser.Text = table.concat(names, ", ")
                hardOverridePreviousCommands()
                return
            end

            -- all / everyone -> everyone in server (excluding local)
            if lowarg == "all" or lowarg == "everyone" then
                local names = allPlayerNames(false)
                txtUser.Text = table.concat(names, ", ")
                hardOverridePreviousCommands()
                return
            end

            -- default: treat arg as list of users or NPC names (preserve original casing)
            if arg ~= "" then
                txtUser.Text = arg
                hardOverridePreviousCommands()
            end
            return
        end

        -- FOLLOW / GOTO
        if cmd == "follow" then
            local lowarg = arg:lower()

            -- no arg or "me" -> follow the commander
            if lowarg == "" or lowarg == "me" then
                txtUser.Text = plr.Name
                hardOverridePreviousCommands()
                return
            end

            -- default: follow provided name(s)
            if arg ~= "" then
                txtUser.Text = arg
                hardOverridePreviousCommands()
            end
            return
        end

        -- Unrecognized commands ignored
    end)
end

