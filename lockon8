-- Lockon script with extended commander commands and hard-override behavior
-- Supports interchangeable commands:
--   .follow / .goto / .follow me
--   .atk / .attack / .atk me
--   .atk all / .attack all / .atk everyone / .attack everyone
--   .atk others / .attack others (everyone except commanders)
--   .atk random
--   .stop
-- New behavior: the most recent commander command HARD overrides previous commands.
-- Updated: Auto Select can now find NPC targets (models/rigs with Humanoids/HumanoidRootPart/PrimaryPart)
-- Optimized: reduced per-frame work, cached candidate resolution, NPC list maintenance, throttled target computation

--// Services
local Players         = game:GetService("Players")
local RunService      = game:GetService("RunService")
local UserInput       = game:GetService("UserInputService")
