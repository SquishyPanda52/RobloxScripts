--// Target resolution caching
-- candidateCache: list of resolved candidate Instances (Players or Models)
local candidateCache = {}
local candidateCacheText = ""
local candidateCacheDirty = true

local function clearCandidateCache()
    candidateCache = {}
    candidateCacheText = ""
    candidateCacheDirty = true
end

-- Resolve txtUser.Text into candidate instances (players and NPC models)
local function rebuildCandidateCache()
    candidateCache = {}
    candidateCacheText = tostring(txtUser.Text or "")
    candidateCacheDirty = false

    -- If auto-select is active and selectedTarget exists, prefer it
    if autoSelectEnabled then
        if selectedTarget then
            candidateCache[1] = selectedTarget
            return
        else
            -- no explicit selection; leave cache empty
            return
        end
    end

    local text = candidateCacheText
    if text == "" then return end

    local parts = string.split(text, ",")
    for _, raw in ipairs(parts) do
        local partial = raw:lower():gsub("%s+", "")
        if partial ~= "" then
            -- Match players by partial name
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= localPlayer and plr.Name:lower():find(partial, 1, true) then
                    table.insert(candidateCache, plr)
                end
            end
            -- Match NPC models by partial name (uses workspace scan once per rebuild)
            local npcs = findNPCsByPartial(partial)
            for _, npc in ipairs(npcs) do
                table.insert(candidateCache, npc)
            end
        end
    end
end

-- Rebuild cache when txtUser changes
txtUser:GetPropertyChangedSignal("Text"):Connect(function()
    candidateCacheDirty = true
end)

-- Also mark dirty when autoSelect/selectedTarget changes
local function markCandidateDirty()
    candidateCacheDirty = true
end

--// NPC list maintenance (to avoid scanning workspace every frame)
local npcList = {} -- weak set of models that are potential NPCs (Model -> true)
local npcListLastScan = 0
local npcDescendantDebounce = 0

local function addNPCIfValid(model)
    if not model or not model:IsA("Model") then return end
    if Players:GetPlayerFromCharacter(model) then return end
    if model == localPlayer.Character then return end
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
    if humanoid or hrp then
        npcList[model] = true
    end
end

local function removeNPC(model)
    if npcList[model] then
        npcList[model] = nil
    end
end

-- Initial population (lightweight)
do
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") then
            addNPCIfValid(obj)
        end
    end
end

-- Keep npcList updated on descendant changes (debounced)
workspace.DescendantAdded:Connect(function(desc)
    npcDescendantDebounce = tick()
    -- schedule a small debounce to avoid thrashing on mass changes
    task.delay(NPC_DESCENDANT_DEBOUNCE, function()
        if tick() - npcDescendantDebounce >= NPC_DESCENDANT_DEBOUNCE then
            addNPCIfValid(desc)
        end
    end)
end)
workspace.DescendantRemoving:Connect(function(desc)
    removeNPC(desc)
end)

-- Periodic fallback scan to catch missed NPCs (runs infrequently)
task.spawn(function()
    while screenGui.Parent do
        local now = tick()
        if now - npcListLastScan >= NPC_SCAN_INTERVAL then
            npcListLastScan = now
            for _, obj in ipairs(workspace:GetDescendants()) do
                if obj:IsA("Model") then
                    addNPCIfValid(obj)
                end
            end
        end
        task.wait(NPC_SCAN_INTERVAL)
    end
end)

--// Auto-select detection (hover)
-- This loop is still RenderStepped but does minimal work: it iterates players and the maintained npcList only.
RunService.RenderStepped:Connect(function()
    if not autoSelectEnabled then
        hoveredTarget = nil
        if targetFoundLabel then targetFoundLabel.Text = "" end
        return
    end

    local mousePos = UserInput:GetMouseLocation()
    local closestTarget = nil
    local closestDistance = targetRadius

    -- Check player characters first
    local players = Players:GetPlayers()
    for i = 1, #players do
        local plr = players[i]
        if plr ~= localPlayer and plr.Character then
            local hrp = plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character.PrimaryPart
            local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
            if hrp and humanoid and humanoid.Health > 0 then
                local screenPos, onScreen = camera:WorldToViewportPoint(hrp.Position)
                if onScreen then
                    local dx = screenPos.X - mousePos.X
                    local dy = screenPos.Y - mousePos.Y
                    local dist = math.sqrt(dx*dx + dy*dy)
                    if dist < closestDistance then
                        closestDistance = dist
                        closestTarget = plr
                    end
                end
            end
        end
    end

    -- Then check NPC models from npcList
    for model, _ in pairs(npcList) do
        if model and model.Parent then
            local humanoid = model:FindFirstChildOfClass("Humanoid")
            local hrp = model:FindFirstChild("HumanoidRootPart") or model.PrimaryPart
            if hrp and (humanoid == nil or humanoid.Health > 0) and model ~= localPlayer.Character then
                local ok, screenPos, onScreen = pcall(function()
                    return camera:WorldToViewportPoint(hrp.Position)
                end)
                if ok and onScreen then
                    local dx = screenPos.X - mousePos.X
                    local dy = screenPos.Y - mousePos.Y
                    local dist = math.sqrt(dx*dx + dy*dy)
                    if dist < closestDistance then
                        closestDistance = dist
                        closestTarget = model
                    end
                end
            end
        else
            -- stale entry cleanup
            npcList[model] = nil
        end
    end

    if closestTarget then
        hoveredTarget = closestTarget
        if not selectedTarget and targetFoundLabel then
            targetFoundLabel.Text = "Target Found"
        end
    else
        hoveredTarget = nil
        if not selectedTarget and targetFoundLabel then
            targetFoundLabel.Text = ""
        end
    end
end)

--// Lockon core (throttled heavy work)
local function startLockon()
    if lockonConnection then return end

    local lastCompute = 0
    local lastTargetCFrame = nil

    lockonConnection = RunService.RenderStepped:Connect(function(dt)
        -- Only run when either mode is active
        if not (lockonEnabled or lockonPredictEnabled) then return end

        -- Rebuild candidate cache if needed (only when txtUser changed or marked dirty)
        if candidateCacheDirty then
            rebuildCandidateCache()
        end

        -- If no candidates, nothing to do
        if #candidateCache == 0 then return end

        -- Throttle heavy computations to TARGET_COMPUTE_INTERVAL
        local now = tick()
        if now - lastCompute < TARGET_COMPUTE_INTERVAL then
            -- Still update camera smoothing if transitionActive is true (handled below)
            if transitionActive and lastTargetCFrame then
                camera.CFrame = lastTargetCFrame
            end
            return
        end
        lastCompute = now

        -- Get my HRP
        local myChar = localPlayer.Character
        local myHRP = myChar and (myChar:FindFirstChild("HumanoidRootPart") or myChar.PrimaryPart)
        if not myHRP then return end

        -- Find closest candidate (by distance)
        local closestHRP = nil
        local closestDist = math.huge

        for i = 1, #candidateCache do
            local candidate = candidateCache[i]
            if candidate then
                local charModel = nil
                if typeof(candidate) == "Instance" and candidate:IsA("Player") then
                    charModel = candidate.Character
                elseif typeof(candidate) == "Instance" and candidate:IsA("Model") then
                    charModel = candidate
                end

                if charModel then
                    local humanoid = charModel:FindFirstChildOfClass("Humanoid")
                    local hrp = charModel:FindFirstChild("HumanoidRootPart") or charModel.PrimaryPart
                    if hrp and (humanoid == nil or humanoid.Health > 0) then
                        local rel = hrp.Position - myHRP.Position
                        local dist = rel.Magnitude
                        if dist < closestDist then
                            closestDist = dist
                            closestHRP = hrp
                        end
                    end
                end
            end
        end

        if closestHRP then
            local targetPosition
            if lockonPredictEnabled then
                local targetPos = closestHRP.Position
                local targetVel = closestHRP.AssemblyLinearVelocity or Vector3.new(0,0,0)
                local rel = targetPos - myHRP.Position
                local dist = rel.Magnitude
                local speed = targetVel.Magnitude
                local distanceFactor = math.clamp(dist / 60, 0, 2)
                local velocityFactor = math.clamp(speed / 20, 0, 2)
                local predictionTime = predictionStrength * (0.5 + 0.5 * distanceFactor + 0.5 * velocityFactor)
                targetPosition = targetPos + targetVel * predictionTime
            else
                targetPosition = closestHRP.Position
            end

            local targetCFrame = CFrame.lookAt(camera.CFrame.Position, targetPosition)

            -- If target HRP changed, perform transition (lerp) once
            if lastTargetHRP ~= closestHRP then
                lastTargetHRP = closestHRP
                if not snapEnabled then
                    transitionActive = true
                    local startCFrame = camera.CFrame
                    local transitionTime = 0.12
                    local startTime = tick()
                    -- Perform the transition without blocking the main loop: step in small increments
                    -- We'll perform the lerp across multiple RenderStepped ticks to avoid long blocking loops
                    task.spawn(function()
                        local done = false
                        while not done and transitionActive and screenGui.Parent do
                            local alpha = math.clamp((tick() - startTime) / transitionTime, 0, 1)
                            local newCFrame = startCFrame:Lerp(targetCFrame, alpha)
                            -- Write camera once per iteration
                            camera.CFrame = newCFrame
                            if alpha >= 1 then
                                done = true
                                transitionActive = false
                            else
                                RunService.RenderStepped:Wait()
                            end
                        end
                    end)
                else
                    camera.CFrame = targetCFrame
                    transitionActive = false
                end
            end

            -- Only set camera when not in transition and when CFrame changed meaningfully
            if not transitionActive then
                -- Compare positions to avoid redundant writes
                local shouldWrite = true
                if lastTargetCFrame then
                    local p1 = lastTargetCFrame.Position
                    local p2 = targetCFrame.Position
                    if (p1 - p2).Magnitude < 0.001 then
                        shouldWrite = false
                    end
                end
                if shouldWrite then
                    camera.CFrame = targetCFrame
                    lastTargetCFrame = targetCFrame
                end
            end
        else
            lastTargetHRP = nil
            lastTargetCFrame = nil
        end
    end)
end

--// Buttons update & toggles
local function updateButtons()
    btnToggle.Text = "Lockon: " .. (lockonEnabled and "ON" or "OFF")
    btnToggle.BackgroundColor3 = lockonEnabled and Color3.fromRGB(0,70,0) or Color3.fromRGB(70,0,0)

    btnPredict.Text = "Predict: " .. (lockonPredictEnabled and "ON" or "OFF")
    btnPredict.BackgroundColor3 = lockonPredictEnabled and Color3.fromRGB(0,70,0) or Color3.fromRGB(70,0,0)

    btnSnap.Text = "Snap: " .. (snapEnabled and "ON" or "OFF")
    btnSnap.BackgroundColor3 = snapEnabled and Color3.fromRGB(0,70,0) or Color3.fromRGB(70,0,0)

    btnAutoSelect.Text = "Auto Select: " .. (autoSelectEnabled and "ON" or "OFF")
    btnAutoSelect.BackgroundColor3 = autoSelectEnabled and Color3.fromRGB(0,70,0) or Color3.fromRGB(70,0,0)

    if commanderToggle then
        commanderToggle.Text = "Cmd Mode: " .. (commanderMode and "ON" or "OFF")
        commanderToggle.BackgroundColor3 = commanderMode and Color3.fromRGB(0,70,0) or Color3.fromRGB(70,0,0)
    end
end

local function toggleLockon()
    lockonEnabled = not lockonEnabled
    if lockonEnabled then
        lockonPredictEnabled = false
        startLockon()
    end
    updateButtons()
end

local function togglePredict()
    lockonPredictEnabled = not lockonPredictEnabled
    if lockonPredictEnabled then
        lockonEnabled = false
        startLockon()
    end
    updateButtons()
end

local function toggleSnap()
    snapEnabled = not snapEnabled
    updateButtons()
end

local function toggleAutoSelect()
    autoSelectEnabled = not autoSelectEnabled
    if autoSelectEnabled and commanderMode then
        commanderMode = false
        if commanderToggle then
            commanderToggle.Text = "Cmd Mode: OFF"
            commanderToggle.BackgroundColor3 = Color3.fromRGB(70,0,0)
        end
    end
    if not autoSelectEnabled then
        selectedTarget = nil
        hoveredTarget = nil
    end
    markCandidateDirty()
