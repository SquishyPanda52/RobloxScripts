local draggingSlider = false

local function setStrengthFromX(x)

    local barPos = sliderBar.AbsolutePosition.X
    local barSize = sliderBar.AbsoluteSize.X

    local rel = math.clamp(x - barPos, 0, barSize)
    local t = rel / barSize

    predictionStrength = round(t, 2)

    valueLabel.Text = string.format("%.2f", predictionStrength)

    sliderKnob.Position = UDim2.new(
        0,
        sliderBar.Position.X.Offset + rel - 5,
        0,
        sliderKnob.Position.Y.Offset
    )
end

sliderBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = true
        setStrengthFromX(input.Position.X)
    end
end)

