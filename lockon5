local function toggleCommanderMode()
    commanderMode = not commanderMode

    if commanderMode and autoSelectEnabled then
        -- Commander mode disables Auto Select
        autoSelectEnabled = false
    end

    if commanderToggle then
        commanderToggle.Text = "Cmd Mode: " .. (commanderMode and "ON" or "OFF")
        commanderToggle.BackgroundColor3 =
            commanderMode and Color3.fromRGB(0,70,0) or Color3.fromRGB(70,0,0)
    end

    updateButtons()
end

if commanderToggle then
    commanderToggle.MouseButton1Click:Connect(toggleCommanderMode)
end

--------------------------------------------------------------------
-- KEYBINDS
--------------------------------------------------------------------

UserInput.InputBegan:Connect(function(input, gp)

    if gp then
        return
    end

    if input.KeyCode == Enum.KeyCode.Q then
        txtUser:CaptureFocus()
    end

    if input.KeyCode == Enum.KeyCode.Return
    or input.KeyCode == Enum.KeyCode.KeypadEnter then

        if txtUser:IsFocused() then
            txtUser:ReleaseFocus()
        end
    end

    ----------------------------------------------------------------
    -- E = TOGGLE LOCK / UNLOCK
    ----------------------------------------------------------------

    if input.KeyCode == Enum.KeyCode.E then

        if autoSelectEnabled then

            -- UNLOCK
            if selectedTargetPlayer then

                selectedTargetPlayer = nil
                lastTargetHRP = nil

                targetFoundLabel.Text = "Unlocked"

                task.delay(0.5, function()
                    if targetFoundLabel and not selectedTargetPlayer then
                        targetFoundLabel.Text = ""
                    end
                end)

            -- LOCK
            elseif hoveredTargetPlayer then

                selectedTargetPlayer = hoveredTargetPlayer
                lastTargetHRP = nil

                targetFoundLabel.Text =
                    "Locked: "..hoveredTargetPlayer.Name
            end
        end
    end

    if input.KeyCode == Enum.KeyCode.X then
        toggleLockon()
    end

    if input.KeyCode == Enum.KeyCode.U then
        togglePredict()
    end
end)

--------------------------------------------------------------------
-- COMMAND LISTENER (TextChatService)
--------------------------------------------------------------------

local function isCommander(name)
    local list = string.split(commanderBox.Text or "", ",")
    name = name:lower()

    for _, raw in ipairs(list) do
        local partial = raw:lower():gsub("%s+", "")
        if partial ~= "" and name:find(partial, 1, true) then
            return true
        end
    end

    return false
end

-- Listen for messages from TextChatService
if TextChatService then
    TextChatService.MessageReceived:Connect(function(msg)
        if not commanderMode then return end
        if not msg then return end

        local source = msg.TextSource
        if not source then return end

        local userId = source.UserId
        if not userId then return end

        local plr = Players:GetPlayerByUserId(userId)
        if not plr then return end

        if not isCommander(plr.Name) then return end

        local text = tostring(msg.Text or "")

        -- Check for .atk command (case-insensitive)
        local lower = text:lower()
        if lower:sub(1,4) == ".atk" then
            -- Extract everything after ".atk" and optional space
            local after = text:match("^%.atk%s*(.+)$")
            if after then
                -- Paste into the main txtUser box
                txtUser.Text = after

                -- Ensure AutoSelect is off when commander triggers
                if autoSelectEnabled then
                    autoSelectEnabled = false
                end

                -- Ensure lockon toggles on
                if not lockonEnabled then
                    toggleLockon()
                end

                updateButtons()
            end
        end
    end)
end

