--------------------------------------------------------------------
-- TARGETS
--------------------------------------------------------------------

local function getTargetPlayers(text)

    if autoSelectEnabled then
        if selectedTargetPlayer then
            return {selectedTargetPlayer}
        end

        return {}
    end

    local results = {}
    local parts = string.split(text, ",")

    for _, raw in ipairs(parts) do

        local partial = raw:lower():gsub("%s+", "")

        if partial ~= "" then

            for _, plr in ipairs(Players:GetPlayers()) do

                if plr ~= localPlayer
                and plr.Name:lower():find(partial, 1, true)
                then
                    table.insert(results, plr)
                end
            end
        end
    end

    return results
end

--------------------------------------------------------------------
-- AUTO SELECT DETECTION
--------------------------------------------------------------------

RunService.RenderStepped:Connect(function()

    if not autoSelectEnabled then
        hoveredTargetPlayer = nil
        targetFoundLabel.Text = ""
        return
    end

    local mousePos = UserInput:GetMouseLocation()

    local closestPlayer = nil
    local closestDistance = targetRadius

    for _, plr in ipairs(Players:GetPlayers()) do

        if plr ~= localPlayer and plr.Character then

            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")

            if hrp and humanoid and humanoid.Health > 0 then

                local screenPos, onScreen =
                    camera:WorldToViewportPoint(hrp.Position)

                if onScreen then

                    local dist =
                        (Vector2.new(screenPos.X, screenPos.Y)
                        - Vector2.new(mousePos.X, mousePos.Y)).Magnitude

                    if dist < closestDistance then
                        closestDistance = dist
                        closestPlayer = plr
                    end
                end
            end
        end
    end

    if closestPlayer then
        hoveredTargetPlayer = closestPlayer

        if not selectedTargetPlayer then
            targetFoundLabel.Text = "Target Found"
        end
    else
        hoveredTargetPlayer = nil

        if not selectedTargetPlayer then
            targetFoundLabel.Text = ""
        end
    end
end)

--------------------------------------------------------------------
-- LOCKON
--------------------------------------------------------------------

local function startLockon()

    if lockonConnection then
        return
    end

    lockonConnection = RunService.RenderStepped:Connect(function()

        if not (lockonEnabled or lockonPredictEnabled) then
            return
        end

        local candidates = getTargetPlayers(txtUser.Text)

        if #candidates == 0 then
            return
        end

        local myChar = localPlayer.Character
        local myHRP = myChar and myChar:FindFirstChild("HumanoidRootPart")

        if not myHRP then
            return
        end

        local closestHRP = nil
        local closestDist = math.huge

        for _, plr in ipairs(candidates) do

            if plr.Character then

                local humanoid =
                    plr.Character:FindFirstChildOfClass("Humanoid")

                local hrp =
                    plr.Character:FindFirstChild("HumanoidRootPart")

                if humanoid
                and humanoid.Health > 0
                and hrp
                then

                    local dist =
                        (hrp.Position - myHRP.Position).Magnitude

                    if dist < closestDist then
                        closestDist = dist
                        closestHRP = hrp
                    end
                end
            end
        end

        if closestHRP then

            local targetPosition

            if lockonPredictEnabled then

                local targetPos = closestHRP.Position
                local targetVel = closestHRP.AssemblyLinearVelocity

                local rel = targetPos - myHRP.Position
                local dist = rel.Magnitude
                local speed = targetVel.Magnitude

                local distanceFactor =
                    math.clamp(dist / 60, 0, 2)

                local velocityFactor =
                    math.clamp(speed / 20, 0, 2)

                local predictionTime =
                    predictionStrength *
                    (
                        0.5
                        + 0.5 * distanceFactor
                        + 0.5 * velocityFactor
                    )

                targetPosition =
                    targetPos + targetVel * predictionTime

            else
                targetPosition = closestHRP.Position
            end

            local targetCFrame =
                CFrame.lookAt(
                    camera.CFrame.Position,
                    targetPosition
                )

            if lastTargetHRP ~= closestHRP then

                if not snapEnabled then

                    transitionActive = true

                    local startCFrame = camera.CFrame
                    local transitionTime = 0.12
                    local startTime = tick()

                    repeat

                        local alpha = math.clamp(
                            (tick() - startTime)
                            / transitionTime,
                            0,
                            1
                        )

                        camera.CFrame =
                            startCFrame:Lerp(
                                targetCFrame,
                                alpha
                            )

                        RunService.RenderStepped:Wait()

                    until alpha >= 1

                    transitionActive = false

                else
                    camera.CFrame = targetCFrame
                end

                lastTargetHRP = closestHRP
            end

            if not transitionActive then
                camera.CFrame = targetCFrame
            end

        else
            lastTargetHRP = nil
        end
    end)
end

