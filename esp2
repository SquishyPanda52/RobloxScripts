---------------------------------------------------------------------
-- SPECIFIC NAMES PARSING
---------------------------------------------------------------------
local function getSpecificNameList()
    local text = specificNamesBox.Text or ""
    local list = {}

    for part in string.gmatch(text, "([^,]+)") do
        local trimmed = string.lower(part:gsub("^%s*(.-)%s*$", "%1"))

        if trimmed ~= "" then
            table.insert(list, trimmed)
        end
    end

    return list
end

local function isSpecificPlayer(player)
    local list = getSpecificNameList()
    local nameLower = string.lower(player.Name)

    for _, pattern in ipairs(list) do
        if string.find(nameLower, pattern, 1, true) then
            return true
        end
    end

    return false
end

---------------------------------------------------------------------
-- HEALTH COLOR
---------------------------------------------------------------------
local function getHealthColor(humanoid)
    if not humanoid or humanoid.MaxHealth <= 0 then
        return Color3.fromRGB(255, 255, 255)
    end

    local ratio = humanoid.Health / humanoid.MaxHealth

    if ratio >= 0.7 then
        return Color3.fromRGB(0, 255, 0)
    elseif ratio >= 0.4 then
        return Color3.fromRGB(255, 255, 0)
    else
        return Color3.fromRGB(255, 0, 0)
    end
end

---------------------------------------------------------------------
-- HIGHLIGHT + NAME TAG CREATION
---------------------------------------------------------------------
local function createHighlightForCharacter(player, character)
    if not character then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "RuntimeHighlight"
    highlight.Adornee = character
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = character

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "RuntimeNameTag"
    billboard.Size = UDim2.new(0, 200, 0, 40)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = 10000
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.Enabled = false
    billboard.Parent = character:FindFirstChild("Head") or character:FindFirstChildWhichIsA("BasePart") or character

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Name = "NameLabel"
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = math.floor(nameLabelSizeSlider.GetValue() + 0.5)
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.Parent = billboard

    characterData[player] = {
        Highlight = highlight,
        Billboard = billboard,
        NameLabel = nameLabel,
    }

    return highlight, billboard, nameLabel
end

local function removeHighlightForPlayer(player)
    local data = characterData[player]

    if data then
        if data.Highlight and data.Highlight.Parent then
            data.Highlight:Destroy()
        end

        if data.Billboard and data.Billboard.Parent then
            data.Billboard:Destroy()
        end

        characterData[player] = nil
    end
end

---------------------------------------------------------------------
-- COLOR / TRANSPARENCY UPDATE
---------------------------------------------------------------------
local function getTeamColor(player)
    if player.Team and player.Team.TeamColor then
        return player.Team.TeamColor.Color
    end

    return Color3.fromRGB(255, 255, 255)
end

local function updateHighlightForPlayer(player)
    local data = characterData[player]
    if not data then return end

    local highlight = data.Highlight
    local billboard = data.Billboard
    local nameLabel = data.NameLabel

    if not highlight or not highlight.Parent then
        return
    end

    local character = player.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")

    local isLocal = (player == LocalPlayer)

    local sameTeam = false
    if LocalPlayer.Team and player.Team then
        sameTeam = (LocalPlayer.Team == player.Team)
    end

    local visible = false
    local fillColor = Color3.fromRGB(255, 255, 255)
    local outlineColor = Color3.fromRGB(0, 0, 0)
    local fillTransparency = 1
    local outlineTransparency = 1

    if allHighlightEnabled then
        visible = true
        fillColor = Color3.fromRGB(255, 255, 255)
        outlineColor = Color3.fromRGB(255, 255, 255)
        fillTransparency = allTransparencySlider.GetValue()
        outlineTransparency = allTransparencySlider.GetValue()
    end

    if teamHighlightEnabled then
        if not (hideTeammatesEnabled and sameTeam and isLocal) then
            visible = true
            fillColor = getTeamColor(player)
            outlineColor = getTeamColor(player)
            fillTransparency = teamTransparencySlider.GetValue()
            outlineTransparency = teamTransparencySlider.GetValue()
        end
    end

    if specificHighlightEnabled and isSpecificPlayer(player) then
        visible = true
        outlineColor = Color3.fromRGB(255, 215, 0)
        outlineTransparency = specificOutlineTransparencySlider.GetValue()
    end

    if not visible then
        fillTransparency = 1
        outlineTransparency = 1
    end

    highlight.Enabled = visible
    highlight.FillColor = fillColor
    highlight.OutlineColor = outlineColor
    highlight.FillTransparency = fillTransparency
    highlight.OutlineTransparency = outlineTransparency

    if billboard then
        billboard.Enabled = visible
    end

    if nameLabel then
        local teamColor = getTeamColor(player)

        -- Set the name label color to the player's team color (no health-based color changes)
        nameLabel.TextColor3 = teamColor

        -- Keep a visible stroke for readability; use black stroke for contrast
        nameLabel.TextStrokeTransparency = 0
        nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)

        -- Apply the size from the new slider
        nameLabel.TextSize = math.floor(nameLabelSizeSlider.GetValue() + 0.5)
    end
end

---------------------------------------------------------------------
-- CHARACTER HANDLING
---------------------------------------------------------------------
local function onCharacterAdded(player, character)
    local humanoid = character:WaitForChild("Humanoid", 5)

    if not humanoid then
        return
    end

    createHighlightForCharacter(player, character)

    local conn1 = humanoid.HealthChanged:Connect(function()
        updateHighlightForPlayer(player)
    end)

    table.insert(connections, conn1)

    updateHighlightForPlayer(player)
end

local function onPlayerAdded(player)
    local function charAdded(char)
        onCharacterAdded(player, char)
    end

    if player.Character then
        charAdded(player.Character)
    end

    local c1 = player.CharacterAdded:Connect(charAdded)
    table.insert(connections, c1)
end

local function onPlayerRemoving(player)
    removeHighlightForPlayer(player)
end

for _, plr in ipairs(Players:GetPlayers()) do
    onPlayerAdded(plr)
end

table.insert(connections, Players.PlayerAdded:Connect(onPlayerAdded))
table.insert(connections, Players.PlayerRemoving:Connect(onPlayerRemoving))

