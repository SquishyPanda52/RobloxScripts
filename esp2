-- LocalScript (place in StarterPlayerScripts or run at runtime)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

--////////////////////////////////////////////////
-- STATE
--////////////////////////////////////////////////

local uiScreenGui
local mainFrame
local minimized = false
local dragging = false
local dragStart
local startPos

local teamHighlightEnabled = false
local allHighlightEnabled = false
local specificHighlightEnabled = false
local showTeammates = true

local teamTransparency = 0.3
local allTransparency = 0.3
local specificTransparency = 0.1

local specificNamesRaw = ""
local specificNameTokens = {}

local connections = {}
local playerData = {} -- [Player] = { highlight = Highlight, billboard = BillboardGui, charConn = RBXScriptConnection, healthConn = RBXScriptConnection }

local destroyed = false

--////////////////////////////////////////////////
-- UTILS
--////////////////////////////////////////////////

local function disconnectAll()
    for _, conn in ipairs(connections) do
        if conn and conn.Disconnect then
            conn:Disconnect()
        end
    end
    table.clear(connections)
end

local function clearPlayerData()
    for plr, data in pairs(playerData) do
        if data.highlight then
            data.highlight:Destroy()
        end
        if data.billboard then
            data.billboard:Destroy()
        end
        if data.charConn then
            data.charConn:Disconnect()
        end
        if data.healthConn then
            data.healthConn:Disconnect()
        end
    end
    table.clear(playerData)
end

local function isSpecificTarget(player)
    if not specificHighlightEnabled or #specificNameTokens == 0 then
        return false
    end
    local nameLower = string.lower(player.Name)
    for _, token in ipairs(specificNameTokens) do
        if token ~= "" and string.find(nameLower, token, 1, true) then
            return true
        end
    end
    return false
end

local function getTeamColor(player)
    if player.Team and player.Team.TeamColor then
        return player.Team.TeamColor.Color
    end
    return Color3.fromRGB(255, 255, 255)
end

local function getHealthColor(humanoid)
    if not humanoid then
        return Color3.fromRGB(255, 255, 255)
    end
    local health = humanoid.Health
    local maxHealth = humanoid.MaxHealth > 0 and humanoid.MaxHealth or 100
    local ratio = health / maxHealth

    if ratio >= 0.7 then
        return Color3.fromRGB(0, 255, 0) -- green
    elseif ratio >= 0.4 then
        return Color3.fromRGB(255, 255, 0) -- yellow
    elseif ratio > 0 then
        return Color3.fromRGB(255, 128, 0) -- orange
    else
        return Color3.fromRGB(255, 0, 0) -- red
    end
end

local function updateSpecificTokens()
    specificNameTokens = {}
    for token in string.gmatch(specificNamesRaw, "([^,]+)") do
        local trimmed = string.lower(token:gsub("^%s+", ""):gsub("%s+$", ""))
        if trimmed ~= "" then
            table.insert(specificNameTokens, trimmed)
        end
    end
end

--////////////////////////////////////////////////
-- HIGHLIGHT + NAME TAG CREATION
--////////////////////////////////////////////////

local function createHighlight(character)
    local highlight = Instance.new("Highlight")
    highlight.Name = "RuntimeHighlight"
    highlight.Adornee = character
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0
    highlight.Parent = character
    return highlight
end

local function createBillboard(player, character)
    local head = character:FindFirstChild("Head")
    if not head then
        return nil
    end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "RuntimeNameTag"
    billboard.Adornee = head
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.MaxDistance = 10000
    billboard.Parent = character

    local textLabel = Instance.new("TextLabel")
    textLabel.Name = "NameLabel"
    textLabel.BackgroundTransparency = 1
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.TextScaled = true
    textLabel.Text = player.Name
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.Parent = billboard

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 3
    stroke.Color = getTeamColor(player)
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Outline
    stroke.Parent = textLabel

    return billboard
end

local function applyHighlightSettings(player, data)
    local highlight = data.highlight
    local billboard = data.billboard
    if not highlight or not billboard then
        return
    end

    local character = player.Character
    if not character then
        return
    end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local healthColor = getHealthColor(humanoid)
    local teamColor = getTeamColor(player)

    -- Name label color based on health
    local nameLabel = billboard:FindFirstChild("NameLabel")
    if nameLabel then
        nameLabel.TextColor3 = healthColor
        local stroke = nameLabel:FindFirstChildOfClass("UIStroke")
        if stroke then
            stroke.Color = teamColor -- stroke color = team color
        end
    end

    -- Determine highlight mode
    local isLocal = (player == LocalPlayer)
    local sameTeam = (LocalPlayer.Team ~= nil and player.Team == LocalPlayer.Team)

    local useHighlight = false
    local fillColor = Color3.fromRGB(255, 255, 255)
    local outlineColor = Color3.fromRGB(0, 0, 0)
    local transparency = 0.3

    if specificHighlightEnabled and isSpecificTarget(player) then
        useHighlight = true
        fillColor = getTeamColor(player)
        outlineColor = Color3.fromRGB(255, 215, 0) -- gold/yellow outline for specific
        transparency = specificTransparency
    elseif teamHighlightEnabled then
        if sameTeam then
            if showTeammates then
                useHighlight = true
                fillColor = getTeamColor(player)
                outlineColor = getTeamColor(player)
                transparency = teamTransparency
            else
                useHighlight = false
            end
        else
            useHighlight = true
            fillColor = getTeamColor(player)
            outlineColor = getTeamColor(player)
            transparency = teamTransparency
        end
    elseif allHighlightEnabled then
        useHighlight = true
        fillColor = getTeamColor(player)
        outlineColor = getTeamColor(player)
        transparency = allTransparency
    end

    if useHighlight then
        highlight.Enabled = true
        highlight.FillColor = fillColor
        highlight.OutlineColor = outlineColor
        highlight.FillTransparency = transparency
        highlight.OutlineTransparency = transparency
    else
        highlight.Enabled = false
    end
end

local function setupCharacter(player, character)
    if destroyed then
        return
    end

    -- Clean old
    local old = playerData[player]
    if old then
        if old.highlight then old.highlight:Destroy() end
        if old.billboard then old.billboard:Destroy() end
        if old.healthConn then old.healthConn:Disconnect() end
    end

    local highlight = createHighlight(character)
    local billboard = createBillboard(player, character)

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local healthConn
    if humanoid then
        healthConn = humanoid.HealthChanged:Connect(function()
            if destroyed then return end
            local data = playerData[player]
            if data then
                applyHighlightSettings(player, data)
            end
        end)
    end

    playerData[player] = {
        highlight = highlight,
        billboard = billboard,
        charConn = nil,
        healthConn = healthConn,
    }

    applyHighlightSettings(player, playerData[player])
end

local function onCharacterAdded(player, character)
    setupCharacter(player, character)
end

local function onPlayerAdded(player)
    local charConn = player.CharacterAdded:Connect(function(character)
        onCharacterAdded(player, character)
    end)
    table.insert(connections, charConn)

    if player.Character then
        onCharacterAdded(player, player.Character)
    end
end

local function onPlayerRemoving(player)
    local data = playerData[player]
    if data then
        if data.highlight then data.highlight:Destroy() end
        if data.billboard then data.billboard:Destroy() end
        if data.charConn then data.charConn:Disconnect() end
        if data.healthConn then data.healthConn:Disconnect() end
    end
    playerData[player] = nil
end

--////////////////////////////////////////////////
-- UI HELPERS
--////////////////////////////////////////////////

local function makeToggle(parent, labelText, default, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -10, 0, 24)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(0.7, 0, 1, 0)
    label.Font = Enum.Font.SourceSans
    label.TextScaled = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Parent = frame

    local button = Instance.new("TextButton")
    button.Size = UDim2.new(0.3, 0, 1, 0)
    button.Position = UDim2.new(0.7, 0, 0, 0)
    button.BackgroundColor3 = default and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
    button.Text = default and "ON" or "OFF"
    button.TextScaled = true
    button.Font = Enum.Font.SourceSansBold
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Parent = frame

    local state = default

    button.MouseButton1Click:Connect(function()
        state = not state
        button.BackgroundColor3 = state and Color3.fromRGB(0, 170, 0) or Color3.fromRGB(170, 0, 0)
        button.Text = state and "ON" or "OFF"
        callback(state)
    end)

    return frame
end

local function makeSlider(parent, labelText, defaultValue, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -10, 0, 40)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(0.5, 0, 0.5, 0)
    label.Font = Enum.Font.SourceSans
    label.TextScaled = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = labelText .. " (" .. tostring(defaultValue) .. ")"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Parent = frame

    local sliderFrame = Instance.new("Frame")
    sliderFrame.Size = UDim2.new(0.9, 0, 0, 10)
    sliderFrame.Position = UDim2.new(0.05, 0, 0.6, 0)
    sliderFrame.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    sliderFrame.BorderSizePixel = 0
    sliderFrame.Parent = frame

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0, 10, 0, 20)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(defaultValue, 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(200, 200, 200)
    knob.BorderSizePixel = 0
    knob.Parent = sliderFrame

    local draggingSlider = false

    local function setValueFromX(x)
        local absPos = sliderFrame.AbsolutePosition.X
        local absSize = sliderFrame.AbsoluteSize.X
        local alpha = math.clamp((x - absPos) / absSize, 0, 1)
        -- step 0.1
        alpha = math.floor(alpha * 10 + 0.5) / 10
        knob.Position = UDim2.new(alpha, 0, 0.5, 0)
        label.Text = labelText .. " (" .. tostring(alpha) .. ")"
        callback(alpha)
    end

    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSlider = true
        end
    end)

    knob.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSlider = false
        end
    end)

    sliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSlider = true
            setValueFromX(input.Position.X)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
            setValueFromX(input.Position.X)
        end
    end)

    return frame
end

local function makeTextBox(parent, labelText, defaultText, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -10, 0, 40)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(0.4, 0, 1, 0)
    label.Font = Enum.Font.SourceSans
    label.TextScaled = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Parent = frame

    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.6, 0, 1, 0)
    box.Position = UDim2.new(0.4, 0, 0, 0)
    box.Font = Enum.Font.SourceSans
    box.TextScaled = true
    box.Text = defaultText
    box.ClearTextOnFocus = false
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    box.Parent = frame

    box.FocusLost:Connect(function(enterPressed)
        callback(box.Text)
    end)

    return frame
end

--////////////////////////////////////////////////
-- UI CREATION
--////////////////////////////////////////////////

local function makeDraggable(frame, dragHandle)
    dragHandle = dragHandle or frame

    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)

    dragHandle.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

local function buildUI()
    uiScreenGui = Instance.new("ScreenGui")
    uiScreenGui.Name = "RuntimeHighlightUI"
    uiScreenGui.ResetOnSpawn = false
    uiScreenGui.IgnoreGuiInset = true
    uiScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    mainFrame = Instance.new("Frame")
    mainFrame.Name = "MainFrame"
    mainFrame.Size = UDim2.new(0, 320, 0, 260)
    mainFrame.Position = UDim2.new(0, 50, 0, 50)
    mainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    mainFrame.BorderSizePixel = 0
    mainFrame.Active = true
    mainFrame.Parent = uiScreenGui

    local topBar = Instance.new("Frame")
    topBar.Name = "TopBar"
    topBar.Size = UDim2.new(1, 0, 0, 24)
    topBar.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    topBar.BorderSizePixel = 0
    topBar.Parent = mainFrame

    local title = Instance.new("TextLabel")
    title.BackgroundTransparency = 1
    title.Size = UDim2.new(1, -60, 1, 0)
    title.Position = UDim2.new(0, 5, 0, 0)
    title.Font = Enum.Font.SourceSansBold
    title.TextScaled = true
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.Text = "Highlight Manager"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.Parent = topBar

    local minimizeButton = Instance.new("TextButton")
    minimizeButton.Size = UDim2.new(0, 24, 0, 24)
    minimizeButton.Position = UDim2.new(1, -48, 0, 0)
    minimizeButton.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
    minimizeButton.Text = "-"
    minimizeButton.TextScaled = true
    minimizeButton.Font = Enum.Font.SourceSansBold
    minimizeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    minimizeButton.Parent = topBar

    local closeButton = Instance.new("TextButton")
    closeButton.Size = UDim2.new(0, 24, 0, 24)
    closeButton.Position = UDim2.new(1, -24, 0, 0)
    closeButton.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
    closeButton.Text = "X"
    closeButton.TextScaled = true
    closeButton.Font = Enum.Font.SourceSansBold
    closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    closeButton.Parent = topBar

    local contentFrame = Instance.new("Frame")
    contentFrame.Name = "Content"
    contentFrame.Size = UDim2.new(1, 0, 1, -24)
    contentFrame.Position = UDim2.new(0, 0, 0, 24)
    contentFrame.BackgroundTransparency = 1
    contentFrame.Parent = mainFrame

    local scrolling = Instance.new("ScrollingFrame")
    scrolling.Name = "SettingsScroll"
    scrolling.Size = UDim2.new(1, -10, 1, -10)
    scrolling.Position = UDim2.new(0, 5, 0, 5)
    scrolling.CanvasSize = UDim2.new(0, 0, 0, 0)
    scrolling.ScrollBarThickness = 6
    scrolling.BackgroundTransparency = 1
    scrolling.Parent = contentFrame

    local layout = Instance.new("UIListLayout")
    layout.Padding = UDim.new(0, 4)
    layout.FillDirection = Enum.FillDirection.Vertical
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Parent = scrolling

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        scrolling.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 10)
    end)

    -- Toggles
    makeToggle(scrolling, "Team Highlight", teamHighlightEnabled, function(state)
        teamHighlightEnabled = state
        if state then
            allHighlightEnabled = false
        end
        for plr, data in pairs(playerData) do
            applyHighlightSettings(plr, data)
        end
    end)

    makeToggle(scrolling, "All Highlight", allHighlightEnabled, function(state)
        allHighlightEnabled = state
        if state then
            teamHighlightEnabled = false
        end
        for plr, data in pairs(playerData) do
            applyHighlightSettings(plr, data)
        end
    end)

    makeToggle(scrolling, "Show Teammates (Team Mode)", showTeammates, function(state)
        showTeammates = state
        for plr, data in pairs(playerData) do
            applyHighlightSettings(plr, data)
        end
    end)

    makeToggle(scrolling, "Specific Highlight", specificHighlightEnabled, function(state)
        specificHighlightEnabled = state
        for plr, data in pairs(playerData) do
            applyHighlightSettings(plr, data)
        end
    end)

    makeTextBox(scrolling, "Specific Names", specificNamesRaw, function(text)
        specificNamesRaw = text
        updateSpecificTokens()
        for plr, data in pairs(playerData) do
            applyHighlightSettings(plr, data)
        end
    end)

    -- Sliders
    makeSlider(scrolling, "Team Highlight Transparency", teamTransparency, function(value)
        teamTransparency = value
        for plr, data in pairs(playerData) do
            applyHighlightSettings(plr, data)
        end
    end)

    makeSlider(scrolling, "All Highlight Transparency", allTransparency, function(value)
        allTransparency = value
        for plr, data in pairs(playerData) do
            applyHighlightSettings(plr, data)
        end
    end)

    makeSlider(scrolling, "Specific Outline Transparency", specificTransparency, function(value)
        specificTransparency = value
        for plr, data in pairs(playerData) do
            applyHighlightSettings(plr, data)
        end
    end)

    -- Dragging
    makeDraggable(mainFrame, topBar)

    -- Minimize
    minimizeButton.MouseButton1Click:Connect(function()
        minimized = not minimized
        contentFrame.Visible = not minimized
    end)

    -- Close (delete everything)
    closeButton.MouseButton1Click:Connect(function()
        destroyed = true
        disconnectAll()
        clearPlayerData()
        if uiScreenGui then
            uiScreenGui:Destroy()
        end
    end)
end

--////////////////////////////////////////////////
-- MAIN
--////////////////////////////////////////////////

buildUI()

-- Hook players
for _, plr in ipairs(Players:GetPlayers()) do
    onPlayerAdded(plr)
end

table.insert(connections, Players.PlayerAdded:Connect(onPlayerAdded))
table.insert(connections, Players.PlayerRemoving:Connect(onPlayerRemoving))

-- Continuous update (safety net for health/team changes)
table.insert(connections, RunService.Heartbeat:Connect(function()
    if destroyed then return end
    for plr, data in pairs(playerData) do
        if plr.Character and data.highlight and data.billboard then
            applyHighlightSettings(plr, data)
        end
    end
end))

