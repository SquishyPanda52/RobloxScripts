local function refreshAllHighlights()
    for player, _ in pairs(playerData) do
        updateHighlightForPlayer(player)
    end
end

teamToggle.MouseButton1Click:Connect(function()
    teamHighlightEnabled = not teamHighlightEnabled
    teamToggle.Text = teamHighlightEnabled and "ON" or "OFF"
    teamToggle.BackgroundColor3 = teamHighlightEnabled and Color3.fromRGB(40, 120, 40) or Color3.fromRGB(80, 80, 80)
    refreshAllHighlights()
end)

teamTeammatesToggle.MouseButton1Click:Connect(function()
    teamHighlightShowTeammates = not teamHighlightShowTeammates
    teamTeammatesToggle.Text = teamHighlightShowTeammates and "ON" or "OFF"
    teamTeammatesToggle.BackgroundColor3 = teamHighlightShowTeammates and Color3.fromRGB(40, 120, 40) or Color3.fromRGB(80, 80, 80)
    refreshAllHighlights()
end)

allToggle.MouseButton1Click:Connect(function()
    allHighlightEnabled = not allHighlightEnabled
    allToggle.Text = allHighlightEnabled and "ON" or "OFF"
    allToggle.BackgroundColor3 = allHighlightEnabled and Color3.fromRGB(40, 120, 40) or Color3.fromRGB(80, 80, 80)
    refreshAllHighlights()
end)

specificToggle.MouseButton1Click:Connect(function()
    specificHighlightEnabled = not specificHighlightEnabled
    specificToggle.Text = specificHighlightEnabled and "ON" or "OFF"
    specificToggle.BackgroundColor3 = specificHighlightEnabled and Color3.fromRGB(40, 120, 40) or Color3.fromRGB(80, 80, 80)
    refreshAllHighlights()
end)

specificBox.FocusLost:Connect(function(enterPressed)
    splitSpecificNames(specificBox.Text or "")
    if specificHighlightEnabled then
        refreshAllHighlights()
    end
end)

teamSliderRow:SetAttribute("OnValueChanged", function(alpha)
    teamTransparency = alpha
    refreshAllHighlights()
end)

allSliderRow:SetAttribute("OnValueChanged", function(alpha)
    allTransparency = alpha
    refreshAllHighlights()
end)

specificSliderRow:SetAttribute("OnValueChanged", function(alpha)
    specificTransparency = alpha
    refreshAllHighlights()
end)

minimizeButton.MouseButton1Click:Connect(function()
    minimized = not minimized
    contentFrame.Visible = not minimized
    minimizeButton.Text = minimized and "+" or "-"
end)

local function fullDestroy()
    if destroyed then return end
    destroyed = true
    uiEnabled = false

    -- Remove all visuals
    for player, _ in pairs(playerData) do
        destroyPlayerVisuals(player)
    end
    playerData = {}

    clearConnections()

    if screenGui and screenGui.Parent then
        screenGui:Destroy()
    end
end

closeButton.MouseButton1Click:Connect(function()
    fullDestroy()
end)

