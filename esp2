---------------------------------------------------------------------
-- UTILS
---------------------------------------------------------------------
local function addConnection(conn)
    table.insert(connections, conn)
    return conn
end

local function clearConnections()
    for _, c in ipairs(connections) do
        pcall(function() c:Disconnect() end)
    end
    table.clear(connections)
end

local function splitSpecificNames(text)
    specificNames = {}
    for part in string.gmatch(text, "([^,]+)") do
        local trimmed = string.lower(part:match("^%s*(.-)%s*$") or "")
        if trimmed ~= "" then
            specificNames[trimmed] = true
        end
    end
end

local function isSpecificPlayer(player)
    local lowerName = string.lower(player.Name)
    for key, _ in pairs(specificNames) do
        if string.find(lowerName, key, 1, true) then
            return true
        end
    end
    return false
end

local function getTeamColor(player)
    if player.Team and player.Team.TeamColor then
        return player.Team.TeamColor.Color
    end
    return Color3.fromRGB(255, 255, 255)
end

local function getHealthColor(humanoid)
    if not humanoid or humanoid.MaxHealth <= 0 then
        return Color3.fromRGB(255, 255, 255)
    end
    local ratio = humanoid.Health / humanoid.MaxHealth
    if ratio >= 0.7 then
        return Color3.fromRGB(0, 255, 0) -- green
    elseif ratio >= 0.4 then
        return Color3.fromRGB(255, 255, 0) -- yellow
    elseif ratio > 0 then
        return Color3.fromRGB(255, 0, 0) -- red
    else
        return Color3.fromRGB(100, 100, 100) -- dead
    end
end

local function createHighlight(character)
    local highlight = Instance.new("Highlight")
    highlight.Name = "HiltonHighlight"
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0.3
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = character
    highlight.Parent = character
    return highlight
end

local function createNameTag(character, player)
    local head = character:FindFirstChild("Head")
    if not head then return nil end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "HiltonNameTag"
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = 10000
    billboard.Adornee = head
    billboard.Parent = character

    local textLabel = Instance.new("TextLabel")
    textLabel.BackgroundTransparency = 1
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.TextScaled = true
    textLabel.Text = player.Name
    textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    textLabel.TextStrokeTransparency = 0
    textLabel.Parent = billboard

    return billboard
end

local function destroyPlayerVisuals(player)
    local data = playerData[player]
    if data then
        if data.highlight and data.highlight.Parent then
            data.highlight:Destroy()
        end
        if data.nameTag and data.nameTag.Parent then
            data.nameTag:Destroy()
        end
    end
    playerData[player] = nil
end

local function updateHighlightForPlayer(player)
    local data = playerData[player]
    if not data or not data.char then return end
    local character = data.char

    -- Ensure highlight exists
    if not data.highlight or not data.highlight.Parent then
        data.highlight = createHighlight(character)
    end
    local highlight = data.highlight

    -- Determine if this player should be highlighted and how
    local isLocal = (player == LocalPlayer)
    local teamColor = getTeamColor(player)
    local useHighlight = false
    local fillColor = teamColor
    local outlineColor = teamColor
    local transparency = 0.3

    -- All highlight
    if allHighlightEnabled then
        useHighlight = true
        fillColor = Color3.fromRGB(255, 255, 255)
        outlineColor = Color3.fromRGB(255, 255, 255)
        transparency = allTransparency
    end

    -- Team highlight
    if teamHighlightEnabled and player.Team ~= nil then
        if player.Team == LocalPlayer.Team then
            if teamHighlightShowTeammates then
                useHighlight = true
                fillColor = teamColor
                outlineColor = teamColor
                transparency = teamTransparency
            end
        else
            useHighlight = true
            fillColor = teamColor
            outlineColor = teamColor
            transparency = teamTransparency
        end
    end

    -- Specific highlight overlay
    if specificHighlightEnabled and isSpecificPlayer(player) then
        useHighlight = true
        -- Keep fill as team/all color, but outline gold
        outlineColor = Color3.fromRGB(255, 215, 0)
        transparency = specificTransparency
    end

    if useHighlight and uiEnabled then
        highlight.Enabled = true
        highlight.FillColor = fillColor
        highlight.OutlineColor = outlineColor
        highlight.FillTransparency = transparency
        highlight.OutlineTransparency = transparency
    else
        highlight.Enabled = false
    end
end

local function updateNameTagForPlayer(player)
    local data = playerData[player]
    if not data or not data.char then return end
    local character = data.char
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    if not data.nameTag or not data.nameTag.Parent then
        data.nameTag = createNameTag(character, player)
    end

    local billboard = data.nameTag
    local textLabel = billboard and billboard:FindFirstChildOfClass("TextLabel")
    if not textLabel then return end

    local color = getHealthColor(humanoid)
    textLabel.TextColor3 = color
    textLabel.TextStrokeColor3 = color
end

local function setupCharacter(player, character)
    if destroyed then return end

    -- Clean old
    destroyPlayerVisuals(player)

    local data = {}
    data.char = character
    data.highlight = createHighlight(character)
    data.nameTag = createNameTag(character, player)
    playerData[player] = data

    updateHighlightForPlayer(player)
    updateNameTagForPlayer(player)

    -- Track health changes for name color
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        addConnection(humanoid.HealthChanged:Connect(function()
            if destroyed then return end
            updateNameTagForPlayer(player)
        end))
    end
end

local function onPlayerAdded(player)
    -- Character added
    addConnection(player.CharacterAdded:Connect(function(char)
        char:WaitForChild("HumanoidRootPart", 10)
        setupCharacter(player, char)
    end))

    -- If already has character
    if player.Character then
        setupCharacter(player, player.Character)
    end
end

local function onPlayerRemoving(player)
    destroyPlayerVisuals(player)
end

