local characterData = {}

local function getTeamColor(player)
    if player.Team then
        return player.Team.TeamColor.Color
    end
    return Color3.fromRGB(255,255,255)
end

---------------------------------------------------------------------
-- HIGHLIGHT + NAME TAG
---------------------------------------------------------------------
local function createHighlightForCharacter(player, character)
    local highlight = Instance.new("Highlight")
    highlight.Adornee = character
    highlight.Parent = character

    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0,200,0,40)
    billboard.AlwaysOnTop = true
    billboard.Parent = character:FindFirstChild("Head") or character

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1,0,1,0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Text = player.Name
    nameLabel.Parent = billboard

    characterData[player] = {
        Highlight = highlight,
        Billboard = billboard,
        NameLabel = nameLabel
    }
end

---------------------------------------------------------------------
-- UPDATE
---------------------------------------------------------------------
local function update(player)
    local data = characterData[player]
    if not data then return end

    local teamColor = getTeamColor(player)

    data.NameLabel.TextColor3 = teamColor
    data.NameLabel.TextStrokeColor3 = teamColor
    data.NameLabel.TextStrokeTransparency = 0
    data.NameLabel.TextSize = nameSizeSlider.GetValue()
end

---------------------------------------------------------------------
-- LOOP
---------------------------------------------------------------------
RunService.Heartbeat:Connect(function()
    for p,_ in pairs(characterData) do
        update(p)
    end
end)

