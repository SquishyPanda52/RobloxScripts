-- HIGHLIGHT + NAME TAG MANAGEMENT
---------------------------------------------------------------------
local highlights = {} -- [player] = {Highlight = h, Billboard = b}
local specificNames = {}

local function parseSpecificNames()
    specificNames = {}
    local text = specificBox.Text or ""
    for part in string.gmatch(text, "([^,]+)") do
        local trimmed = part:lower():gsub("^%s+", ""):gsub("%s+$", "")
        if trimmed ~= "" then
            table.insert(specificNames, trimmed)
        end
    end
end

specificBox.FocusLost:Connect(parseSpecificNames)

local function isSpecificPlayer(plr)
    local nameLower = plr.Name:lower()
    for _, pattern in ipairs(specificNames) do
        if string.find(nameLower, pattern, 1, true) then
            return true
        end
    end
    return false
end

local function getHealthColor(humanoid)
    local hp = humanoid.Health
    local max = humanoid.MaxHealth > 0 and humanoid.MaxHealth or 100
    local ratio = hp / max
    if ratio >= 0.7 then
        return Color3.fromRGB(80, 255, 80)
    elseif ratio >= 0.3 then
        return Color3.fromRGB(255, 230, 80)
    else
        return Color3.fromRGB(255, 80, 80)
    end
end

local function createNameTag(character, plr)
    local head = character:FindFirstChild("Head")
    if not head then return nil end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "NameTag"
    billboard.Size = UDim2.new(0, 220, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = math.huge
    billboard.LightInfluence = 0
    billboard.Adornee = head
    billboard.Parent = character

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = plr.Name
    label.Font = Enum.Font.GothamBold
    label.TextScaled = true
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.new(0, 0, 0)
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Parent = billboard

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        label.TextColor3 = getHealthColor(humanoid)
        trackConnection(humanoid.HealthChanged:Connect(function()
            label.TextColor3 = getHealthColor(humanoid)
        end))
    end

    return billboard
end

local function createHighlight(character)
    local highlight = Instance.new("Highlight")
    highlight.Name = "PlayerHighlight"
    highlight.FillTransparency = 0.2
    highlight.OutlineTransparency = 0.2
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Adornee = character
    highlight.Parent = character
    return highlight
end

local function ensureEntry(plr)
    if not highlights[plr] then
        highlights[plr] = {Highlight = nil, Billboard = nil}
    end
end

local function setupCharacter(plr, character)
    ensureEntry(plr)

    local h = character:FindFirstChild("PlayerHighlight")
    if not h then
        h = createHighlight(character)
    end

    local tag = character:FindFirstChild("NameTag")
    if not tag then
        tag = createNameTag(character, plr)
    end

    highlights[plr].Highlight = h
    highlights[plr].Billboard = tag
end

local function onCharacterAdded(plr, character)
    setupCharacter(plr, character)
end

local function onPlayerAdded(plr)
    trackConnection(plr.CharacterAdded:Connect(function(char)
        onCharacterAdded(plr, char)
    end))
    if plr.Character then
        onCharacterAdded(plr, plr.Character)
    end
end

for _, plr in ipairs(Players:GetPlayers()) do
    onPlayerAdded(plr)
end
trackConnection(Players.PlayerAdded:Connect(onPlayerAdded))
trackConnection(Players.PlayerRemoving:Connect(function(plr)
    highlights[plr] = nil
end))

---------------------------------------------------------------------
-- UPDATE LOOP
---------------------------------------------------------------------
local function getTeamColor(plr)
    if plr.Team and plr.Team.TeamColor then
        return plr.Team.TeamColor.Color
    end
    return Color3.fromRGB(255, 255, 255)
end

local SPEC_OUTLINE_COLOR = Color3.fromRGB(255, 215, 0) -- gold
local ALL_FILL_COLOR = Color3.fromRGB(120, 200, 255)

trackConnection(RunService.RenderStepped:Connect(function()
    if not screenGui.Parent then return end

    local teamEnabled = getTeamEnabled()
    local showOwnTeam = getTeamSelfEnabled()
    local allEnabled = getAllEnabled()
    local specEnabled = getSpecificEnabled()
    local teamTrans = getTeamTrans()
    local allTrans = getAllTrans()
    local specOutlineTrans = getSpecOutlineTrans()

    for _, plr in ipairs(Players:GetPlayers()) do
        local entry = highlights[plr]
        local character = plr.Character
        if character and entry and entry.Highlight then
            local h = entry.Highlight
            if not h.Parent then
                h.Parent = character
            end
            h.Adornee = character

            local isLocal = (plr == localPlayer)
            local sameTeam = (localPlayer.Team ~= nil and plr.Team == localPlayer.Team)

            local visible = false
            local fillColor = Color3.fromRGB(255, 255, 255)
            local outlineColor = Color3.fromRGB(0, 0, 0)
            local fillTrans = 1
            local outlineTrans = 1

            if allEnabled then
                visible = true
                fillColor = ALL_FILL_COLOR
                fillTrans = allTrans
                outlineColor = Color3.new(0, 0, 0)
                outlineTrans = allTrans
            end

            if teamEnabled then
                if sameTeam then
                    if (not isLocal) or (isLocal and showOwnTeam) then
                        visible = true
                        fillColor = getTeamColor(plr)
                        fillTrans = teamTrans
                        outlineColor = fillColor
                        outlineTrans = teamTrans
                    end
                else
                    visible = true
                    fillColor = getTeamColor(plr)
                    fillTrans = teamTrans
                    outlineColor = fillColor
                    outlineTrans = teamTrans
                end
            end

            if specEnabled and isSpecificPlayer(plr) then
                visible = true
                outlineColor = SPEC_OUTLINE_COLOR
                outlineTrans = specOutlineTrans
            end

            h.Enabled = visible
            h.FillColor = fillColor
            h.OutlineColor = outlineColor
            h.FillTransparency = fillTrans
            h.OutlineTransparency = outlineTrans
        end
    end
end))
