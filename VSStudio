-- Dragging variables
local dragging = false
local dragStart = Vector2.new(0,0)
local startPos = Vector2.new(0,0)
local targetPos = Vector2.new(main.AbsolutePosition.X, main.AbsolutePosition.Y)
local currentPos = Vector2.new(main.AbsolutePosition.X, main.AbsolutePosition.Y)
local viewport = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize or Vector2.new(800,600)
local normalSize = main.Size
local minimized = false

-- Helpers
local function clamp(n, a, b) if n < a then return a elseif n > b then return b else return n end end

local function updateViewport()
    if workspace.CurrentCamera then
        viewport = workspace.CurrentCamera.ViewportSize
    end
end

-- Drag input handlers
title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = UserInputService:GetMouseLocation()
        startPos = Vector2.new(main.AbsolutePosition.X, main.AbsolutePosition.Y)
        targetPos = startPos
        currentPos = startPos
    end
end)

title.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement and dragging then
        local m = UserInputService:GetMouseLocation()
        local delta = m - dragStart
        local desired = startPos + delta
        updateViewport()
        -- keep on screen
        desired = Vector2.new(
            clamp(desired.X, 0, math.max(0, viewport.X - main.AbsoluteSize.X)),
            clamp(desired.Y, 0, math.max(0, viewport.Y - main.AbsoluteSize.Y))
        )
        targetPos = desired
    end
end)

-- Smooth follow
RunService.RenderStepped:Connect(function(dt)
    if (currentPos - targetPos).Magnitude > 0.5 then
        currentPos = currentPos:Lerp(targetPos, 0.22)
        main.Position = UDim2.new(0, math.floor(currentPos.X), 0, math.floor(currentPos.Y))
    end
end)

-- Minimize / Close
local tweenInfo = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
btnClose.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

btnMin.MouseButton1Click:Connect(function()
    if minimized then
        -- restore
        TweenService:Create(main, tweenInfo, {Size = normalSize}):Play()
        body.Visible = true
        minimized = false
    else
        normalSize = main.Size
        local target = UDim2.new(normalSize.X.Scale, normalSize.X.Offset, 0, 36)
        TweenService:Create(main, tweenInfo, {Size = target}):Play()
        body.Visible = false
        minimized = true
    end
end)

-- Speed change logic
local function setWalkSpeed(val)
    local ok, err = pcall(function()
        local char = player.Character or player.CharacterAdded:Wait()
        local humanoid = char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid")
        humanoid.WalkSpeed = val
    end)
    return ok, err
end

local function applySpeedFromInput()
    local text = txt.Text ~= "" and txt.Text or txt.PlaceholderText
    local n = tonumber(text)
    if not n then
        status.Text = "Invalid number."
        return
    end
    n = clamp(math.floor(n), 0, 500)
    local ok, err = setWalkSpeed(n)
    if ok then
        status.Text = "WalkSpeed set to "..tostring(n)
        changeBtn.BackgroundColor3 = Color3.fromRGB(40,140,40)
        wait(0.18)
        changeBtn.BackgroundColor3 = Color3.fromRGB(16,90,160)
    else
        status.Text = "Error: "..tostring(err)
    end
end

changeBtn.MouseButton1Click:Connect(function()
    applySpeedFromInput()
end)

txt.FocusLost:Connect(function(enter)
    if enter then applySpeedFromInput() end
end)

