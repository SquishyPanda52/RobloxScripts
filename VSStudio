-- close and minimize behavior
btnClose.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

local minimized = false
btnMin.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        local t = TweenService:Create(main, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 200, 0, 34)})
        t:Play()
        content.Visible = false
    else
        local t = TweenService:Create(main, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 360, 0, 160)})
        t:Play()
        delay(0.25, function() content.Visible = true end)
    end
end)

-- smooth draggable
local dragging, dragInput, dragStart, startPos
local function update(input)
    local delta = input.Position - dragStart
    local goal = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    local tween = TweenService:Create(main, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Position = goal})
    tween:Play()
end

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

titleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

RunService.RenderStepped:Connect(function()
    if dragging and dragInput then
        update(dragInput)
    end
end)

-- speed change logic
local function setSpeedFromText(txt)
    local n = tonumber(txt)
    if not n then
        speedBox.Text = ""
        speedBox.PlaceholderText = "Invalid number"
        return
    end
    if n < 0 then n = 0 end
    if n > 500 then n = 500 end
    humanoid.WalkSpeed = n
    speedBox.Text = ""
    speedBox.PlaceholderText = tostring(n)
    -- small visual feedback
    local orig = changeBtn.BackgroundColor3
    changeBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 120)
    delay(0.25, function() if changeBtn then changeBtn.BackgroundColor3 = orig end end)
end

changeBtn.MouseButton1Click:Connect(function()
    setSpeedFromText(speedBox.Text ~= "" and speedBox.Text or speedBox.PlaceholderText)
end)

speedBox.FocusLost:Connect(function(enter)
    if enter then
        setSpeedFromText(speedBox.Text)
    end
end)

-- keyboard quick apply (Enter)
player:GetMouse().KeyDown:Connect(function(key)
    if key == "\r" or key == "\n" then
        if screenGui and screenGui.Parent then
            setSpeedFromText(speedBox.Text ~= "" and speedBox.Text or speedBox.PlaceholderText)
        end
    end
end)
