local enabled = false
local autoRunning = false
--////////////////////////////////////////////////////
-- Commander Handling
--////////////////////////////////////////////////////

local function splitCommanders()
	local results = {}

	for entry in string.gmatch(commanderBox.Text, "[^,]+") do
		entry = entry:gsub("^%s+", "")
		entry = entry:gsub("%s+$", "")

		if entry ~= "" then
			table.insert(results, string.lower(entry))
		end
	end

	return results
end

local function isCommander(playerName)
	local lowerName = string.lower(playerName)

	for _, commander in ipairs(splitCommanders()) do
		if string.find(lowerName, commander, 1, true) then
			return true
		end
	end

	return false
end

--////////////////////////////////////////////////////
-- Key Pressing
--////////////////////////////////////////////////////

local function pressKey()
	local keyText = string.upper(keyBox.Text)

	if keyText == "" then
		return
	end

	local success, keyCode = pcall(function()
		return Enum.KeyCode[keyText]
	end)

	if not success or not keyCode then
		return
	end

	pcall(function()
		VirtualInputManager:SendKeyEvent(
			true,
			keyCode,
			false,
			game
		)

		task.wait(0.05)

		VirtualInputManager:SendKeyEvent(
			false,
			keyCode,
			false,
			game
		)
	end)
end

local loopThread

local function stopLoop()
	autoRunning = false
end

local function startLoop()
	if autoRunning then
		return
	end

	autoRunning = true

	loopThread = task.spawn(function()

		while autoRunning and not destroyed do

			local cooldown =
				tonumber(cooldownBox.Text)
				or 1

			cooldown = math.max(0.05, cooldown)

			statusLabel.Text =
				"Running (" ..
				string.upper(keyBox.Text) ..
				" every " ..
				tostring(cooldown) ..
				"s)"

			pressKey()

			local startTime = tick()

			repeat
				task.wait(0.1)
			until
				not autoRunning
				or destroyed
				or (tick() - startTime >= cooldown)

		end

		statusLabel.Text = "Waiting for .start"
	end)
end

