--// Cooldown Disabler (Client-Side)
--// Runs at runtime only. Disables cooldowns for abilities 1–5.
--// Includes debugging output.

local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

print("[CooldownDisabler] Script started.")

--// Wait for your custom hotbar
local hotbar = playerGui:WaitForChild("Hotbar", 10)
if not hotbar then
    warn("[CooldownDisabler] Hotbar not found. Check UI name.")
    return
end

print("[CooldownDisabler] Hotbar found.")

--// Ability slot names (change if needed)
local abilitySlots = {
    "1", "2", "3", "4", "5"
}

--// Function to instantly reset cooldown visuals
local function resetCooldown(slot)
    -- Remove cooldown frame, timer text, etc.
    for _, obj in ipairs(slot:GetChildren()) do
        if obj:IsA("Frame") or obj:IsA("ImageLabel") then
            if obj.Name:lower():find("cool") then
                obj.Visible = false
                print("[CooldownDisabler] Hid cooldown UI for slot:", slot.Name)
            end
        end
        if obj:IsA("TextLabel") then
            if obj.Name:lower():find("cool") or obj.Text:match("%d") then
                obj.Text = ""
                print("[CooldownDisabler] Cleared cooldown text for slot:", slot.Name)
            end
        end
    end
end

--// Loop that constantly forces cooldowns off
task.spawn(function()
    while true do
        for _, slotName in ipairs(abilitySlots) do
            local slot = hotbar:FindFirstChild(slotName)
            if slot then
                resetCooldown(slot)
            else
                warn("[CooldownDisabler] Slot missing:", slotName)
            end
        end
        task.wait(0.1) -- fast refresh
    end
end)

print("[CooldownDisabler] Cooldown override active.")
