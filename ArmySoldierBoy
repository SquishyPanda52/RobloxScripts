        if not (followEnabled or attackEnabled) then
            stopWalkFix()
        end
    end
end

local function startTeamAttack()
    if teamAttackConn then
        teamAttackConn:Disconnect()
        teamAttackConn = nil
    end
    teamAttackConn = RunService.Heartbeat:Connect(function()
        if not teamAttackEnabled or #teamAttackNames == 0 then return end

        local myHum = getHumanoid(localPlayer)
        local myRoot = getHRP(localPlayer)
        if not (myHum and myRoot) or myHum.Health <= 0 then
            return
        end

        local closestDist, targetPos
        for _, tname in ipairs(teamAttackNames) do
            local frag = trim(tname):lower()
            if frag ~= "" then
                for _, pl in ipairs(Players:GetPlayers()) do
                    if pl ~= localPlayer and pl.Team and pl.Team.Name then
                        local teamNameLower = tostring(pl.Team.Name):lower()
                        if teamNameLower:find(frag, 1, true) then
                            local hrp = getHRP(pl)
                            if hrp then
                                local d = (hrp.Position - myRoot.Position).Magnitude
                                if not closestDist or d < closestDist then
                                    closestDist, targetPos = d, hrp.Position
                                end
                            end
                        end
                    end
                end
            end
        end

        if targetPos then
            myHum:MoveTo(targetPos)
        end
    end)
    table.insert(connections, teamAttackConn)

    if not autoPressConn then
        startAutoPress()
    end
    if lockedEnabled then
        if followEnabled or attackEnabled then
            startWalkFix()
        end
    end
end

local function startAttack()
    if attackConn then
        attackConn:Disconnect()
        attackConn = nil
    end
    attackConn = RunService.Heartbeat:Connect(function()
        if not attackEnabled or #attackNames == 0 then return end

        local myHum = getHumanoid(localPlayer)
        local myRoot = getHRP(localPlayer)
        if not (myHum and myRoot) or myHum.Health <= 0 then
            return
        end

        local closestDist, targetPos
        for _, uname in ipairs(attackNames) do
            local pl = findClosestPlayer(uname)
            local hrp = pl and getHRP(pl)
            if hrp then
                local d = (hrp.Position - myRoot.Position).Magnitude
                if not closestDist or d < closestDist then
                    closestDist, targetPos = d, hrp.Position
                end
            end
        end

        if targetPos then
            myHum:MoveTo(targetPos)
        end
    end)
    table.insert(connections, attackConn)

    if not autoPressConn then
        startAutoPress()
    end
    if lockedEnabled then
        if followEnabled or attackEnabled then
            startWalkFix()
        end
    end
end

-- Walk Fix helpers (two-interval model: key + hold duration; repeats immediately)
local function parseWalkPattern(text)
    text = tostring(text or ""):gsub("%s+", " ")
    local parts = {}
    for p in text:gmatch("%S+") do
        table.insert(parts, p)
    end
    -- Accept "W 10" or "W,10"
    if #parts < 2 then
        -- try comma split
        local commaParts = {}
        for p in tostring(text or ""):gmatch("([^,]+)") do
            table.insert(commaParts, trim(p))
        end
        if #commaParts >= 2 then
            parts = commaParts
        end
    end
    if #parts < 2 then
        return nil
    end
    local keyStr = tostring(parts[1] or "W")
    local holdRaw = tonumber(parts[2]) or 10
    local hold = math.max(0.01, holdRaw) -- hold in seconds
    return { key = keyStr, hold = hold }
end

local function keyStringToEnum(keyStr)
    if not keyStr then return nil end
    local k = tostring(keyStr):upper()
    -- If single letter A-Z, Enum.KeyCode.A etc works
    if Enum.KeyCode[k] then
        return Enum.KeyCode[k]
    end
    -- handle numeric keys "1".."0"
    if #k == 1 and k:match("%d") then
        local map = {
            ["1"] = "One", ["2"] = "Two", ["3"] = "Three", ["4"] = "Four",
            ["5"] = "Five", ["6"] = "Six", ["7"] = "Seven", ["8"] = "Eight",
            ["9"] = "Nine", ["0"] = "Zero"
        }
        local name = map[k]
        if name and Enum.KeyCode[name] then
            return Enum.KeyCode[name]
        end
    end
    -- fallback: try direct Enum lookup
    local ok, val = pcall(function() return Enum.KeyCode[k] end)
    if ok and val then return val end
    return nil
end

local function startWalkFix()
    if walkFixConn then
        walkFixConn:Disconnect()
        walkFixConn = nil
    end
    local pattern = parseWalkPattern(walkPatternText) or parseWalkPattern("W 10")
    local keyEnum = keyStringToEnum(pattern.key)
    if not keyEnum then
        return
    end
    walkFixEnabled = true
    setBtnState(walkFixBtn, true, "WalkFix")
    local running = true
    walkFixConn = RunService.Heartbeat:Connect(function()
        if not walkFixEnabled or not running then return end
        running = false
        -- press down
        pcall(function()
            VirtualInputManager:SendKeyEvent(true, keyEnum, false, game)
        end)
        -- hold for pattern.hold seconds, then release and immediately start again
        task.delay(pattern.hold, function()
            pcall(function()
                VirtualInputManager:SendKeyEvent(false, keyEnum, false, game)
            end)
            running = true
        end)
    end)
    table.insert(connections, walkFixConn)
end

local function stopWalkFix()
    walkFixEnabled = false
    if walkFixConn then
        walkFixConn:Disconnect()
        walkFixConn = nil
    end
    setBtnState(walkFixBtn, false, "WalkFix")
end

