-- 🔥 KEYBINDS: T focuses attackBox, R toggles Attack, Y toggles Follow
table.insert(connections, UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    -- T = focus Attack textbox
    if input.KeyCode == Enum.KeyCode.T then
        if attackBox then
            attackBox:CaptureFocus()
        end
    end

    -- R = toggle Attack ONLY if attackBox is not focused
    if input.KeyCode == Enum.KeyCode.R then
        if attackBox and not attackBox:IsFocused() then
            onAttackToggle()
        end
    end

    -- Y = toggle Follow ONLY if followBox is not focused
    if input.KeyCode == Enum.KeyCode.Y then
        if followBox and not followBox:IsFocused() then
            onFollowToggle()
        end
    end
end))
