--// PARSE USER INPUT
local function getTargetPlayers()
    local raw = TextBox.Text
    local names = {}

    for part in string.gmatch(raw, "([^,]+)") do
        table.insert(names, string.lower(part:gsub("%s+", "")))
    end

    local matched = {}

    for _, plr in ipairs(Players:GetPlayers()) do
        local lowerName = string.lower(plr.Name)
        for _, partial in ipairs(names) do
            if partial ~= "" and string.find(lowerName, partial, 1, true) then
                table.insert(matched, plr)
            end
        end
    end

    return matched
end

--// CHAT LISTENER
TextChatService.MessageReceived:Connect(function(message)
    local sender = message.TextSource
    if not sender then return end

    local senderPlayer = Players:GetPlayerByUserId(sender.UserId)
    if not senderPlayer then return end

    -- Check if sender matches textbox list
    local targets = getTargetPlayers()
    local isTarget = false

    for _, plr in ipairs(targets) do
        if plr == senderPlayer then
            isTarget = true
            break
        end
    end

    if not isTarget then return end

    -- COMMANDS
    local msg = string.lower(message.Text)

    if msg == ".jump" then
        local char = LocalPlayer.Character
        if char and char:FindFirstChildOfClass("Humanoid") then
            char:FindFirstChildOfClass("Humanoid").Jump = true
        end
    end
end)
