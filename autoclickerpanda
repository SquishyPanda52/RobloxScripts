    delayBox.PlaceholderText = "Delay (s)"

    rows[i] = {
        key = keyBox,
        clicks = clicksBox,
        cooldown = cooldownBox,
        delay = delayBox,
        loop = nil
    }

    local function update()
        if not destroyed then
            startLoop(rows[i])
        end
    end

    keyBox.FocusLost:Connect(update)
    clicksBox.FocusLost:Connect(update)
    cooldownBox.FocusLost:Connect(update)
    delayBox.FocusLost:Connect(update)

    recalcCanvasSize()
end

for i = 1, 7 do
    createRow(i)
end

