    keyBox.Parent = scroll

    local intervalBox = Instance.new("TextBox")
    intervalBox.Size = UDim2.new(0, 80, 0, 30)
    intervalBox.Position = UDim2.new(0, 70, 0, y)
    intervalBox.ZIndex = 999999
    intervalBox.PlaceholderText = ""
    intervalBox.Parent = scroll

    local holdBox = Instance.new("TextBox")
    holdBox.Size = UDim2.new(0, 80, 0, 30)
    holdBox.Position = UDim2.new(0, 160, 0, y)
    holdBox.ZIndex = 999999
    holdBox.PlaceholderText = ""
    holdBox.Parent = scroll

    local row = makeRowObject(keyBox, intervalBox, holdBox)
    rows[i] = row

    -- initial parse
    updateRowParsed(row)

    -- re-parse on focus lost (safe, lightweight)
    local function onEdit()
        if destroyed then return end
        updateRowParsed(row)
    end
    keyBox.FocusLost:Connect(onEdit)
    intervalBox.FocusLost:Connect(onEdit)
    holdBox.FocusLost:Connect(onEdit)
end

