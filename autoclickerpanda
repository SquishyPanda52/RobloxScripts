--////////////////////////////////////////////////////
-- DRAGGING FUNCTION
--////////////////////////////////////////////////////

local function makeDraggable(dragObject, moveObject)

	local dragging = false
	local dragInput
	local dragStart
	local startPos

	table.insert(connections, dragObject.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then

			dragging = true
			dragStart = input.Position
			startPos = moveObject.Position

			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end))

	table.insert(connections, dragObject.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement then
			dragInput = input
		end
	end))

	table.insert(connections, UserInputService.InputChanged:Connect(function(input)

		if dragging and input == dragInput then

			local delta = input.Position - dragStart

			moveObject.Position = UDim2.new(
				startPos.X.Scale,
				startPos.X.Offset + delta.X,
				startPos.Y.Scale,
				startPos.Y.Offset + delta.Y
			)
		end
	end))
end

makeDraggable(topBar, frame)
makeDraggable(clickPoint, clickPoint)

--////////////////////////////////////////////////////
-- CLICK FUNCTION
--////////////////////////////////////////////////////

local function doClick()

	-- EXACT CENTER OF RED CIRCLE
	local pos = clickPoint.AbsolutePosition
	local size = clickPoint.AbsoluteSize

	local x = pos.X + (size.X / 2)
	local y = pos.Y + (size.Y / 2)

	VirtualInputManager:SendMouseButtonEvent(
		x,
		y,
		0,
		true,
		game,
		0
	)

	VirtualInputManager:SendMouseButtonEvent(
		x,
		y,
		0,
		false,
		game,
		0
	)
end

--////////////////////////////////////////////////////
-- AUTO CLICK LOOP
--////////////////////////////////////////////////////

local function startClicking()

	if clickingThread then
		return
	end

	clickingThread = task.spawn(function()

		local cps = tonumber(speedBox.Text) or 10
		if cps <= 0 then
			cps = 10
		end

		local duration = tonumber(durationBox.Text) or 0
		local delayTime = 1 / cps
		local startTime = tick()

		print("[AutoClicker] Started")

		while enabled and not destroyed do

			doClick()

			if duration > 0 then
				if tick() - startTime >= duration then
					print("[AutoClicker] Duration ended")
					enabled = false
					break
				end
			end

			task.wait(delayTime)
		end

		status.Text = "OFF"
		status.TextColor3 = Color3.fromRGB(255,80,80)

		clickingThread = nil

		print("[AutoClicker] Stopped")

	end)
end

--////////////////////////////////////////////////////
-- TOGGLE
--////////////////////////////////////////////////////

table.insert(connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)

	if destroyed then
		return
	end

	if gameProcessed then
		return
	end

	if input.KeyCode == Enum.KeyCode.Y then

		enabled = not enabled

		if enabled then

			status.Text = "ON"
			status.TextColor3 = Color3.fromRGB(80,255,80)

			startClicking()

		else

			status.Text = "OFF"
			status.TextColor3 = Color3.fromRGB(255,80,80)

		end

		print("[AutoClicker] Toggle:", enabled)
	end
end))

