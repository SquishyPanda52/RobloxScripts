---------------------------------------------------------------------
-- DRAG
---------------------------------------------------------------------

local dragging = false
local dragStart
local startPos

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
    end
end)

frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

---------------------------------------------------------------------
-- ROWS (now with 4 boxes: key, clicks, cooldown, delay)
---------------------------------------------------------------------

local rows = {}
local ROW_HEIGHT = 40
local ROW_PADDING_BOTTOM = 10
local NOTES_HEIGHT = 80
local NOTES_PADDING = 10

local function recalcCanvasSize()
    local totalRows = #rows
    local contentHeight = totalRows * ROW_HEIGHT
    -- include notes area at bottom
    local canvasTotal = contentHeight + NOTES_HEIGHT + NOTES_PADDING * 2
    scroll.CanvasSize = UDim2.new(0, 0, 0, canvasTotal)
end

local function startLoop(row)
    if row.loop then
        row.loop:Disconnect()
        row.loop = nil
    end

    local keyCode = resolveKey(row.key.Text)
    local clicks = tonumber(row.clicks.Text)
    local cooldown = tonumber(row.cooldown.Text)
    local delay = tonumber(row.delay.Text)

    if not keyCode or not clicks or not cooldown or not delay then return end
    if clicks < 1 then return end

    row.loop = RunService.Heartbeat:Connect(function()
        if enabled and not destroyed then
            -- perform the configured number of clicks
            task.spawn(function()
                for i = 1, clicks do
                    if destroyed then break end
                    VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
                    task.wait(0.05)
                    VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
                    -- small gap between repeated clicks
                    if i < clicks then
                        task.wait(0.05)
                    end
                end
            end)
            -- wait the cooldown period (box 3)
            task.wait(cooldown)
            -- wait the additional delay before restarting (box 4)
            task.wait(delay)
        end
    end)
end

local function createRow(i)
    local y = (i - 1) * ROW_HEIGHT

    local keyBox = Instance.new("TextBox")
    keyBox.Size = UDim2.new(0, 60, 0, 30)
    keyBox.Position = UDim2.new(0, 0, 0, y)
