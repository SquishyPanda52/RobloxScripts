---------------------------------------------------------------------
-- CMD / COMMANDERS LOGIC
---------------------------------------------------------------------

local function parseCommanders(text)
    local list = {}
    if not text then return list end
    for part in string.gmatch(text, "[^,]+") do
        local trimmed = part:match("^%s*(.-)%s*$")
        if trimmed ~= "" then
            table.insert(list, string.lower(trimmed))
        end
    end
    return list
end

local function isCommanderName(playerName)
    if not playerName then return false end
    local lowerName = string.lower(playerName)
    for _, sub in ipairs(commanders) do
        if sub ~= "" and string.find(lowerName, sub, 1, true) then
            return true
        end
    end
    return false
end

local function onPlayerChatted(p, message)
    if destroyed then return end
    if not cmdEnabled then return end
    if not message or message == "" then return end
    if #commanders == 0 then return end
    if not isCommanderName(p.Name) then return end

    local msg = tostring(message)
    local msgLower = string.lower(msg):gsub("^%s+", "")

    -- Attack commands -> toggle on
    if msgLower:match("^%.atk") or msgLower:match("^%.attack") then
        enabled = true
        updateToggle()
        return
    end

    -- Stop/follow/goto/hold -> toggle off
    if msgLower:match("^%.stop") or msgLower:match("^%.follow") or msgLower:match("^%.goto") or msgLower:match("^%.hold") then
        enabled = false
        updateToggle()
        return
    end
end

local function connectPlayerChat(p)
    if playerConnections[p] then return end
    local conn = p.Chatted:Connect(function(msg)
        onPlayerChatted(p, msg)
    end)
    playerConnections[p] = conn
end

local function disconnectPlayerChat(p)
    local conn = playerConnections[p]
    if conn then
        conn:Disconnect()
        playerConnections[p] = nil
    end
end

-- Connect existing players
for _, p in ipairs(Players:GetPlayers()) do
    connectPlayerChat(p)
end

-- Connect future players
Players.PlayerAdded:Connect(function(p)
    connectPlayerChat(p)
end)

Players.PlayerRemoving:Connect(function(p)
    disconnectPlayerChat(p)
end)

