	else
		frame.Size = UDim2.new(0,280,0,180)
		minimizeBtn.Text = "-"
	end
end)

--////////////////////////////////////////////////////
-- FULL CLEANUP
--////////////////////////////////////////////////////

local function destroyEverything()

	destroyed = true
	enabled = false

	for _, conn in pairs(connections) do
		pcall(function()
			conn:Disconnect()
		end)
	end

	if gui then
		gui:Destroy()
	end

	print("[AutoClicker] Fully Destroyed")
end

closeBtn.MouseButton1Click:Connect(function()
	destroyEverything()
end)

