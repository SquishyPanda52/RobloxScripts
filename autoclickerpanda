---------------------------------------------------------------------
-- DRAG
---------------------------------------------------------------------
local dragging = false
local dragStart
local startPos

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = frame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

---------------------------------------------------------------------
-- ROWS (7 rows, each with 3 textboxes)
-- Left: key name (string)
-- Middle: cooldown (number) seconds between presses
-- Right: hold (number) seconds to hold the key continuously
---------------------------------------------------------------------
local rows = {}

local function parseNumberSafe(s)
    if not s then return nil end
    local cleaned = tostring(s):gsub("%s+", "")
    if cleaned == "" then return nil end
    return tonumber(cleaned)
end

local function makeRowObject(keyBox, intervalBox, holdBox)
    return {
        keyBox = keyBox,
        intervalBox = intervalBox,
        holdBox = holdBox,
        keyCode = nil,
        interval = nil,
        hold = nil,
        nextTime = 0,
        pressing = false,
        holdEndTime = 0,
        _lastKeyText = nil,
        _lastIntervalText = nil,
        _lastHoldText = nil
    }
end

local function updateRowParsed(row)
    local keyText = tostring(row.keyBox.Text or "")
    row.keyCode = resolveKey(keyText)

    local intervalNum = parseNumberSafe(row.intervalBox.Text)
    local holdNum = parseNumberSafe(row.holdBox.Text)

    if intervalNum and intervalNum > 0 then
        row.interval = intervalNum
    else
        row.interval = nil
    end

    if holdNum and holdNum >= 0 then
        row.hold = holdNum
    else
        row.hold = nil
    end

    if row.nextTime == 0 then
        row.nextTime = tick() + (math.random() * 0.2)
    end
end

for i = 1, 7 do
    local y = (i - 1) * 40

    local keyBox = Instance.new("TextBox")
    keyBox.Size = UDim2.new(0, 60, 0, 30)
    keyBox.Position = UDim2.new(0, 0, 0, y)
    keyBox.ZIndex = 999999
