--------------------------------------------------------------------
-- SLIDER LOGIC
--------------------------------------------------------------------

local draggingSlider = false

local function updateSliderVisual()
    local barSize = sliderBar.AbsoluteSize.X
    local t = math.clamp(predictionStrength, 0, 1)
    local x = t * barSize
    sliderKnob.Position = UDim2.new(0, sliderBar.Position.X.Offset + x - 5, 0, 31)
    valueLabel.Text = string.format("%.2f", predictionStrength)
end

local function setStrengthFromX(x)
    local barPos = sliderBar.AbsolutePosition.X
    local barSize = sliderBar.AbsoluteSize.X
    local rel = math.clamp(x - barPos, 0, barSize)
    predictionStrength = round(rel / barSize, 2)
    updateSliderVisual()
end

sliderBar.InputBegan:Connect(function(input)
    if autoPredictEnabled then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = true
        setStrengthFromX(input.Position.X)
    end
end)

sliderKnob.InputBegan:Connect(function(input)
    if autoPredictEnabled then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = true
    end
end)

UserInput.InputChanged:Connect(function(input)
    if draggingSlider and not autoPredictEnabled and input.UserInputType == Enum.UserInputType.MouseMovement then
        setStrengthFromX(input.Position.X)
    end
end)

UserInput.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end
end)

