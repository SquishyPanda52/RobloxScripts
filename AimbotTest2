local function updateButtons()
    btnAimbot.Text = "Aimbot: " .. (aimbotEnabled and "ON" or "OFF")
    btnAimbot.BackgroundColor3 = aimbotEnabled and Color3.fromRGB(0, 70, 0) or Color3.fromRGB(70, 0, 0)

    btnPredict.Text = "Predict: " .. (predictEnabled and "ON" or "OFF")
    btnPredict.BackgroundColor3 = predictEnabled and Color3.fromRGB(0, 70, 0) or Color3.fromRGB(70, 0, 0)

    btnAuto.Text = "Auto Predict: " .. (autoPredictEnabled and "ON" or "OFF")
    btnAuto.BackgroundColor3 = autoPredictEnabled and Color3.fromRGB(0, 70, 0) or Color3.fromRGB(70, 0, 0)

    -- Grey out slider when auto predict is ON
    local grey = autoPredictEnabled
    sliderBar.BackgroundColor3 = grey and Color3.fromRGB(60, 60, 60) or Color3.fromRGB(40, 40, 40)
    sliderKnob.BackgroundColor3 = grey and Color3.fromRGB(120, 120, 120) or Color3.fromRGB(200, 200, 200)
    valueLabel.TextColor3 = grey and Color3.fromRGB(150, 150, 150) or Color3.fromRGB(0, 255, 0)
end

local function stopConnectionIfNeeded()
    if not aimbotEnabled and not predictEnabled and not autoPredictEnabled then
        if aimConnection then aimConnection:Disconnect() end
        aimConnection = nil
    end
end

local function toggleAimbot()
    aimbotEnabled = not aimbotEnabled
    if aimbotEnabled then
        predictEnabled = false
        autoPredictEnabled = false
        startAimbot()
    end
    updateButtons()
    stopConnectionIfNeeded()
end

local function togglePredict()
    predictEnabled = not predictEnabled
    if predictEnabled then
        aimbotEnabled = false
        autoPredictEnabled = false
        startAimbot()
    end
    updateButtons()
    stopConnectionIfNeeded()
end

local function toggleAuto()
    autoPredictEnabled = not autoPredictEnabled
    if autoPredictEnabled then
        aimbotEnabled = false
        predictEnabled = false
        startAimbot()
    end
    updateButtons()
    stopConnectionIfNeeded()
end

btnAimbot.MouseButton1Click:Connect(toggleAimbot)
btnPredict.MouseButton1Click:Connect(togglePredict)
btnAuto.MouseButton1Click:Connect(toggleAuto)

