-- Highlight UI LocalScript
-- Place this LocalScript in StarterPlayerScripts (or run at runtime on the client)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local localPlayer = Players.LocalPlayer
local playerGui = localPlayer:WaitForChild("PlayerGui")

-- Container to hold all created objects so deletion is easy
local container = Instance.new("Folder")
container.Name = "HighlightUI_Container"
container.Parent = playerGui

-- Tables to track created objects and connections
local createdHighlights = {} -- [player.UserId] = {team = Highlight, specific = Highlight, all = Highlight}
local nameTags = {} -- [player.UserId] = BillboardGui
local connections = {} -- list of connections to disconnect on cleanup

-- Settings state
local state = {
    teamHighlightEnabled = true,
    showOwnTeammates = true,
    allHighlightEnabled = false,
    specificHighlightEnabled = true,
    teamTransparency = 0.3,
    allTransparency = 0.3,
    specificOutlineTransparency = 0.0,
    specificNames = {}, -- list of lowercase substrings
}

-- Utility functions
local function roundToStep(value, step)
    return math.floor(value/step + 0.5) * step
end

local function parseSpecificText(text)
    local list = {}
    for token in string.gmatch(text, "[^,]+") do
        local trimmed = token:match("^%s*(.-)%s*$")
        if trimmed ~= "" then
            table.insert(list, string.lower(trimmed))
        end
    end
    return list
end

local function isSpecificMatch(playerName)
    local lower = string.lower(playerName)
    for _, sub in ipairs(state.specificNames) do
        if string.find(lower, sub, 1, true) then
            return true
        end
    end
    return false
end

local function safeColor3FromTeam(player)
    if player and player.TeamColor then
        local c = player.TeamColor.Color
        return c
    end
    return Color3.fromRGB(255,255,255)
end

-- Create or update highlight objects for a player
local function ensureHighlightsForPlayer(player)
    if not player or not player.Character then return end
    local uid = player.UserId
    createdHighlights[uid] = createdHighlights[uid] or {}
    local t = createdHighlights[uid]

    -- Helper to create a Highlight if missing
    local function makeHighlight(key)
        if t[key] and t[key].Parent then return t[key] end
        local h = Instance.new("Highlight")
        h.Name = "HL_" .. key
        h.Adornee = player.Character
        h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        h.Parent = container
        t[key] = h
        return h
    end

    -- Team highlight
    local teamH = makeHighlight("team")
    teamH.FillColor = safeColor3FromTeam(player)
    teamH.OutlineColor = safeColor3FromTeam(player)
    teamH.FillTransparency = state.teamTransparency
    teamH.OutlineTransparency = state.teamTransparency

    -- All highlight
    local allH = makeHighlight("all")
    allH.FillColor = safeColor3FromTeam(player)
    allH.OutlineColor = safeColor3FromTeam(player)
    allH.FillTransparency = state.allTransparency
    allH.OutlineTransparency = state.allTransparency

    -- Specific highlight (overlay)
    local specH = makeHighlight("specific")
    specH.FillColor = safeColor3FromTeam(player)
    specH.OutlineColor = Color3.fromRGB(255, 215, 0) -- gold
    specH.FillTransparency = state.teamTransparency -- keep fill same as team by default
    specH.OutlineTransparency = state.specificOutlineTransparency

    -- Set enabled states
    teamH.Enabled = state.teamHighlightEnabled and (state.showOwnTeammates or player ~= localPlayer or (player.Team ~= localPlayer.Team))
    allH.Enabled = state.allHighlightEnabled
    specH.Enabled = state.specificHighlightEnabled and isSpecificMatch(player.Name)

    -- If specific overlay is enabled for this player, make outline gold and visible
    if specH.Enabled then
        -- ensure outline stands out
        specH.OutlineColor = Color3.fromRGB(255, 215, 0)
        -- make fill slightly less transparent so outline shows
        specH.FillTransparency = math.clamp(state.teamTransparency, 0, 1)
    end
end

-- Remove highlights for a player (when they leave)
local function removeHighlightsForPlayer(player)
    local uid = player.UserId
    local t = createdHighlights[uid]
    if t then
        for k, h in pairs(t) do
            if h and h.Parent then
                h:Destroy()
            end
        end
        createdHighlights[uid] = nil
    end
    -- remove name tag
    local tag = nameTags[player.UserId]
    if tag and tag.Parent then
        tag:Destroy()
    end
    nameTags[player.UserId] = nil
end

-- Create name tag for a player
local function createNameTag(player)
    if not player or not player.Character then return end
    local uid = player.UserId
    if nameTags[uid] then return nameTags[uid] end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "NameTag_" .. player.Name
    billboard.Adornee = player.Character:FindFirstChild("HumanoidRootPart") or player.Character:FindFirstChildWhichIsA("BasePart")
    billboard.Size = UDim2.new(0, 300, 0, 60)
    billboard.StudsOffset = Vector3.new(0, 3.5, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = 1000
    billboard.Parent = container

    local label = Instance.new("TextLabel")
    label.Name = "NameLabel"
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = player.Name
    label.Font = Enum.Font.SourceSansBold
    label.TextSize = 28
    label.TextScaled = true
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.new(0,0,0)
    label.TextColor3 = Color3.new(1,1,1)
    label.Parent = billboard

    nameTags[uid] = billboard
    return billboard
end

-- Update name tag color based on health
local function updateNameTagHealth(player)
    local tag = nameTags[player.UserId]
    if not tag or not player.Character then return end
    local humanoid = player.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local health = humanoid.Health
    local maxHealth = humanoid.MaxHealth
    local pct = 0
    if maxHealth > 0 then pct = health / maxHealth end

    local color
    if pct > 0.66 then
        color = Color3.fromRGB(0, 255, 0) -- green
    elseif pct > 0.33 then
        color = Color3.fromRGB(255, 200, 0) -- yellow
    else
        color = Color3.fromRGB(255, 0, 0) -- red
    end

    local label = tag:FindFirstChild("NameLabel")
    if label then
        label.TextColor3 = color
        label.TextStrokeColor3 = Color3.new(0,0,0)
    end
end

-- Reapply highlights and name tags for all players (used on setting changes)
local function refreshAllPlayers()
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Character then
            ensureHighlightsForPlayer(player)
            createNameTag(player)
            updateNameTagHealth(player)
        end
    end
end

-- Character added handler to reapply highlights and name tags on respawn
local function onCharacterAdded(player, character)
    -- small delay to allow parts to exist
    task.wait(0.1)
    ensureHighlightsForPlayer(player)
    createNameTag(player)

    -- connect health changed for name tag color updates
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        local conn = humanoid.HealthChanged:Connect(function()
            updateNameTagHealth(player)
        end)
        table.insert(connections, conn)
    end
end

-- Player added/removed handlers
local function onPlayerAdded(player)
    local conn = player.CharacterAdded:Connect(function(char) onCharacterAdded(player, char) end)
    table.insert(connections, conn)
    if player.Character then
        onCharacterAdded(player, player.Character)
    end
end

local function onPlayerRemoving(player)
    removeHighlightsForPlayer(player)
end

-- Connect existing players
for _, p in ipairs(Players:GetPlayers()) do
    onPlayerAdded(p)
end
table.insert(connections, Players.PlayerAdded:Connect(onPlayerAdded))
table.insert(connections, Players.PlayerRemoving:Connect(onPlayerRemoving))

