minBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        scroll.Visible = false
        mainFrame.Size = UDim2.new(0, 220, 0, 36)
    else
        scroll.Visible = true
        mainFrame.Size = UDim2.new(0, 420, 0, 360)
    end
end)

-- Full delete behavior: destroy everything and disconnect
local function cleanupAndDeleteAll()
    -- Disconnect connections
    for _, conn in ipairs(connections) do
        if conn and conn.Disconnect then
            pcall(function() conn:Disconnect() end)
        end
    end
    connections = {}

    -- Destroy created highlights and tags
    for uid, tbl in pairs(createdHighlights) do
        for k, h in pairs(tbl) do
            if h and h.Parent then
                pcall(function() h:Destroy() end)
            end
        end
    end
    createdHighlights = {}

    for uid, tag in pairs(nameTags) do
        if tag and tag.Parent then
            pcall(function() tag:Destroy() end)
        end
    end
    nameTags = {}

    -- Destroy UI and container
    if container and container.Parent then
        pcall(function() container:Destroy() end)
    end

    -- Destroy this script (LocalScript)
    local thisScript = script
    if thisScript and thisScript.Parent then
        pcall(function() thisScript:Destroy() end)
    end
end

delBtn.MouseButton1Click:Connect(function()
    cleanupAndDeleteAll()
end)

