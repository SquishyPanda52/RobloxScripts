-- Toggle helper
local function makeToggle(parent, text, initial, onToggle)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 120, 0, 28)
    btn.Position = UDim2.new(1, -130, 0, 4)
    btn.AnchorPoint = Vector2.new(1,0)
    btn.BackgroundColor3 = initial and Color3.fromRGB(0,170,0) or Color3.fromRGB(120,120,120)
    btn.Text = initial and "ON" or "OFF"
    btn.Font = Enum.Font.SourceSansBold
    btn.TextSize = 14
    btn.Parent = parent

    btn.MouseButton1Click:Connect(function()
        local new = not (btn.Text == "ON")
        btn.Text = new and "ON" or "OFF"
        btn.BackgroundColor3 = new and Color3.fromRGB(0,170,0) or Color3.fromRGB(120,120,120)
        if onToggle then onToggle(new) end
    end)
    return btn
end

-- Slider helper (0..1 with step 0.1)
local function makeSlider(parent, labelText, initial, onChange)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, -12, 0, 44)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.6, 0, 0, 20)
    lbl.Position = UDim2.new(0, 6, 0, 2)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelText
    lbl.TextColor3 = Color3.fromRGB(255,255,255)
    lbl.Font = Enum.Font.SourceSans
    lbl.TextSize = 14
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    lbl.Parent = frame

    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0.2, 0, 0, 20)
    valueLabel.Position = UDim2.new(0.82, 0, 0, 2)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(initial)
    valueLabel.TextColor3 = Color3.fromRGB(255,255,255)
    valueLabel.Font = Enum.Font.SourceSansBold
    valueLabel.TextSize = 14
    valueLabel.Parent = frame

    local sliderBar = Instance.new("Frame")
    sliderBar.Size = UDim2.new(0.9, 0, 0, 10)
    sliderBar.Position = UDim2.new(0.05, 0, 0, 22)
    sliderBar.BackgroundColor3 = Color3.fromRGB(80,80,80)
    sliderBar.Parent = frame

    local knob = Instance.new("ImageButton")
    knob.Size = UDim2.new(0, 16, 0, 16)
    knob.Position = UDim2.new(math.clamp(initial,0,1), -8, 0, -3)
    knob.BackgroundColor3 = Color3.fromRGB(200,200,200)
    knob.Parent = sliderBar

    local dragging = false
    local function updateFromX(x)
        local absPos = x - sliderBar.AbsolutePosition.X
        local frac = math.clamp(absPos / sliderBar.AbsoluteSize.X, 0, 1)
        local stepped = roundToStep(frac, 0.1)
        knob.Position = UDim2.new(stepped, -8, 0, -3)
        valueLabel.Text = tostring(stepped)
        if onChange then onChange(stepped) end
    end

    knob.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
        end
    end)
    knob.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromX(input.Position.X)
        end
    end)
    sliderBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            updateFromX(input.Position.X)
        end
    end)

    return frame
end

