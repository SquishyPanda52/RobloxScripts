--////////////////////////////////////////////////////////////
-- HIGHLIGHT SYSTEM
--////////////////////////////////////////////////////////////

local HighlightFolder = Instance.new("Folder")
HighlightFolder.Name = "RuntimeHighlights"
HighlightFolder.Parent = ScreenGui

local function IsSpecific(player)
    for _,name in pairs(Settings.SpecificPlayers) do
        if string.find(string.lower(player.Name), name, 1, true) then
            return true
        end
    end

    return false
end

local function GetHealthColor(humanoid)
    local hp = humanoid.Health / humanoid.MaxHealth

    if hp > 0.7 then
        return Color3.fromRGB(0,255,0)
    elseif hp > 0.4 then
        return Color3.fromRGB(255,255,0)
    else
        return Color3.fromRGB(255,0,0)
    end
end

local function RemoveESP(player)
    if HighlightFolder:FindFirstChild(player.Name .. "_ESP") then
        HighlightFolder[player.Name .. "_ESP"]:Destroy()
    end
end

local function CreateESP(player)
    if player == LocalPlayer and not Settings.ShowOwnTeam then
        RemoveESP(player)
        return
    end

    local Character = player.Character
    if not Character then return end

    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
    local Head = Character:FindFirstChild("Head")

    if not Humanoid or not Head then return end

    local Existing = HighlightFolder:FindFirstChild(player.Name .. "_ESP")

    if Existing then
        Existing:Destroy()
    end

    local Holder = Instance.new("Folder")
    Holder.Name = player.Name .. "_ESP"
    Holder.Parent = HighlightFolder

    local ShouldHighlight = false

    local FillColor = Color3.new(1,1,1)
    local OutlineColor = Color3.new(1,1,1)
    local FillTransparency = 0.2

    if Settings.AllHighlight then
        ShouldHighlight = true
        FillColor = Color3.fromRGB(255,255,255)
        OutlineColor = Color3.fromRGB(180,180,180)
        FillTransparency = Settings.AllTransparency
    end

    if Settings.TeamHighlight then
        ShouldHighlight = true

        if player.Team then
            FillColor = player.Team.TeamColor.Color
            OutlineColor = player.Team.TeamColor.Color
        end

        FillTransparency = Settings.TeamTransparency

        if player.Team == LocalPlayer.Team and not Settings.ShowOwnTeam then
            ShouldHighlight = false
        end
    end

    if IsSpecific(player) then
        ShouldHighlight = true
        OutlineColor = Color3.fromRGB(255,215,0)
        FillTransparency = Settings.SpecificTransparency
    end

    if ShouldHighlight then
        local Highlight = Instance.new("Highlight")
        Highlight.Name = "Highlight"
        Highlight.Adornee = Character
        Highlight.FillColor = FillColor
        Highlight.OutlineColor = OutlineColor
        Highlight.FillTransparency = FillTransparency
        Highlight.OutlineTransparency = 0
        Highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        Highlight.Parent = Holder
    end

    local Billboard = Instance.new("BillboardGui")
    Billboard.Name = "NameTag"
    Billboard.Adornee = Head
    Billboard.AlwaysOnTop = true
    Billboard.Size = UDim2.new(0,200,0,40)
    Billboard.StudsOffset = Vector3.new(0,3,0)
    Billboard.Parent = Holder

    local Name = Instance.new("TextLabel")
    Name.BackgroundTransparency = 1
    Name.Size = UDim2.new(1,0,1,0)
    Name.Font = Enum.Font.GothamBold
    Name.Text = player.Name
    Name.TextScaled = true
    Name.TextStrokeTransparency = 0
    Name.Parent = Billboard

    local function UpdateHealthColor()
        if Humanoid and Humanoid.Parent then
            Name.TextColor3 = GetHealthColor(Humanoid)
        end
    end

    UpdateHealthColor()

    AddConnection(Humanoid.HealthChanged:Connect(UpdateHealthColor))
end

local function RefreshESP()
    for _,player in pairs(Players:GetPlayers()) do
        if player.Character then
            CreateESP(player)
        end
    end
end

