-- Roblox Fly Script with Smooth PC Controls
-- Place this as a LocalScript in StarterPlayer > StarterCharacterScripts

local character = script.Parent
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- Flight Configuration
local flySpeed = 50
local acceleration = 2
local maxSpeed = 100
local friction = 0.9

-- Flight State
local isFlying = false
local velocity = Vector3.new(0, 0, 0)
local targetVelocity = Vector3.new(0, 0, 0)

-- Physics Objects
local bodyVelocity
local bodyGyro

-- Initialize Flight
local function startFly()
    if isFlying then return end
    isFlying = true
    
    -- Disable normal gravity
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, false)
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
    
    -- Create BodyVelocity for movement
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.Parent = rootPart
    
    -- Create BodyGyro for rotation
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyGyro.CFrame = rootPart.CFrame
    bodyGyro.Parent = rootPart
end

-- Stop Flight
local function stopFly()
    if not isFlying then return end
    isFlying = false
    
    -- Re-enable gravity
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Climbing, true)
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
    
    -- Remove physics objects
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    
    velocity = Vector3.new(0, 0, 0)
    targetVelocity = Vector3.new(0, 0, 0)
end

-- Handle Input for Flight Control
local function handleInput(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.F then
        -- Toggle Flight with F key
        if isFlying then
            stopFly()
        else
            startFly()
        end
    end
end

-- Update Flight Velocity Based on Input
local function updateFlightInput()
    if not isFlying then return end
    
    targetVelocity = Vector3.new(0, 0, 0)
    local camera = workspace.CurrentCamera
    
    -- Get camera direction for forward/backward
    local moveDirection = (camera.Focus.Position - camera.CFrame.Position).Unit
    
    -- Up (Space) and Down (Ctrl)
    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
        targetVelocity = targetVelocity + Vector3.new(0, 1, 0) * flySpeed
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        targetVelocity = targetVelocity + Vector3.new(0, -1, 0) * flySpeed
    end
    
    -- Forward (W) and Backward (S)
    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        targetVelocity = targetVelocity + moveDirection * flySpeed
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        targetVelocity = targetVelocity - moveDirection * flySpeed
    end
    
    -- Left (A) and Right (D)
    local rightDirection = camera.CFrame.RightVector
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
        targetVelocity = targetVelocity - rightDirection * flySpeed
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
        targetVelocity = targetVelocity + rightDirection * flySpeed
    end
    
    -- Speed boost with Shift
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
        flySpeed = math.min(flySpeed + 1, maxSpeed)
    else
        flySpeed = math.max(flySpeed - 1, 50)
    end
    
    -- Smooth acceleration
    velocity = velocity:Lerp(targetVelocity, acceleration * 0.1)
    velocity = velocity * friction
end

-- Apply Flight Movement
local function applyFlightMovement()
    if not isFlying then return end
    
    bodyVelocity.Velocity = velocity
    bodyGyro.CFrame = workspace.CurrentCamera.CFrame
end

-- Main Loop
RunService.RenderStepped:Connect(function()
    if isFlying then
        updateFlightInput()
        applyFlightMovement()
    end
end)

-- Input Binding
UserInputService.InputBegan:Connect(handleInput)

-- Cleanup on death
humanoid.Died:Connect(function()
    stopFly()
end)

print("Fly Script Loaded! Press F to fly. Use WASD + Space/Ctrl for movement. Shift to speed up.")
