local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- Config defaults
local DEFAULT_DAMPING = 5
local DEFAULT_STRENGTH = 1000 -- base strength multiplier (per kg)
local MIN_MAXFORCE = 1e4
local MAX_MAXFORCE = 1e9
local MIN_P = 1000
local MAX_P = 1e7

-- State
local enabled = false
local forces = {} -- [part] = {bp = BodyPosition, bg = BodyGyro}
local heartbeatConn
local gui, mainFrame, contentFrame, toggleButton, nameBox, dampingBox, strengthBox
