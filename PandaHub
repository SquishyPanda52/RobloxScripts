-- Utility: find players by partial username (case-insensitive)
local function findPlayersByPartial(part)
    if not part or part == "" then return {} end
    part = part:lower()
    local results = {}
    for _, pl in pairs(Players:GetPlayers()) do
        if pl.Name:lower():find(part, 1, true) then
            table.insert(results, pl)
        end
    end
    return results
end

-- Cleanup forces
local function clearForces()
    for part, insts in pairs(forces) do
        if insts.bp and insts.bp.Parent then insts.bp:Destroy() end
        if insts.bg and insts.bg.Parent then insts.bg:Destroy() end
    end
    forces = {}
end

-- Create BodyPosition and BodyGyro for a part with mass-scaled parameters
local function applyForceToPart(part, targetCFrame, damping, strengthMultiplier)
    -- remove existing movers
    for _, child in pairs(part:GetChildren()) do
        if child:IsA("BodyPosition") or child:IsA("BodyGyro") then
            child:Destroy()
        end
    end

    -- get mass safely
    local mass = 1
    local ok, m = pcall(function() return part:GetMass() end)
    if ok and type(m) == "number" and m > 0 then
        mass = m
    end

    -- compute scaled MaxForce and P based on mass and user strength multiplier
    -- strengthMultiplier is treated as Newtons per kilogram (approx)
    local rawForce = mass * strengthMultiplier
    local clampedForce = math.clamp(rawForce, MIN_MAXFORCE, MAX_MAXFORCE)

    local bp = Instance.new("BodyPosition")
    bp.MaxForce = Vector3.new(clampedForce, clampedForce, clampedForce)
    -- P (power) scaled by mass to help heavier parts respond; clamped to avoid extremes
    bp.P = math.clamp(12500 * mass, MIN_P, MAX_P)
    bp.D = damping
    bp.Position = targetCFrame.Position
    bp.Parent = part

    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(clampedForce, clampedForce, clampedForce)
    bg.P = math.clamp(3000 * mass, MIN_P, MAX_P)
    bg.D = damping
    bg.CFrame = targetCFrame
    bg.Parent = part

    forces[part] = {bp = bp, bg = bg}
end

-- Update loop: move all tracked parts toward target
local function updateForces()
    local targetText = nameBox.Text
    local targets = findPlayersByPartial(targetText)
    if #targets == 0 then
        return
    end

    local damping = tonumber(dampingBox.Text) or DEFAULT_DAMPING
    local strengthInput = tonumber(strengthBox.Text) or DEFAULT_STRENGTH
    if damping < 0 then damping = 0 end
    if damping > 100 then damping = 100 end
    if strengthInput < 1 then strengthInput = 1 end

    -- choose first matched player with a valid character/head
    local targetChar
    for _, pl in ipairs(targets) do
        if pl.Character and pl.Character:FindFirstChild("Head") and pl.Character:FindFirstChild("HumanoidRootPart") then
            targetChar = pl.Character
            break
        end
    end
    if not targetChar then return end

    local targetPos = targetChar:FindFirstChild("Head") and targetChar.Head.Position or targetChar:FindFirstChild("HumanoidRootPart") and targetChar.HumanoidRootPart.Position
    if not targetPos then return end

    -- iterate workspace parts and apply forces where appropriate
    for _, part in pairs(workspace:GetDescendants()) do
        if part:IsA("BasePart") then
            if not part.Anchored then
                -- skip parts that are part of any player's character
                local isCharacterPart = false
                for _, pl in pairs(Players:GetPlayers()) do
                    if pl.Character and part:IsDescendantOf(pl.Character) then
                        isCharacterPart = true
                        break
                    end
                end
                if not isCharacterPart then
                    local nameLower = part.Name:lower()
                    if nameLower ~= "head" and nameLower ~= "torso" and nameLower ~= "humanoidrootpart" and nameLower ~= "right arm" and nameLower ~= "left arm" and nameLower ~= "right leg" and nameLower ~= "left leg" then
                        local targetCFrame = CFrame.new(targetPos)
                        local existing = forces[part]
                        if existing and existing.bp and existing.bg then
                            -- update properties using mass scaling
                            local mass = 1
                            local ok, m = pcall(function() return part:GetMass() end)
                            if ok and type(m) == "number" and m > 0 then mass = m end
                            local rawForce = mass * strengthInput
                            local clampedForce = math.clamp(rawForce, MIN_MAXFORCE, MAX_MAXFORCE)
                            existing.bp.MaxForce = Vector3.new(clampedForce, clampedForce, clampedForce)
                            existing.bp.D = damping
                            existing.bp.Position = targetPos
                            existing.bp.P = math.clamp(12500 * mass, MIN_P, MAX_P)
                            existing.bg.MaxTorque = Vector3.new(clampedForce, clampedForce, clampedForce)
                            existing.bg.D = damping
                            existing.bg.P = math.clamp(3000 * mass, MIN_P, MAX_P)
                            existing.bg.CFrame = targetCFrame
                        else
                            applyForceToPart(part, targetCFrame, damping, strengthInput)
                        end
                    end
                end
            else
                -- anchored but previously forced: remove
                if forces[part] then
                    if forces[part].bp and forces[part].bp.Parent then forces[part].bp:Destroy() end
                    if forces[part].bg and forces[part].bg.Parent then forces[part].bg:Destroy() end
                    forces[part] = nil
                end
            end
        end
    end
end

-- Toggle TPUA
local function setEnabled(state)
    enabled = state
    if enabled then
        toggleButton.Text = "TPUA: ON"
        if heartbeatConn then heartbeatConn:Disconnect() end
        heartbeatConn = RunService.Heartbeat:Connect(function()
            local ok, err = pcall(updateForces)
            if not ok then
                warn("Telekinesis update error:", err)
            end
        end)
    else
        toggleButton.Text = "TPUA: OFF"
        if heartbeatConn then
            heartbeatConn:Disconnect()
            heartbeatConn = nil
        end
        clearForces()
    end
end

