---------------------------------------------------------------------
-- UTILS
---------------------------------------------------------------------
local function disconnectAll()
    for _, c in ipairs(connections) do
        if typeof(c) == "RBXScriptConnection" then
            c:Disconnect()
        end
    end
    table.clear(connections)
    for char, data in pairs(characterData) do
        if data.HumanoidConn then
            data.HumanoidConn:Disconnect()
        end
    end
end

local function destroyAllVisuals()
    for char, data in pairs(characterData) do
        if data.Highlight and data.Highlight.Parent then
            data.Highlight:Destroy()
        end
        if data.Billboard and data.Billboard.Parent then
            data.Billboard:Destroy()
        end
    end
    table.clear(characterData)
end

local function parseSpecificNames()
    specificNameList = {}
    for part in string.gmatch(specificNamesRaw, "([^,]+)") do
        local trimmed = string.lower(string.gsub(part, "^%s*(.-)%s*$", "%1"))
        if trimmed ~= "" then
            table.insert(specificNameList, trimmed)
        end
    end
end

local function isSpecificPlayer(player)
    if not specificHighlightEnabled or #specificNameList == 0 then
        return false
    end
    local nameLower = string.lower(player.Name)
    local displayLower = player.DisplayName and string.lower(player.DisplayName) or ""
    for _, pattern in ipairs(specificNameList) do
        if string.find(nameLower, pattern, 1, true) or string.find(displayLower, pattern, 1, true) then
            return true
        end
    end
    return false
end

local function getTeamColor(player)
    if player.Team and player.Team.TeamColor then
        return player.Team.TeamColor.Color
    end
    return Color3.new(1, 1, 1)
end

local function getHealthColor(humanoid)
    if not humanoid or humanoid.MaxHealth <= 0 then
        return Color3.new(1, 1, 1)
    end
    local ratio = humanoid.Health / humanoid.MaxHealth
    if ratio >= 0.6 then
        return Color3.fromRGB(0, 255, 0) -- green
    elseif ratio >= 0.3 then
        return Color3.fromRGB(255, 255, 0) -- yellow
    else
        return Color3.fromRGB(255, 0, 0) -- red
    end
end

local function darkerColor(c)
    return Color3.new(c.R * 0.3, c.G * 0.3, c.B * 0.3)
end

---------------------------------------------------------------------
-- VISUAL CREATION
---------------------------------------------------------------------
local function ensureCharacterData(player, character)
    if not character then return end
    if characterData[character] then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "RuntimeHighlight"
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillTransparency = 0.3
    highlight.OutlineTransparency = 0.1
    highlight.Parent = character

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "RuntimeNameTag"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.MaxDistance = 5000
    billboard.Parent = character:FindFirstChild("Head") or character:FindFirstChildWhichIsA("BasePart") or character

    local textLabel = Instance.new("TextLabel")
    textLabel.Name = "NameLabel"
    textLabel.BackgroundTransparency = 1
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.Font = Enum.Font.SourceSansBold
    textLabel.TextScaled = true
    textLabel.TextStrokeTransparency = 0
    textLabel.TextColor3 = Color3.new(1, 1, 1)
    textLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    textLabel.Text = player.Name
    textLabel.Parent = billboard

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local humConn
    if humanoid then
        humConn = humanoid.HealthChanged:Connect(function()
            local c = getHealthColor(humanoid)
            textLabel.TextColor3 = c
            textLabel.TextStrokeColor3 = darkerColor(c)
        end)
        -- Initialize color
        local c = getHealthColor(humanoid)
        textLabel.TextColor3 = c
        textLabel.TextStrokeColor3 = darkerColor(c)
    end

    characterData[character] = {
        Player = player,
        Highlight = highlight,
        Billboard = billboard,
        HumanoidConn = humConn,
    }
end

local function cleanupCharacter(character)
    local data = characterData[character]
    if not data then return end
    if data.HumanoidConn then
        data.HumanoidConn:Disconnect()
    end
    if data.Highlight and data.Highlight.Parent then
        data.Highlight:Destroy()
    end
    if data.Billboard and data.Billboard.Parent then
        data.Billboard:Destroy()
    end
    characterData[character] = nil
end

---------------------------------------------------------------------
-- UPDATE LOOP
---------------------------------------------------------------------
local function updateHighlights()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character and character:FindFirstChildOfClass("Humanoid") then
                ensureCharacterData(player, character)
            end
        else
            local character = player.Character
            if character and character:FindFirstChildOfClass("Humanoid") then
                ensureCharacterData(player, character)
            end
        end
    end

    for character, data in pairs(characterData) do
        local player = data.Player
        local highlight = data.Highlight
        local billboard = data.Billboard

        if not player or not player.Parent or not character.Parent then
            cleanupCharacter(character)
        else
            if not highlight or not highlight.Parent then
                ensureCharacterData(player, character)
                highlight = characterData[character] and characterData[character].Highlight
            end
            if not billboard or not billboard.Parent then
                ensureCharacterData(player, character)
                billboard = characterData[character] and characterData[character].Billboard
            end

            local isLocal = (player == LocalPlayer)
            local sameTeam = false
            if LocalPlayer.Team and player.Team and LocalPlayer.Team == player.Team then
                sameTeam = true
            end

            local visible = false
            local fillColor = Color3.new(1, 1, 1)
            local outlineColor = Color3.new(0, 0, 0)
            local fillTransparency = 1
            local outlineTransparency = 1

            local specific = isSpecificPlayer(player)

            if allHighlightEnabled then
                visible = true
                fillColor = Color3.new(1, 1, 1)
                outlineColor = Color3.new(0, 0, 0)
                fillTransparency = allTransparency
                outlineTransparency = allTransparency
            end

            if teamHighlightEnabled then
                if sameTeam then
                    if not (isLocal and not showTeammatesHighlight) then
                        visible = true
                        fillColor = getTeamColor(player)
                        outlineColor = getTeamColor(player)
                        fillTransparency = teamTransparency
                        outlineTransparency = teamTransparency
                    end
                else
                    visible = true
                    fillColor = getTeamColor(player)
                    outlineColor = getTeamColor(player)
                    fillTransparency = teamTransparency
                    outlineTransparency = teamTransparency
                end
            end

            if specific then
                visible = true
                outlineColor = Color3.fromRGB(255, 215, 0) -- gold
                outlineTransparency = specificOutlineTransparency
            end

            if highlight then
                highlight.Enabled = visible
                highlight.FillColor = fillColor
                highlight.OutlineColor = outlineColor
                highlight.FillTransparency = fillTransparency
                highlight.OutlineTransparency = outlineTransparency
            end

            if billboard then
                billboard.Enabled = true
            end
        end
    end
end

---------------------------------------------------------------------
-- CHARACTER / PLAYER HOOKS
---------------------------------------------------------------------
local function onCharacterAdded(player, character)
    ensureCharacterData(player, character)
end

local function onPlayerAdded(player)
    local c1 = player.CharacterAdded:Connect(function(char)
        onCharacterAdded(player, char)
    end)
    table.insert(connections, c1)
    if player.Character then
        onCharacterAdded(player, player.Character)
    end)
end

for _, player in ipairs(Players:GetPlayers()) do
    onPlayerAdded(player)
end

table.insert(connections, Players.PlayerAdded:Connect(onPlayerAdded))
table.insert(connections, Players.PlayerRemoving:Connect(function(player)
    if player.Character then
        cleanupCharacter(player.Character)
    end
end))

table.insert(connections, RunService.Heartbeat:Connect(function()
    updateHighlights()
end))

