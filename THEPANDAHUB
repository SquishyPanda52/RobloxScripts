--// MINIMIZE / CLOSE LOGIC (simple & reliable)
local minimized = false
local fullSize = UDim2.new(0, 520, 0, 380)
local miniSize = UDim2.new(0, 520, 0, 32)

miniBtn.MouseButton1Click:Connect(function()
    minimized = not minimized

    -- Visual feedback so you KNOW it's firing
    miniBtn.BackgroundColor3 = minimized and Color3.fromRGB(40, 120, 40) or Color3.fromRGB(60, 160, 60)

    scroll.Visible = not minimized
    sideTab.Visible = not minimized

    mainFrame.Size = minimized and miniSize or fullSize
end)

closeBtn.MouseButton1Click:Connect(function()
    mainFrame.Visible = false
end)
