local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Debris = game:GetService("Debris")

local player = Players.LocalPlayer
if not player then return end

-- ensure script runs as a LocalScript environment
if not script:IsDescendantOf(game:GetService("StarterPlayer").StarterPlayerScripts) then
    script.Parent = game:GetService("StarterPlayer").StarterPlayerScripts
end
print("Script parented to:", script.Parent:GetFullName())

local function waitChar()
    local c = player.Character or player.CharacterAdded:Wait()
    return c
end

local character = waitChar()
player.CharacterAdded:Connect(function(c) character = c end)

local function makeFlingTool()
    local tool = Instance.new("Tool")
    tool.Name = "Fling"
    tool.RequiresHandle = true
    tool.CanBeDropped = false

    local handle = Instance.new("Part")
    handle.Name = "Handle"
    handle.Size = Vector3.new(1,1,1)
    handle.Transparency = 1
    handle.CanCollide = false
    handle.Parent = tool

    tool.Parent = player:WaitForChild("Backpack")
    return tool
end

local tool = makeFlingTool()
local active = false
local touchConn

local function flingTarget(targetRoot)
    if not targetRoot or not targetRoot:IsA("BasePart") then return end
    local targetChar = targetRoot.Parent
    if not targetChar then return end
    local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
    if not targetHRP or targetChar == character then return end

    local dir = (targetHRP.Position - (character:FindFirstChild("HumanoidRootPart") and character.HumanoidRootPart.Position or targetHRP.Position)).Unit
    local vel = Instance.new("BodyVelocity")
    vel.MaxForce = Vector3.new(1e5,1e5,1e5)
    vel.Velocity = dir * 80 + Vector3.new(0,120,0)
    vel.P = 1250
    vel.Parent = targetHRP
    Debris:AddItem(vel, 0.45)
end

local function onTouched(hit)
    if not active then return end
    local otherRoot = hit
    -- if hit is a descendant (e.g., limb), find the HumanoidRootPart
    if not otherRoot.Parent:FindFirstChild("HumanoidRootPart") then
        otherRoot = otherRoot:FindFirstAncestorWhichIsA("BasePart") or otherRoot
    end
    local hrp = otherRoot.Parent and otherRoot.Parent:FindFirstChild("HumanoidRootPart")
    if hrp then
        flingTarget(hrp)
    end
end

tool.Activated:Connect(function()
    active = not active
    if active then
        local hrp = character:WaitForChild("HumanoidRootPart")
        touchConn = hrp.Touched:Connect(onTouched)
        tool.ToolTip = "Fling: ON"
    else
        if touchConn then touchConn:Disconnect() touchConn = nil end
        tool.ToolTip = "Fling: OFF"
    end
end)
