-- state
local enabled = false
local running = true
local interval = 15.5
local pressConnection
local loopThread

-- attempt multiple methods to "press" G locally
local function trySendG()
    -- 1) VirtualUser (best-effort; may not exist in all environments)
    if VirtualUser then
        pcall(function()
            VirtualUser:CaptureController()
            -- try both common signatures
            if VirtualUser.SendKeyEvent then
                pcall(function() VirtualUser:SendKeyEvent(true, Enum.KeyCode.G, false, game) end)
                pcall(function() VirtualUser:SendKeyEvent(false, Enum.KeyCode.G, false, game) end)
            else
                -- fallback older signature
                pcall(function() VirtualUser:SendKeyEvent(true, "G", false, game) end)
                pcall(function() VirtualUser:SendKeyEvent(false, "G", false, game) end)
            end
        end)
    end
    -- 2) If the game exposes a RemoteEvent named "GKey" or "GPress" in ReplicatedStorage, fire it (best-effort)
    local candidates = {"GKey","GPress","KeyG","PressG"}
    for _,name in ipairs(candidates) do
        local ev = ReplicatedStorage:FindFirstChild(name)
        if ev and ev:IsA("RemoteEvent") then
            pcall(function() ev:FireServer() end)
        end
    end
    -- 3) Try ContextActionService bound actions: if an action named "G" exists, invoke it locally
    -- (we can't list bound actions, but try to call a common action name)
    local success,err = pcall(function()
        CAS:UnbindAction("AutoG_Temp") -- ensure not bound
    end)
    -- Bind a temporary action and immediately call it to emulate local action handlers that use ContextActionService
    local function tempAction(name, state, input)
        -- no-op
    end
    pcall(function()
        CAS:BindAction("AutoG_Temp", tempAction, false, Enum.KeyCode.G)
        CAS:UnbindAction("AutoG_Temp")
    end)
end

-- loop
local function startLoop()
    if loopThread then return end
    loopThread = coroutine.create(function()
        while running do
            if enabled then
                trySendG()
            end
            local t = 0
            while t < interval and running do
                local dt = RunService.Heartbeat:Wait()
                t = t + dt
            end
        end
    end)
    coroutine.resume(loopThread)
end

local function stopLoop()
    running = false
end

-- UI interactions
toggle.MouseButton1Click:Connect(function()
    enabled = not enabled
    if enabled then
        toggle.Text = "Disable"
        toggle.BackgroundColor3 = Color3.fromRGB(255,85,85)
    else
        toggle.Text = "Enable"
        toggle.BackgroundColor3 = Color3.fromRGB(0,170,255)
    end
end)

local minimized = false
btnMin.MouseButton1Click:Connect(function()
    minimized = not minimized
    main.Size = minimized and UDim2.new(0, 120, 0, 36) or UDim2.new(0, 260, 0, 90)
    title.Visible = not minimized
    toggle.Visible = not minimized
    info.Visible = not minimized
end)

btnClose.MouseButton1Click:Connect(function()
    -- destroy UI and stop script
    pcall(function() screenGui:Destroy() end)
    enabled = false
    running = false
    -- attempt to destroy this script object
    pcall(function() script:Destroy() end)
end)

-- persist UI across respawn
screenGui.Parent = playerGui
screenGui.ResetOnSpawn = false

-- ensure UI exists after respawn (recreate if needed)
player.CharacterAdded:Connect(function()
    if not screenGui.Parent then
        screenGui.Parent = playerGui
        screenGui.ResetOnSpawn = false
    end
end)

-- start
startLoop()
print("Auto G started (interval "..tostring(interval).."s). Toggle with UI.")
