---------------------------------------------------------------------
-- COMMANDER LOGIC
---------------------------------------------------------------------

local function splitCommaList(s)
    local out = {}
    if not s then return out end
    for part in tostring(s):gmatch("([^,]+)") do
        local t = part:gsub("^%s+", ""):gsub("%s+$", "")
        if t ~= "" then
            table.insert(out, t)
        end
    end
    return out
end

local function isCommanderName(name)
    local list = splitCommaList(commanderBox.Text or "")
    name = tostring(name or ""):lower()
    for _, raw in ipairs(list) do
        local partial = raw:lower():gsub("%s+", "")
        if partial ~= "" and name:find(partial, 1, true) then
            return true
        end
    end
    return false
end

commanderToggle.MouseButton1Click:Connect(function()
    commanderMode = not commanderMode
    if commanderMode then
        commanderToggle.Text = "Cmd Mode: ON"
        commanderToggle.BackgroundColor3 = Color3.fromRGB(46,204,113)
    else
        commanderToggle.Text = "Cmd Mode: OFF"
        commanderToggle.BackgroundColor3 = Color3.fromRGB(70,0,0)
    end
end)

-- Listen for chat commands from commanders and auto-enable/disable the script
if TextChatService then
    TextChatService.MessageReceived:Connect(function(msg)
        if not commanderMode then return end
        if not msg then return end

        local source = msg.TextSource
        if not source then return end

        local userId = source.UserId
        if not userId then return end

        local plr = Players:GetPlayerByUserId(userId)
        if not plr then return end

        if not isCommanderName(plr.Name) then return end

        local text = tostring(msg.Text or "")
        local lower = text:lower()

        -- Extract command token after leading dot, if present
        local cmd = lower:match("^%.([%w_]+)")
        if not cmd then return end

        -- Normalize synonyms
        if cmd == "attack" then cmd = "atk" end
        if cmd == "goto" then cmd = "follow" end

        -- If commander says .atk or .attack -> enable auto-press
        if cmd == "atk" then
            enabled = true
            updateToggle()
            return
        end

        -- If commander says .stop -> disable auto-press
        if cmd == "stop" then
            enabled = false
            updateToggle()
            return
        end

        -- If commander says any of these non-attack commands, ensure auto-press is off
        if cmd == "follow" or cmd == "goto" or cmd == "hold" then
            enabled = false
            updateToggle()
            return
        end

        -- Other commands are ignored for auto-press toggling
    end)
end

