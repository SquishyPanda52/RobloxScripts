        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

---------------------------------------------------------------------
-- ROWS (7 rows, each with 3 textboxes)
-- Left: key name (string)
-- Middle: cooldown (number) seconds between presses
-- Right: hold (number) seconds to hold the key continuously
---------------------------------------------------------------------

local rows = {}

-- Utility to stop a row's running coroutine
local function stopRow(row)
    if row and row.running then
        row.running = false
        row.thread = nil
    end
end

-- Start a loop for a row. The loop will run continuously but only perform presses when:
--  - the row has valid key/interval/hold values
--  - enabled == true
-- The loop checks values each iteration so edits take effect immediately.
local function startLoop(row)
    stopRow(row)

    row.running = true
    row.thread = coroutine.create(function()
        while row.running and not destroyed do
            -- read current values (allow dynamic edits)
            local keyText = tostring(row.key.Text or "")
            local intervalNum = tonumber(row.interval.Text)
            local holdNum = tonumber(row.hold.Text)

            local keyCode = resolveKey(keyText)

            if keyCode and intervalNum and holdNum and intervalNum > 0 and holdNum >= 0 then
                -- Only perform presses when enabled
                if enabled and not destroyed then
                    -- Press and hold
                    pcall(function()
                        VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
                    end)
                    -- hold for specified time (allow early exit)
                    local holdStart = tick()
                    while tick() - holdStart < holdNum do
                        if not enabled or destroyed or not row.running then break end
                        task.wait(0.01)
                    end
                    pcall(function()
                        VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
                    end)
                end

                -- Wait for cooldown interval before next press (allow early exit)
                local waitStart = tick()
                while tick() - waitStart < intervalNum do
                    if not enabled or destroyed or not row.running then break end
                    task.wait(0.05)
                end
            else
                -- invalid config: sleep briefly and re-check later
                task.wait(0.25)
            end
        end
    end)

    -- resume coroutine in a safe spawn so it doesn't block
    task.spawn(function()
        if row.thread and coroutine.status(row.thread) == "suspended" then
            local ok, err = pcall(coroutine.resume, row.thread)
            if not ok then
                -- stop on error
                row.running = false
                row.thread = nil
                warn("AutoPress row thread error:", err)
            end
        end
    end)
end

local function createRow(i)
    local y = (i - 1) * 40

    local keyBox = Instance.new("TextBox")
    keyBox.Size = UDim2.new(0, 60, 0, 30)
    keyBox.Position = UDim2.new(0, 0, 0, y)
    keyBox.ZIndex = 999999
    keyBox.PlaceholderText = "" -- blank by default
    keyBox.Parent = scroll

    local intervalBox = Instance.new("TextBox")
    intervalBox.Size = UDim2.new(0, 80, 0, 30)
    intervalBox.Position = UDim2.new(0, 70, 0, y)
    intervalBox.ZIndex = 999999
    intervalBox.PlaceholderText = "" -- blank by default
    intervalBox.Parent = scroll

    local holdBox = Instance.new("TextBox")
    holdBox.Size = UDim2.new(0, 80, 0, 30)
    holdBox.Position = UDim2.new(0, 160, 0, y)
    holdBox.ZIndex = 999999
    holdBox.PlaceholderText = "" -- blank by default
    holdBox.Parent = scroll

    rows[i] = {
        key = keyBox,
        interval = intervalBox,
        hold = holdBox,
        running = false,
        thread = nil
    }

    -- Start the loop for this row immediately so it reacts to enabled toggles
    startLoop(rows[i])

    -- When user edits a box and leaves focus, restart the row to pick up new values immediately
    local function onEdit()
        if destroyed then return end
        -- restart the loop to pick up new values
        startLoop(rows[i])
    end

    keyBox.FocusLost:Connect(onEdit)
    intervalBox.FocusLost:Connect(onEdit)
    holdBox.FocusLost:Connect(onEdit)

    scroll.CanvasSize = UDim2.new(0, 0, 0, y + 50)
end

for i = 1, 7 do
    createRow(i)
end

