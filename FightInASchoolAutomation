info.TextColor3 = Color3.fromRGB(170,170,170)
info.Font = Enum.Font.Gotham
info.TextSize = 14
info.TextXAlignment = Enum.TextXAlignment.Left

-- state
local enabled = false
local running = true
local interval = 15.5
screenGui.ResetOnSpawn = false

-- function to attempt to "press" G locally
local function sendG()
    -- VirtualUser attempt
    if VirtualUser then
        pcall(function()
            VirtualUser:CaptureController()
            -- try both common signatures
            if VirtualUser.SendKeyEvent then
                pcall(function() VirtualUser:SendKeyEvent(true, Enum.KeyCode.G, false, game) end)
                pcall(function() VirtualUser:SendKeyEvent(false, Enum.KeyCode.G, false, game) end)
            else
                pcall(function() VirtualUser:SendKeyEvent(true, "G", false, game) end)
                pcall(function() VirtualUser:SendKeyEvent(false, "G", false, game) end)
            end
        end)
    end
    -- RemoteEvent heuristics
    local candidates = {"GKey","GPress","KeyG","PressG"}
    for _,name in ipairs(candidates) do
        local ev = ReplicatedStorage:FindFirstChild(name)
        if ev and ev:IsA("RemoteEvent") then
            pcall(function() ev:FireServer() end)
        end
    end
    -- ContextActionService temporary bind (no-op) to try trigger local handlers
    pcall(function()
        local function tmpAction() end
        ContextActionService:BindAction("AutoG_Temp", tmpAction, false, Enum.KeyCode.G)
        ContextActionService:UnbindAction("AutoG_Temp")
    end)
end

-- loop coroutine
local loop
local function startLoop()
    if loop then return end
    loop = coroutine.create(function()
        while running do
            if enabled then
                pcall(sendG)
            end
            local t = 0
            while t < interval and running do
                local dt = RunService.Heartbeat:Wait()
                t = t + dt
            end
        end
    end)
    coroutine.resume(loop)
end

-- UI behavior
toggle.MouseButton1Click:Connect(function()
    enabled = not enabled
    if enabled then
        toggle.Text = "Disable"
        toggle.BackgroundColor3 = Color3.fromRGB(255,85,85)
    else
        toggle.Text = "Enable"
        toggle.BackgroundColor3 = Color3.fromRGB(0,170,255)
    end
end)

local minimized = false
btnMin.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        main.Size = UDim2.new(0, 140, 0, 40)
        title.Visible = false
        toggle.Visible = false
        info.Visible = false
        btnMin.Text = "+"
    else
        main.Size = UDim2.new(0, 260, 0, 92)
        title.Visible = true
        toggle.Visible = true
        info.Visible = true
        btnMin.Text = "—"
    end
end)

btnClose.MouseButton1Click:Connect(function()
    enabled = false
    running = false
    pcall(function() screenGui:Destroy() end)
    pcall(function() script:Destroy() end)
end)

-- ensure UI persists after respawn
player.CharacterAdded:Connect(function()
    if not screenGui.Parent then
        screenGui.Parent = playerGui
    end
    screenGui.ResetOnSpawn = false
end)

-- safety: if PlayerGui is replaced (rare), reparent
playerGui.ChildRemoved:Connect(function(child)
    if child == screenGui then
        wait(0.1)
        if not screenGui.Parent then
            screenGui.Parent = player:FindFirstChild("PlayerGui") or playerGui
        end
    end
end)

startLoop()
print("AutoG running. UI created. Interval:", interval)
