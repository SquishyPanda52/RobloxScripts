local function updateButtons()
    btnToggle.Text = "Lockon: " .. (lockonEnabled and "ON" or "OFF")
    btnToggle.BackgroundColor3 = lockonEnabled and Color3.fromRGB(0, 70, 0) or Color3.fromRGB(70, 0, 0)

    btnLockonPredict.Text = "Predict: " .. (lockonPredictEnabled and "ON" or "OFF")
    btnLockonPredict.BackgroundColor3 = lockonPredictEnabled and Color3.fromRGB(0, 70, 0) or Color3.fromRGB(70, 0, 0)

    -- NEW
    btnSnap.Text = "Snap: " .. (snapEnabled and "ON" or "OFF")
    btnSnap.BackgroundColor3 = snapEnabled and Color3.fromRGB(0, 70, 0) or Color3.fromRGB(70, 0, 0)
end

local function stopConnectionIfNeeded()
    if not lockonEnabled and not lockonPredictEnabled then
        if lockonConnection then
            lockonConnection:Disconnect()
            lockonConnection = nil
        end
    end
end

local function toggleLockon()
    lockonEnabled = not lockonEnabled
    if lockonEnabled then
        lockonPredictEnabled = false
        startLockon()
    end
    updateButtons()
    stopConnectionIfNeeded()
end

local function toggleLockonPredict()
    lockonPredictEnabled = not lockonPredictEnabled
    if lockonPredictEnabled then
        lockonEnabled = false
        startLockon()
    end
    updateButtons()
    stopConnectionIfNeeded()
end

-- NEW
local function toggleSnap()
    snapEnabled = not snapEnabled
    updateButtons()
end

btnToggle.MouseButton1Click:Connect(toggleLockon)
btnLockonPredict.MouseButton1Click:Connect(toggleLockonPredict)
btnSnap.MouseButton1Click:Connect(toggleSnap)

