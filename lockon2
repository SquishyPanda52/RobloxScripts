local draggingSlider = false

local function updateSliderFromStrength()
    if not sliderBar or not sliderKnob then return end
    local barAbsSize = sliderBar.AbsoluteSize.X
    if barAbsSize <= 0 then return end
    local t = math.clamp(predictionStrength, 0, 1)
    local x = t * barAbsSize
    sliderKnob.Position = UDim2.new(0, sliderBar.Position.X.Offset + x - 5, 0, sliderKnob.Position.Y.Offset)
    valueLabel.Text = string.format("%.2f", predictionStrength)
end

local function setStrengthFromX(x)
    local barPos = sliderBar.AbsolutePosition.X
    local barSize = sliderBar.AbsoluteSize.X
    local rel = math.clamp(x - barPos, 0, barSize)
    local t = rel / barSize
    predictionStrength = round(t, 2)
    valueLabel.Text = string.format("%.2f", predictionStrength)
    sliderKnob.Position = UDim2.new(0, sliderBar.Position.X.Offset + rel - 5, 0, sliderKnob.Position.Y.Offset)
end

sliderBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = true
        setStrengthFromX(input.Position.X)
    end
end)

sliderKnob.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = true
    end
end)

UserInput.InputChanged:Connect(function(input)
    if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
        setStrengthFromX(input.Position.X)
    end
end)

UserInput.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = false
    end
end)

