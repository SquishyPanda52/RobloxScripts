-- Command processing helpers
local function setLastCommander(plr)
    if plr and plr.UserId then
        lastCommanderUserId = plr.UserId
        lastCommanderPlayer = plr
    end
end

-- Command handling (TextChatService)
if TextChatService then
    TextChatService.MessageReceived:Connect(function(msg)
        if not commanderMode then return end
        if not msg then return end

        local source = msg.TextSource
        if not source then return end

        local userId = source.UserId
        if not userId then return end

        local plr = Players:GetPlayerByUserId(userId)
        if not plr then return end

        -- Only accept commands from players listed in commanderBox
        if not isCommander(plr.Name) then return end

        -- newest commander overrides everything: record, hard-override
        setLastCommander(plr)
        hardOverridePreviousCommands()

        -- IMPORTANT: yield briefly and re-check session token so that if another command
        -- arrived immediately after this one, this handler will abort and not proceed.
        -- This prevents near-simultaneous commands from different commanders from both
        -- executing and causing jitter.
        local mySession = commandSession
        -- small yield to allow disconnects to take effect; tiny value to minimize latency
        task.wait(0.02)
        if mySession ~= commandSession then
            -- a newer command arrived; abort processing this message
            return
        end

        local text = tostring(msg.Text or "")
        local lower = text:lower()

        -- Extract command and argument robustly: command is first token after leading dot
        local cmd, arg = lower:match("^%.([%w_]+)%s*(.*)$")
        if not cmd then
            return
        end
        arg = trim(arg or "")

        -- Normalize synonyms
        if cmd == "attack" then cmd = "atk" end
        if cmd == "goto" then cmd = "follow" end

        -- .stop command (any commander can stop)
        if cmd == "stop" then
            attackBox.Text = ""
            followBox.Text = ""
            teamAttackBox.Text = ""
            -- disable all modes and stop movement immediately
            if followEnabled then stopFollow() end
            if attackEnabled then stopAttack() end
            if teamAttackEnabled then stopTeamAttack() end
            stopMovementImmediate()
            return
        end

        -- .atk / .attack handling
        if cmd == "atk" then
            local lowarg = arg:lower()
            if lowarg == "" or lowarg == "me" then
                -- attack the commander who said it (use full username)
                attackBox.Text = plr.Name
                parseAttackNames(attackBox.Text)
                ensureEquipSlotOne()
                attackEnabled = true
                startAttack()
                return
            end

            if lowarg == "random" then
                local pool = {}
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= localPlayer and not isCommander(p.Name) then
                        table.insert(pool, p)
                    end
                end
                if #pool > 0 then
                    local choice = pool[math.random(1, #pool)]
                    attackBox.Text = choice.Name
                    parseAttackNames(attackBox.Text)
                    ensureEquipSlotOne()
                    attackEnabled = true
                    startAttack()
                end
                return
            end

            if lowarg == "others" then
                local names = allPlayerNames(true)
                attackBox.Text = table.concat(names, ", ")
                parseAttackNames(attackBox.Text)
                ensureEquipSlotOne()
                attackEnabled = true
                startAttack()
                return
            end

            if lowarg == "all" or lowarg == "everyone" then
                local names = allPlayerNames(false)
                attackBox.Text = table.concat(names, ", ")
                parseAttackNames(attackBox.Text)
                ensureEquipSlotOne()
                attackEnabled = true
                startAttack()
                return
            end

            -- default: treat arg as comma-separated names (use fragments as provided)
            attackBox.Text = arg
            parseAttackNames(attackBox.Text)
            ensureEquipSlotOne()
            attackEnabled = true
            startAttack()
            return
        end

        -- .follow / .goto handling
        if cmd == "follow" then
            local lowarg = arg:lower()
            if lowarg == "stop" or lowarg == "none" or lowarg == "" then
                if followEnabled then stopFollow() end
                followBox.Text = ""
                return
            end

            if lowarg == "me" then
                -- follow the commander who said it; paste full username
                followBox.Text = plr.Name
                followTargetPlayer = plr
                followEnabled = true
                startFollow()
                return
            end

            if lowarg == "hold" then
                local char = localPlayer.Character
                if char then
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        holdMode = true
                        holdPosition = hrp.Position
                        followEnabled = true
                        startFollow()
                        followBox.Text = "Hold"
                    end
                end
                return
            end

            -- normal follow target: resolve fragment to full username if possible
            local target = findClosestPlayer(arg)
            if target then
                followBox.Text = target.Name
                followTargetPlayer = target
                followEnabled = true
                startFollow()
            else
                -- if no player found, still paste the fragment (keeps original behavior)
                followBox.Text = arg
            end
            return
        end

        -- .teamattack handling
        if cmd == "teamattack" or cmd == "team_atk" or cmd == "team" then
            local lowarg = arg:lower()
            if lowarg == "" then
                if teamAttackEnabled then stopTeamAttack() end
                teamAttackBox.Text = ""
                return
            end
            teamAttackBox.Text = arg
            parseTeamNames(teamAttackBox.Text)
            teamAttackEnabled = true
            startTeamAttack()
            return
        end

        -- .hold command (explicit)
        if cmd == "hold" then
            local char = localPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    holdMode = true
                    holdPosition = hrp.Position
                    followEnabled = true
                    startFollow()
                end
            end
            return
        end

        -- other commands ignored
    end)
end

-- UI interactions and bindings
local function wireUpUI()
    -- Commander toggle
    commanderToggle.MouseButton1Click:Connect(function()
        commanderMode = not commanderMode
        commanderToggle.Text = "Cmd Mode: " .. (commanderMode and "On" or "Off")
        commanderToggle.BackgroundColor3 = commanderMode and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(70, 0, 0)
    end)

    -- Follow button
    followBtn.MouseButton1Click:Connect(function()
        if followEnabled then
            stopFollow()
            return
        end
        local txt = trim(followBox.Text or "")
        if txt == "" then
            -- nothing to follow
            return
        end
        local target = findClosestPlayer(txt)
        if target then
            followBox.Text = target.Name
            followTargetPlayer = target
            followEnabled = true
            startFollow()
        else
            -- if no player found, still set followTargetPlayer nil and do nothing
            followBox.Text = txt
        end
    end)

    -- Attack button
    attackBtn.MouseButton1Click:Connect(function()
        if attackEnabled then
            stopAttack()
            return
        end
        local txt = trim(attackBox.Text or "")
        if txt == "" then
            -- nothing specified; do nothing
            return
        end
        parseAttackNames(txt)
        attackEnabled = true
        -- ensure slot 1 tool is equipped if present
        ensureEquipSlotOne()
        startAttack()
    end)

    -- TeamAttack button
    teamAttackBtn.MouseButton1Click:Connect(function()
        if teamAttackEnabled then
            stopTeamAttack()
            return
        end
        local txt = trim(teamAttackBox.Text or "")
        if txt == "" then
            return
        end
        parseTeamNames(txt)
        teamAttackEnabled = true
        startTeamAttack()
    end)

    -- AutoBox capture: allow user to click and press a key or mouse to bind
    autoBox.Focused:Connect(function()
        -- capture next input
        if bindingCaptureConn then bindingCaptureConn:Disconnect() bindingCaptureConn = nil end
        bindingCaptureConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                binding = { kind = "mouse", button = 1 }
                autoBox.Text = "Mouse1"
            elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
                binding = { kind = "mouse", button = 2 }
                autoBox.Text = "Mouse2"
            elseif input.UserInputType == Enum.UserInputType.Keyboard then
                binding = { kind = "key", keyCode = input.KeyCode }
                autoBox.Text = tostring(input.KeyCode):gsub("Enum.KeyCode.", "")
            end
            if bindingCaptureConn then bindingCaptureConn:Disconnect() bindingCaptureConn = nil end
            autoBox:ReleaseFocus()
        end)
    end)

    -- Rate buttons
    rateMinusBtn.MouseButton1Click:Connect(function()
        AUTOPRESS_HZ = math.max(AUTOPRESS_MIN_HZ, AUTOPRESS_HZ - 1)
        rateLabel.Text = tostring(AUTOPRESS_HZ) .. "/s"
    end)
    ratePlusBtn.MouseButton1Click:Connect(function()
        AUTOPRESS_HZ = math.min(AUTOPRESS_MAX_HZ, AUTOPRESS_HZ + 1)
        rateLabel.Text = tostring(AUTOPRESS_HZ) .. "/s"
    end)
end

-- Cleanup
local function cleanup()
    if gui and gui.Parent then
        gui:Destroy()
    end
    for _, c in ipairs(connections) do
        if c and c.Disconnect then
            pcall(function() c:Disconnect() end)
        end
    end
    connections = {}
    if bindingCaptureConn then
        pcall(function() bindingCaptureConn:Disconnect() end)
        bindingCaptureConn = nil
    end
    if autoPressConn then
        pcall(function() autoPressConn:Disconnect() end)
        autoPressConn = nil
    end
    if followConn then
        pcall(function() followConn:Disconnect() end)
        followConn = nil
    end
    if attackConn then
        pcall(function() attackConn:Disconnect() end)
        attackConn = nil
    end
    if teamAttackConn then
        pcall(function() teamAttackConn:Disconnect() end)
        teamAttackConn = nil
    end
    if localHumanoidDiedConn then
        pcall(function() localHumanoidDiedConn:Disconnect() end)
        localHumanoidDiedConn = nil
    end
    if localCharacterRemovingConn then
        pcall(function() localCharacterRemovingConn:Disconnect() end)
        localCharacterRemovingConn = nil
    end
    _G.HiltonExec = nil
end

_G.HiltonExec.Cleanup = cleanup

-- Character death handling: disable modes on death/respawn
local function onCharacterAdded(char)
    -- disconnect previous humanoid died if any
    if localHumanoidDiedConn then
        pcall(function() localHumanoidDiedConn:Disconnect() end)
        localHumanoidDiedConn = nil
    end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        localHumanoidDiedConn = hum.Died:Connect(function()
            -- turn off modes on death
            if followEnabled then stopFollow() end
            if attackEnabled then stopAttack() end
            if teamAttackEnabled then stopTeamAttack() end
        end)
    end
end

local function onCharacterRemoving()
    -- clear follow/attack on character removal
    if followEnabled then stopFollow() end
    if attackEnabled then stopAttack() end
    if teamAttackEnabled then stopTeamAttack() end
end

-- Initialize
buildUI()
wireUpUI()

-- Wire character events
if localPlayer.Character then
    onCharacterAdded(localPlayer.Character)
end
localPlayer.CharacterAdded:Connect(onCharacterAdded)
localPlayer.CharacterRemoving:Connect(onCharacterRemoving)

-- Expose a simple API for external cleanup if needed
_G.HiltonExec.Cleanup = cleanup
