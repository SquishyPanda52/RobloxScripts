    end
end

-- AutoPress binding capture
local function describeBinding()
    if binding.kind == "mouse" then
        return (binding.button == 2) and "Mouse2" or "Mouse1"
    else
        return "Key:" .. tostring(binding.keyCode):gsub("Enum.KeyCode.", "")
    end
end

local function beginBindingCapture()
    if bindingCaptureConn then
        bindingCaptureConn:Disconnect()
        bindingCaptureConn = nil
    end
    autoBox.Text = "Press a key or click..."
    bindingCaptureConn = UserInputService.InputBegan:Connect(function(input, gpe)
        if not autoBox:IsFocused() then return end
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            binding = { kind = "mouse", button = 1 }
        elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
            binding = { kind = "mouse", button = 2 }
        elseif input.KeyCode and input.KeyCode ~= Enum.KeyCode.Unknown then
            binding = { kind = "key", keyCode = input.KeyCode }
        else
            return
        end
        autoBox.Text = describeBinding()
        autoBox:ReleaseFocus()
        if bindingCaptureConn then
            bindingCaptureConn:Disconnect()
            bindingCaptureConn = nil
        end
    end)
    table.insert(connections, bindingCaptureConn)
end

-- Rate helpers
local function clampRate(v)
    if v < AUTOPRESS_MIN_HZ then return AUTOPRESS_MIN_HZ end
    if v > AUTOPRESS_MAX_HZ then return AUTOPRESS_MAX_HZ end
    return math.floor(v + 0.5)
end

local function setRate(v)
    AUTOPRESS_HZ = clampRate(v)
    if rateLabel then
        rateLabel.Text = tostring(AUTOPRESS_HZ) .. "/s"
    end
end

-- Ensure all attack/follow modes are turned off
local function disableAllModes()
    if followEnabled then stopFollow() end
    if attackEnabled then stopAttack() end
    if teamAttackEnabled then stopTeamAttack() end
end

-- Character events
local function connectLocalCharacterEvents(character)
    if localHumanoidDiedConn then
        pcall(function() localHumanoidDiedConn:Disconnect() end)
        localHumanoidDiedConn = nil
    end
    if localCharacterRemovingConn then
        pcall(function() localCharacterRemovingConn:Disconnect() end)
        localCharacterRemovingConn = nil
    end

    if not character then return end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then
        localHumanoidDiedConn = humanoid.Died:Connect(function()
            disableAllModes()
        end)
        table.insert(connections, localHumanoidDiedConn)
    end

    localCharacterRemovingConn = character.AncestryChanged:Connect(function(_, parent)
        if not parent then
            disableAllModes()
        end
    end)
    table.insert(connections, localCharacterRemovingConn)

    -- If autoJumpEnabled, ensure the autoJump connection is active after respawn
    if autoJumpEnabled and not autoJumpConn then
        startAutoJump()
    end
end

-- Cleanup routine
function _G.HiltonExec.Cleanup()
    pcall(function()
        if followConn then followConn:Disconnect() end
        if attackConn then attackConn:Disconnect() end
        if teamAttackConn then teamAttackConn:Disconnect() end
        if autoPressConn then autoPressConn:Disconnect() end
        if bindingCaptureConn then bindingCaptureConn:Disconnect() end
        if autoJumpConn then autoJumpConn:Disconnect() end
        if localHumanoidDiedConn then localHumanoidDiedConn:Disconnect() end
        if localCharacterRemovingConn then localCharacterRemovingConn:Disconnect() end
        for _, c in ipairs(connections) do
            if c and c.Disconnect then
                pcall(function() c:Disconnect() end)
            end
        end
    end)
    followConn, attackConn, teamAttackConn, autoPressConn, bindingCaptureConn, autoJumpConn = nil, nil, nil, nil, nil, nil
    localHumanoidDiedConn, localCharacterRemovingConn = nil, nil
    if gui then
        pcall(function() gui:Destroy() end)
    end
    _G.HiltonExec = nil
end

-- COMMANDER UTILITIES
local function isCommander(name)
    local list = string.split(commanderBox.Text or "", ",")
    name = tostring(name or ""):lower()
    for _, raw in ipairs(list) do
        local partial = raw:lower():gsub("%s+", "")
        if partial ~= "" and name:find(partial, 1, true) then
            return true
        end
    end
    return false
end

local function toggleCommanderMode()
    commanderMode = not commanderMode
    if commanderToggle then
        commanderToggle.Text = "Cmd Mode: " .. (commanderMode and "On" or "Off")
        commanderToggle.BackgroundColor3 = commanderMode and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(70, 0, 0)
    end
end

-- Listen for messages from TextChatService and handle commands
if TextChatService then
    TextChatService.MessageReceived:Connect(function(msg)
        if not commanderMode then return end
        if not msg then return end

        local source = msg.TextSource
        if not source then return end

        local userId = source.UserId
        if not userId then return end

        local plr = Players:GetPlayerByUserId(userId)
        if not plr then return end

        if not isCommander(plr.Name) then return end

        local text = tostring(msg.Text or "")
        local lower = text:lower()

        -- .atk command
        if lower:sub(1,4) == ".atk" then
            local after = text:match("^%.atk%s*(.+)$")
            if after then
                -- Before enabling attack, auto-press '1' to select first tool
                pcall(function()
                    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
                    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
                end)

                -- Paste into attack textbox
                attackBox.Text = after

                -- Ensure follow and team attack are off
                if followEnabled then
                    followEnabled = false
                    stopFollow()
                end
                if teamAttackEnabled then
                    teamAttackEnabled = false
                    stopTeamAttack()
                end

                -- If attack is not enabled, toggle it on; if already enabled, reparse names and restart
                if not attackEnabled then
                    onAttackToggle()
                else
                    parseAttackNames(attackBox.Text)
                    stopAttack()
                    startAttack()
                end
            end
            return
        end

        -- .stop command (clear and turn off modes except commander)
        if lower:match("^%.stop%s*$") or lower:match("^%.stop%s+") then
            attackBox.Text = ""
            followBox.Text = ""
            teamAttackBox.Text = ""
            -- disable all modes except commander
            if followEnabled then stopFollow() end
            if attackEnabled then stopAttack() end
            if teamAttackEnabled then stopTeamAttack() end
            return
        end

        -- .follow me command (paste commander into follow textbox and enable follow)
        if lower:match("^%.follow%s+me") or lower:match("^%.followme") then
            followBox.Text = plr.Name

            if attackEnabled then
                attackEnabled = false
                stopAttack()
            end
            if teamAttackEnabled then
                teamAttackEnabled = false
                stopTeamAttack()
            end

            if not followEnabled then
                onFollowToggle()
            else
                followTargetPlayer = findClosestPlayer(followBox.Text)
                stopFollow()
                if followTargetPlayer then
                    followEnabled = true
                    setBtnState(followBtn, true, "Follow")
                    startFollow()
                end
            end
            return
        end

        -- .follow <user> command (follow specified user)
        if lower:sub(1,7) == ".follow" then
            local after = text:match("^%.follow%s*(.+)$")
            if after and #trim(after) > 0 then
                followBox.Text = after

                if attackEnabled then
                    attackEnabled = false
                    stopAttack()
                end
                if teamAttackEnabled then
                    teamAttackEnabled = false
                    stopTeamAttack()
                end

                if not followEnabled then
                    onFollowToggle()
                else
                    followTargetPlayer = findClosestPlayer(followBox.Text)
                    stopFollow()
                    if followTargetPlayer then
                        followEnabled = true
                        setBtnState(followBtn, true, "Follow")
                        startFollow()
                    end
                end
            end
            return
        end

        -- Optionally allow ".autojump on/off" to control auto-jump via commander
        if lower:match("^%.autojump%s+on") then
            autoJumpEnabled = true
            if not autoJumpConn then startAutoJump() end
            return
        end
        if lower:match("^%.autojump%s+off") then
            autoJumpEnabled = false
            stopAutoJump()
            return
        end
    end)
end

