        mainFrame.Size = isMinimized and UDim2.new(0, 300, 0, 30) or UDim2.new(0, 300, 0, 260)
        minBtn.Text = isMinimized and "+" or "—"
    end)

    -- Close
    closeBtn.MouseButton1Click:Connect(function()
        if _G.HiltonExec and _G.HiltonExec.Cleanup then
            _G.HiltonExec.Cleanup()
        end
    end)

    -- Ensure all GUI objects render above other UI by setting their ZIndex where applicable
    for _, obj in ipairs(gui:GetDescendants()) do
        if obj:IsA("GuiObject") then
            pcall(function() obj.ZIndex = 9999 end)
        end
    end
end

-- Button logic
local function onFollowToggle()
    local newState = not followEnabled
    if newState then
        if attackEnabled then
            attackEnabled = false
            stopAttack()
        end
        if teamAttackEnabled then
            teamAttackEnabled = false
            stopTeamAttack()
        end
        local targetName = followBox.Text
        local target = findClosestPlayer(targetName)
        if not target then
            setBtnState(followBtn, false, "Follow")
            followEnabled = false
            return
        end
        followTargetPlayer = target
        followEnabled = true
        setBtnState(followBtn, true, "Follow")
        startFollow()
    else
        stopFollow()
    end
    -- AutoJump persistence: if enabled, ensure auto-jump is running while follow/attack active
    if autoJumpEnabled then
        if followEnabled or attackEnabled or teamAttackEnabled then
            if not autoJumpConn then startAutoJump() end
        else
            -- keep autoJump running if user wants it persistent; user requested it stays on even after respawn
            -- but auto-jump should only act when follow/attack active; so we don't stop the connection here
            -- connection will check follow/attack state before jumping
            if not autoJumpConn then startAutoJump() end
        end
    end
end

local function onAttackToggle()
    local newState = not attackEnabled
    if newState then
        if followEnabled then
            followEnabled = false
            stopFollow()
        end
        if teamAttackEnabled then
            teamAttackEnabled = false
            stopTeamAttack()
        end
        parseAttackNames(attackBox.Text)
        if #attackNames == 0 then
            setBtnState(attackBtn, false, "Attack")
            attackEnabled = false
            return
        end
        attackEnabled = true
        setBtnState(attackBtn, true, "Attack")
        startAttack()
    else
        stopAttack()
    end
    -- AutoJump persistence: ensure auto-jump connection exists if enabled
    if autoJumpEnabled then
        if not autoJumpConn then startAutoJump() end
    end
end

local function onTeamAttackToggle()
    local newState = not teamAttackEnabled
    if newState then
        if followEnabled then
            followEnabled = false
            stopFollow()
        end
        if attackEnabled then
            attackEnabled = false
            stopAttack()
        end
        parseTeamNames(teamAttackBox.Text)
        if #teamAttackNames == 0 then
