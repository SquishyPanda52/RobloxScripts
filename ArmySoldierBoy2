-- Utils
local function trim(s)
    return (tostring(s):gsub("^%s+", ""):gsub("%s+$", ""))
end

local function setBtnState(btn, on, label)
    if not btn then return end
    btn.Text = label .. ": " .. (on and "On" or "Off")
    btn.BackgroundColor3 = on and Color3.fromRGB(46, 204, 113) or Color3.fromRGB(231, 76, 60)
end

local function findClosestPlayer(fragment)
    fragment = trim(fragment or ""):lower()
    if fragment == "" then return nil end
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= localPlayer then
            local nm = pl.Name:lower()
            if nm:find(fragment, 1, true) then
                return pl
            end
        end
    end
    -- fallback: return any non-local player
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= localPlayer then return pl end
    end
    return nil
end

local function parseAttackNames(text)
    attackNames = {}
    for name in tostring(text or ""):gmatch("([^,]+)") do
        name = trim(name)
        if #name > 0 then
            table.insert(attackNames, name)
        end
    end
end

local function parseTeamNames(text)
    teamAttackNames = {}
    for name in tostring(text or ""):gmatch("([^,]+)") do
        name = trim(name)
        if #name > 0 then
            table.insert(teamAttackNames, name)
        end
    end
end

local function getHRP(p)
    local char = p and p.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local function getHumanoid(p)
    local char = p and p.Character
    if not char then return nil end
    return char:FindFirstChildOfClass("Humanoid")
end

local function stopMovementImmediate()
    local char = localPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if humanoid then
        pcall(function() humanoid:Move(Vector3.new()) end)
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            pcall(function() humanoid:MoveTo(hrp.Position) end)
        end
    end
end

-- === Slot-1 equip helpers (only additions) ===
-- Heuristic: treat the first Tool in Backpack as hotbar slot 1.
local function getSlotOneTool()
    local bp = localPlayer:FindFirstChild("Backpack")
    if bp then
        for _, v in ipairs(bp:GetChildren()) do
            if v:IsA("Tool") then
                return v
            end
        end
    end
    -- Fallback: check character for equipped tool
    local char = localPlayer.Character
    if char then
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("Tool") then
                return v
            end
        end
    end
    return nil
end

local function isSlotOneEquipped()
    local slotTool = getSlotOneTool()
    if not slotTool then return false end
    return slotTool.Parent == (localPlayer.Character or nil)
end

local function ensureEquipSlotOne()
    local slotTool = getSlotOneTool()
    if not slotTool then
        return
    end
    if isSlotOneEquipped() then
        return
    end
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.One, false, game)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.One, false, game)
    end)
end
-- === end slot-1 helpers ===

-- Ensure commands from any listed commander are accepted
local function isCommander(name)
    local list = string.split(commanderBox.Text or "", ",")
    name = tostring(name or ""):lower()
    for _, raw in ipairs(list) do
        local partial = raw:lower():gsub("%s+", "")
        if partial ~= "" and name:find(partial, 1, true) then
            return true
        end
    end
    return false
end

-- Helper: build list of all players' names (optionally exclude commanders)
local function allPlayerNames(excludeCommanders)
    local names = {}
    for _, pl in ipairs(Players:GetPlayers()) do
        if pl ~= localPlayer then
            if excludeCommanders then
                if not isCommander(pl.Name) then
                    table.insert(names, pl.Name)
                end
            else
                table.insert(names, pl.Name)
            end
        end
    end
    return names
end

-- Override previous commands cleanly (HARD override)
local function hardOverridePreviousCommands()
    -- increment session token to invalidate any running routines
    commandSession = commandSession + 1

    -- Stop and clear everything so the new command starts from a clean state
    if followConn then
        pcall(function() followConn:Disconnect() end)
        followConn = nil
    end
    if attackConn then
        pcall(function() attackConn:Disconnect() end)
        attackConn = nil
    end
    if teamAttackConn then
        pcall(function() teamAttackConn:Disconnect() end)
        teamAttackConn = nil
    end
    if autoPressConn then
        pcall(function() autoPressConn:Disconnect() end)
        autoPressConn = nil
    end

    -- Clear flags and targets
    followEnabled = false
    followTargetPlayer = nil
    attackEnabled = false
    attackNames = {}
    teamAttackEnabled = false
    teamAttackNames = {}
    holdMode = false
    holdPosition = nil

    -- Stop movement immediately
    stopMovementImmediate()

    -- Update UI states
    setBtnState(followBtn, false, "Follow")
    setBtnState(attackBtn, false, "Attack")
    setBtnState(teamAttackBtn, false, "TeamAttack")
end

-- Follow routine
local function stopFollow()
    followEnabled = false
    followTargetPlayer = nil
    holdMode = false
    holdPosition = nil
    if followConn then
        pcall(function() followConn:Disconnect() end)
        followConn = nil
    end
    stopMovementImmediate()
    setBtnState(followBtn, false, "Follow")
end

local function startFollow()
    -- capture the session token at start
    local mySession = commandSession

    if followConn then
        pcall(function() followConn:Disconnect() end)
        followConn = nil
    end
    followConn = RunService.Heartbeat:Connect(function()
        -- if session changed, stop this routine immediately
        if mySession ~= commandSession then
            if followConn then
                pcall(function() followConn:Disconnect() end)
                followConn = nil
            end
            return
        end

        if not followEnabled then return end

        local myHum = getHumanoid(localPlayer)
        local myRoot = getHRP(localPlayer)
        if not (myHum and myRoot) or myHum.Health <= 0 then
            stopFollow()
            return
        end

        -- If holdMode: move to fixed holdPosition and stop when reached
        if holdMode and holdPosition then
            local dist = (holdPosition - myRoot.Position).Magnitude
            if dist > HOLD_REACH_THRESHOLD then
                myHum:MoveTo(holdPosition)
            else
                -- reached: turn off follow and holdMode
                holdMode = false
                holdPosition = nil
                stopFollow()
            end
            return
        end

        if not followTargetPlayer then
            return
        end

        local thHum = getHumanoid(followTargetPlayer)
        local thRoot = getHRP(followTargetPlayer)
        if not (thHum and thRoot) or thHum.Health <= 0 then
            stopFollow()
            return
        end

        -- If humanoid is sitting, make them jump / stop sitting
        if myHum.Sit then
            pcall(function()
                myHum.Jump = true
                myHum.Sit = false
            end)
        end

        local dist = (thRoot.Position - myRoot.Position).Magnitude
        if dist > FOLLOW_FAR then
            local dir = (thRoot.Position - myRoot.Position).Unit
            myHum:MoveTo(thRoot.Position - dir * 2)
        elseif dist < FOLLOW_NEAR then
            myHum:Move(Vector3.new())
        end
    end)
    table.insert(connections, followConn)
    setBtnState(followBtn, true, "Follow")
end

-- Attack routine
local function stopAttack()
