local autoRunning = false
--////////////////////////////////////////////////////
-- Commander Handling
--////////////////////////////////////////////////////

local function splitCommanders()
    local results = {}

    for entry in string.gmatch(commanderBox.Text, "[^,]+") do
        entry = entry:gsub("^%s+", "")
        entry = entry:gsub("%s+$", "")

        if entry ~= "" then
            table.insert(results, string.lower(entry))
        end
    end

    return results
end

local function isCommander(playerName)
    local lowerName = string.lower(playerName)

    for _, commander in ipairs(splitCommanders()) do
        if string.find(lowerName, commander, 1, true) then
            return true
        end
    end

    return false
end

--////////////////////////////////////////////////////
-- Key Pressing (generalized for two keys)
--////////////////////////////////////////////////////

local function pressKeyFor(box)
    local keyText = tostring(box.Text or ""):upper()

    if keyText == "" then
        return
    end

    local success, keyCode = pcall(function()
        return Enum.KeyCode[keyText]
    end)

    if not success or not keyCode then
        return
    end

    pcall(function()
        VirtualInputManager:SendKeyEvent(
            true,
            keyCode,
            false,
            game
        )

        task.wait(0.05)

        VirtualInputManager:SendKeyEvent(
            false,
            keyCode,
            false,
            game
        )
    end)
end

-- keep original pressKey for compatibility (calls the generalized function)
local function pressKey()
    pressKeyFor(keyBox)
end

local loopThread

local function stopLoop()
    autoRunning = false
end

local function startLoop()
    if autoRunning then
        return
    end

    autoRunning = true

    loopThread = task.spawn(function()

        local last1 = 0
        local last2 = 0

        while autoRunning and not destroyed do

            local cooldown1 = tonumber(cooldownBox.Text) or 1
            local cooldown2 = tonumber(cooldown2Box.Text) or 1

            cooldown1 = math.max(0.05, cooldown1)
            cooldown2 = math.max(0.05, cooldown2)

            -- Update status to show both keys and their cooldowns
            statusLabel.Text =
                "Running (" ..
                string.upper(tostring(keyBox.Text)) ..
                " every " ..
                tostring(cooldown1) ..
                "s; " ..
                string.upper(tostring(key2Box.Text)) ..
                " every " ..
                tostring(cooldown2) ..
                "s)"

            local now = tick()

            -- Press key 1 if its cooldown elapsed
            if (now - last1) >= cooldown1 then
                pressKeyFor(keyBox)
                last1 = now
            end

            -- Press key 2 if its cooldown elapsed
            if (now - last2) >= cooldown2 then
                pressKeyFor(key2Box)
                last2 = now
            end

            -- Sleep a short time to avoid busy loop but remain responsive
            task.wait(0.05)
        end

        statusLabel.Text = "Waiting for -start"
    end)
end

