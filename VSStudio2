-- Input handling for movement
local function onInputBegan(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.Keyboard then
		local key = input.KeyCode
		if key == Enum.KeyCode.W then forward = 1 end
		if key == Enum.KeyCode.S then forward = -1 end
		if key == Enum.KeyCode.A then right = -1 end
		if key == Enum.KeyCode.D then right = 1 end
		if key == Enum.KeyCode.Space then up = 1 end
		if key == Enum.KeyCode.LeftShift then up = -1 end
	end
end

local function onInputEnded(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.Keyboard then
		local key = input.KeyCode
		if key == Enum.KeyCode.W or key == Enum.KeyCode.S then forward = 0 end
		if key == Enum.KeyCode.A or key == Enum.KeyCode.D then right = 0 end
		if key == Enum.KeyCode.Space or key == Enum.KeyCode.LeftShift then up = 0 end
	end
end

-- Fly implementation (client-side)
local function createMover(humanoidRootPart)
	-- Clean previous
	if renderConn then
		safeDisconnect(renderConn)
		renderConn = nil
	end

	local bv = Instance.new("BodyVelocity")
	bv.Name = "FlyBodyVelocity"
	bv.MaxForce = Vector3.new(9e5, 9e5, 9e5)
	bv.Velocity = Vector3.new(0,0,0)
	bv.P = 1250
	bv.Parent = humanoidRootPart

	local bg = Instance.new("BodyGyro")
	bg.Name = "FlyBodyGyro"
	bg.MaxTorque = Vector3.new(9e5, 9e5, 9e5)
	bg.CFrame = workspace.CurrentCamera.CFrame
	bg.P = 1250
	bg.Parent = humanoidRootPart

	-- Smooth movement using RenderStepped
	renderConn = RunService.RenderStepped:Connect(function(dt)
		if not flying then return end
		local cam = workspace.CurrentCamera
		if not cam then return end
		-- direction relative to camera
		local look = cam.CFrame.LookVector
		local rightVec = cam.CFrame.RightVector
		local upVec = Vector3.new(0,1,0)

		local moveDir = (look * forward) + (rightVec * right) + (upVec * up)
		if moveDir.Magnitude > 0 then
			moveDir = moveDir.Unit
		end

		-- apply velocity
		local currentSpeed = tonumber(speedBox.Text) or speed
		currentSpeed = math.clamp(currentSpeed, 5, 500)
		bv.Velocity = moveDir * currentSpeed

		-- keep orientation aligned with camera for stable feel
		bg.CFrame = CFrame.new(humanoidRootPart.Position, humanoidRootPart.Position + cam.CFrame.LookVector)
	end)

	-- return cleanup function
	return function()
		if renderConn then
			safeDisconnect(renderConn)
			renderConn = nil
		end
		if bv and bv.Parent then bv:Destroy() end
		if bg and bg.Parent then bg:Destroy() end
	end
end

-- Manage character, humanoid, and death
local currentCleanup
local function _onCharacterAdded(char) -- prefixed to silence unused warning if not referenced elsewhere
	-- disconnect previous cleanup
	if currentCleanup then
		currentCleanup()
		currentCleanup = nil
	end

	local _hrp = char:WaitForChild("HumanoidRootPart", 5)
	local humanoid = char:FindFirstChild("Humanoid")

	-- ensure flying is turned off on death
	local diedConn
	if humanoid then
		diedConn = humanoid.Died:Connect(function()
			flying = false
			if renderConn then
				safeDisconnect(renderConn)
				renderConn = nil
			end
		end)
		table.insert(connections, diedConn)
	end

	currentCleanup = function()
		-- placeholder for any future cleanup
	end

	return _hrp
end

