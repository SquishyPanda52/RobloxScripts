-- UNIVERSAL CAMERA-DIRECTIONAL FLY SYSTEM (CLIENT ONLY)

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local ContextActionService = game:GetService("ContextActionService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local character = player.Character or player.CharacterAdded:Wait()
local hrp = character:WaitForChild("HumanoidRootPart")
local humanoid = character:WaitForChild("Humanoid")

print("Fly script parent:", script.Parent and script.Parent:GetFullName() or "unknown")

-- UI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FlyToggleUI"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local toggleBtn = Instance.new("TextButton", screenGui)
toggleBtn.Size = UDim2.new(0, 140, 0, 50)
toggleBtn.Position = UDim2.new(0.5, -70, 0.85, -25)
toggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,255)
toggleBtn.TextColor3 = Color3.new(1,1,1)
toggleBtn.Font = Enum.Font.GothamBold
toggleBtn.TextSize = 20
toggleBtn.Text = "Enable"
toggleBtn.AutoButtonColor = true

local speed = 50
local minSpeed = 10
local maxSpeed = 250

local flying = false
local bodyGyro, bodyVelocity
local rsConn

-- smoothing
local velocity = Vector3.new(0,0,0)
local targetVelocity = Vector3.new(0,0,0)
local smoothing = 0.85

-- mobile joystick vector
local mobileMove = Vector3.new(0,0,0)

UserInputService.TouchMovementMode = Enum.TouchMovementMode.Thumbstick

UserInputService.TouchMove:Connect(function(_, delta)
	mobileMove = Vector3.new(delta.X, 0, -delta.Y)
	if mobileMove.Magnitude > 1 then
		mobileMove = mobileMove.Unit
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseWheel then
		speed = math.clamp(speed + input.Position.Z * 5, minSpeed, maxSpeed)
	end
end)

local function startFlying()
	if flying then return end
	flying = true

	bodyGyro = Instance.new("BodyGyro")
	bodyGyro.P = 9e4
	bodyGyro.MaxTorque = Vector3.new(9e9,9e9,9e9)
	bodyGyro.CFrame = hrp.CFrame
	bodyGyro.Parent = hrp

	bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.MaxForce = Vector3.new(9e9,9e9,9e9)
	bodyVelocity.Velocity = Vector3.new(0,0,0)
	bodyVelocity.Parent = hrp

	velocity = hrp.Velocity

	rsConn = RunService.RenderStepped:Connect(function(dt)
		if not flying then return end
		local cam = workspace.CurrentCamera
		if not cam then return end

		bodyGyro.CFrame = CFrame.new(hrp.Position, hrp.Position + cam.CFrame.LookVector)

		local moveDir = cam.CFrame.LookVector

		if mobileMove.Magnitude > 0 then
			moveDir = (cam.CFrame.LookVector * mobileMove.Z) + (cam.CFrame.RightVector * mobileMove.X)
		end

		targetVelocity = moveDir.Unit * speed

		velocity = velocity:Lerp(targetVelocity, 1 - smoothing^(dt * 60))

		bodyVelocity.Velocity = velocity

		humanoid.PlatformStand = true
	end)
end

local function stopFlying()
	if not flying then return end
	flying = false

	if rsConn then rsConn:Disconnect(); rsConn = nil end
	if bodyGyro then bodyGyro:Destroy(); bodyGyro = nil end
	if bodyVelocity then bodyVelocity:Destroy(); bodyVelocity = nil end

	humanoid.PlatformStand = false
	velocity = Vector3.new(0,0,0)
	targetVelocity = Vector3.new(0,0,0)
end

toggleBtn.MouseButton1Click:Connect(function()
	if flying then
		stopFlying()
		toggleBtn.Text = "Enable"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,255)
	else
		startFlying()
		toggleBtn.Text = "Disable"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(255,85,85)
	end
end)

player.CharacterAdded:Connect(function(char)
	stopFlying()
	character = char
	hrp = char:WaitForChild("HumanoidRootPart")
	humanoid = char:WaitForChild("Humanoid")
	toggleBtn.Text = "Enable"
	toggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,255)
end)

ContextActionService:BindAction("ToggleFly", function(_, state)
	if state == Enum.UserInputState.Begin then
		toggleBtn:Activate()
	end
end, false, Enum.KeyCode.F)

print("Fly system loaded.")
