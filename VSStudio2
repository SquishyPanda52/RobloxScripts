		renderConn = nil
	end
	-- small delay to wait for HRP
	local _hrp = char:WaitForChild("HumanoidRootPart", 5)
	-- nothing else required; user can re-enable fly manually
end))

-- Clean up if the script is destroyed
script.Destroying:Connect(function()
	flying = false
	if renderConn then safeDisconnect(renderConn) end
	for _,c in pairs(connections) do safeDisconnect(c) end
	connections = {}
end)
