--// Fly logic
local flying = false
local speed = 50
local bodyGyro
local bodyVelocity
local flyConnection

local moveDirection = Vector3.new()
local keysDown = {
	W = false,
	A = false,
	S = false,
	D = false,
	Space = false,
	Shift = false,
}

local function updateMoveDirection()
	local dir = Vector3.new()
	if keysDown.W then dir = dir + Vector3.new(0, 0, -1) end
	if keysDown.S then dir = dir + Vector3.new(0, 0, 1) end
	if keysDown.A then dir = dir + Vector3.new(-1, 0, 0) end
	if keysDown.D then dir = dir + Vector3.new(1, 0, 0) end
	if keysDown.Space then dir = dir + Vector3.new(0, 1, 0) end
	if keysDown.Shift then dir = dir + Vector3.new(0, -1, 0) end
	if dir.Magnitude > 0 then
		dir = dir.Unit
	end
	moveDirection = dir
end

UserInputService.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.W then keysDown.W = true
	elseif input.KeyCode == Enum.KeyCode.S then keysDown.S = true
	elseif input.KeyCode == Enum.KeyCode.A then keysDown.A = true
	elseif input.KeyCode == Enum.KeyCode.D then keysDown.D = true
	elseif input.KeyCode == Enum.KeyCode.Space then keysDown.Space = true
	elseif input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then keysDown.Shift = true
	end
	updateMoveDirection()
end)

UserInputService.InputEnded:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.W then keysDown.W = false
	elseif input.KeyCode == Enum.KeyCode.S then keysDown.S = false
	elseif input.KeyCode == Enum.KeyCode.A then keysDown.A = false
	elseif input.KeyCode == Enum.KeyCode.D then keysDown.D = false
	elseif input.KeyCode == Enum.KeyCode.Space then keysDown.Space = false
	elseif input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then keysDown.Shift = false
	end
	updateMoveDirection()
end)

local function startFlying()
	if flying then return end
	flying = true

	-- Validate speed from textbox
	local num = tonumber(speedBox.Text)
	if num and num > 0 then
		speed = num
	else
		speedBox.Text = tostring(speed)
	end

	if not humanoidRootPart or not humanoid or humanoid.Health <= 0 then
		flying = false
		return
	end

	bodyGyro = Instance.new("BodyGyro")
	bodyGyro.P = 9e4
	bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
	bodyGyro.CFrame = humanoidRootPart.CFrame
	bodyGyro.Parent = humanoidRootPart

	bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.Velocity = Vector3.zero
	bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
	bodyVelocity.Parent = humanoidRootPart

	-- Disable default physics influence on movement
	humanoid.PlatformStand = true

	if flyConnection then
		flyConnection:Disconnect()
	end

	flyConnection = RunService.RenderStepped:Connect(function()
		if not flying or not humanoidRootPart then return end

		local cam = workspace.CurrentCamera
		if not cam then return end

		bodyGyro.CFrame = cam.CFrame

		local camCF = cam.CFrame
		local forward = camCF.LookVector
		local right = camCF.RightVector
		local up = Vector3.new(0, 1, 0)

		local moveVec = Vector3.new()
		moveVec = moveVec + forward * (keysDown.W and 1 or 0)
		moveVec = moveVec - forward * (keysDown.S and 1 or 0)
		moveVec = moveVec - right * (keysDown.A and 1 or 0)
		moveVec = moveVec + right * (keysDown.D and 1 or 0)
		moveVec = moveVec + up * (keysDown.Space and 1 or 0)
		moveVec = moveVec - up * (keysDown.Shift and 1 or 0)

		if moveVec.Magnitude > 0 then
			moveVec = moveVec.Unit * speed
		end

		bodyVelocity.Velocity = moveVec
	end)

	toggleButton.Text = "Stop Fly"
	toggleButton.BackgroundColor3 = Color3.fromRGB(255, 85, 85)
end

function stopFlying()
	if not flying then return end
	flying = false

	if flyConnection then
		flyConnection:Disconnect()
		flyConnection = nil
	end

	if bodyGyro then
		bodyGyro:Destroy()
		bodyGyro = nil
	end

	if bodyVelocity then
		bodyVelocity:Destroy()
		bodyVelocity = nil
	end

	if humanoid then
		humanoid.PlatformStand = false
	end

	toggleButton.Text = "Start Fly"
	toggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
end

