-- Toggle fly behavior
local moverCleanup
toggleBtn.MouseButton1Click:Connect(function()
	-- update speed variable from textbox
	local parsed = tonumber(speedBox.Text)
	if parsed then speed = parsed end

	flying = not flying
	if flying then
		toggleBtn.Text = "Disable Fly"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(255,85,85)
		-- create mover for current HRP
		local char = player.Character
		if not char then
			char = player.CharacterAdded:Wait()
		end
		local hrp = char:FindFirstChild("HumanoidRootPart")
		if hrp then
			moverCleanup = createMover(hrp)
		end
	else
		toggleBtn.Text = "Enable Fly"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,255)
		-- cleanup mover
		if moverCleanup then
			moverCleanup()
			moverCleanup = nil
		end
	end
end)

