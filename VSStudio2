-- Minimize animation: scale down to miniBox
local function minimizeUI()
	if not frame or not miniBox then return end
	local targetPos = miniBox.Position
	local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local posTween = TweenService:Create(frame, tweenInfo, {Position = targetPos})
	local sizeTween = TweenService:Create(frame, tweenInfo, {Size = miniBox.Size})
	posTween:Play()
	sizeTween:Play()
	posTween.Completed:Wait()
	frame.Visible = false
	miniBox.Visible = true
end

local function restoreUI()
	if not frame or not miniBox then return end
	frame.Visible = true
	miniBox.Visible = false
	-- animate back to original size/position
	local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
	local posTween = TweenService:Create(frame, tweenInfo, {Position = UDim2.new(0.5, -160, 0.2, 0)})
	local sizeTween = TweenService:Create(frame, tweenInfo, {Size = UDim2.new(0, 320, 0, 160)})
	posTween:Play()
	sizeTween:Play()
end

btnMin.MouseButton1Click:Connect(function()
	-- scale animation for a quick "close" feel then minimize
	local sInfo = TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, true, 0)
	local sTween = TweenService:Create(frame, sInfo, {Size = UDim2.new(0, 300, 0, 150)})
	sTween:Play()
	sTween.Completed:Wait()
	minimizeUI()
end)

