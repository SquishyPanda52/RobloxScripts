-- Flight state
local flying = false
local speed = 50
local maxSpeed = 250
local minSpeed = 10
local accel = 200 -- studs/s^2 for smoothing
local velocity = Vector3.new(0,0,0)
local targetVelocity = Vector3.new(0,0,0)

local bodyGyro, bodyVelocity
local rsConn

-- Input state
local moveVec = Vector3.new(0,0,0)
local ascend = 0

local keys = {
	forward = false,
	back = false,
	left = false,
	right = false,
	up = false,
	down = false
}

local function updateMoveVec()
	local cam = workspace.CurrentCamera
	if not cam then return end
	local look = cam.CFrame.LookVector
	local right = cam.CFrame.RightVector
	local forward = Vector3.new(look.X, 0, look.Z).Unit
	if forward ~= forward then forward = Vector3.new(0,0,-1) end
	local rightFlat = Vector3.new(right.X, 0, right.Z).Unit
	if rightFlat ~= rightFlat then rightFlat = Vector3.new(1,0,0) end
	local mv = Vector3.new(0,0,0)
	if keys.forward then mv = mv + forward end
	if keys.back then mv = mv - forward end
	if keys.right then mv = mv + rightFlat end
	if keys.left then mv = mv - rightFlat end
	mv = mv.Unit ~= mv.Unit and Vector3.new(0,0,0) or mv
	moveVec = mv
	ascend = (keys.up and 1 or 0) + (keys.down and -1 or 0)
end

-- Input handlers
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.Keyboard then
		local k = input.KeyCode
		if k == Enum.KeyCode.W then keys.forward = true
		elseif k == Enum.KeyCode.S then keys.back = true
		elseif k == Enum.KeyCode.A then keys.left = true
		elseif k == Enum.KeyCode.D then keys.right = true
		elseif k == Enum.KeyCode.Space then keys.up = true
		elseif k == Enum.KeyCode.LeftControl or k == Enum.KeyCode.RightControl then keys.down = true
		elseif k == Enum.KeyCode.F then -- toggle
			toggleBtn:Activate()
		end
		updateMoveVec()
	end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	if input.UserInputType == Enum.UserInputType.Keyboard then
		local k = input.KeyCode
		if k == Enum.KeyCode.W then keys.forward = false
		elseif k == Enum.KeyCode.S then keys.back = false
		elseif k == Enum.KeyCode.A then keys.left = false
		elseif k == Enum.KeyCode.D then keys.right = false
		elseif k == Enum.KeyCode.Space then keys.up = false
		elseif k == Enum.KeyCode.LeftControl or k == Enum.KeyCode.RightControl then keys.down = false
		end
		updateMoveVec()
	end
end)

UserInputService.InputChanged:Connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseWheel then
		speed = math.clamp(speed + input.Position.Z * 5, minSpeed, maxSpeed)
		speedLabel.Text = "Speed: "..math.floor(speed)
	end
end)

-- Start/stop flight
local function startFlying()
	if flying then return end
	flying = true
	-- create movers
	bodyGyro = Instance.new("BodyGyro")
	bodyGyro.P = 9e4
	bodyGyro.MaxTorque = Vector3.new(9e9,9e9,9e9)
	bodyGyro.CFrame = hrp.CFrame
	bodyGyro.Parent = hrp

	bodyVelocity = Instance.new("BodyVelocity")
	bodyVelocity.MaxForce = Vector3.new(9e9,9e9,9e9)
	bodyVelocity.Velocity = Vector3.new(0,0,0)
	bodyVelocity.Parent = hrp

	velocity = hrp.Velocity
	targetVelocity = Vector3.new(0,0,0)

	rsConn = RunService.RenderStepped:Connect(function(dt)
		if not flying then return end
		if not hrp or not hrp.Parent then return end
		local cam = workspace.CurrentCamera
		if cam then
			bodyGyro.CFrame = CFrame.new(hrp.Position, hrp.Position + cam.CFrame.LookVector)
		end
		-- compute target velocity
		local horiz = moveVec * speed
		local vert = Vector3.new(0, ascend * speed)
		targetVelocity = horiz + vert
		-- smooth velocity towards target
		local delta = targetVelocity - velocity
		local maxChange = accel * dt
		if delta.Magnitude > maxChange then
			delta = delta.Unit * maxChange
		end
		velocity = velocity + delta
		-- apply
		bodyVelocity.Velocity = velocity
		-- keep humanoid state
		if humanoid and humanoid.PlatformStand then
			-- nothing
		else
			humanoid.PlatformStand = true
		end
	end)
end

local function stopFlying()
	if not flying then return end
	flying = false
	if rsConn then rsConn:Disconnect() rsConn = nil end
	if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
	if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
	if humanoid then
		pcall(function() humanoid.PlatformStand = false end)
	end
	velocity = Vector3.new(0,0,0)
	targetVelocity = Vector3.new(0,0,0)
end

toggleBtn.MouseButton1Click:Connect(function()
	if not flying then
		startFlying()
		toggleBtn.Text = "Disable"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(255,85,85)
	else
		stopFlying()
		toggleBtn.Text = "Enable"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(0,170,255)
	end
end)

-- ensure cleanup on death or character change
local function onCharacterAdded(char)
	stopFlying()
	character = char
	hrp = character:WaitForChild("HumanoidRootPart")
	humanoid = character:WaitForChild("Humanoid")
end

player.CharacterAdded:Connect(onCharacterAdded)
humanoid.Died:Connect(function() stopFlying() end)

-- bind context action for mobile / gamepad toggle
ContextActionService:BindAction("ToggleFly", function(_, state, _)
	if state == Enum.UserInputState.Begin then
		toggleBtn:Activate()
	end
end, false, Enum.KeyCode.F)

