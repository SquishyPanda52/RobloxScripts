local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")
local cam = workspace.CurrentCamera

print("Fly Script Loaded - Memory Only Execution")

local gui = Instance.new("ScreenGui")
gui.Name = "FlyUI"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

local btn = Instance.new("TextButton")
btn.Name = "FlyBtn"
btn.Size = UDim2.new(0, 100, 0, 40)
btn.Position = UDim2.new(0.5, -50, 0.85, -20)
btn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
btn.TextColor3 = Color3.new(1, 1, 1)
btn.Font = Enum.Font.GothamBold
btn.TextSize = 16
btn.Text = "Fly ON"
btn.Parent = gui

local spd = Instance.new("TextLabel")
spd.Name = "SpeedLabel"
spd.Size = UDim2.new(0, 100, 0, 20)
spd.Position = UDim2.new(0.5, -50, 0.82, -20)
spd.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
spd.TextColor3 = Color3.new(1, 1, 1)
spd.Font = Enum.Font.Gotham
spd.TextSize = 14
spd.Text = "Speed: 50"
spd.Parent = gui

local flying = false
local flySpeed = 50
local maxSpeed = 150
local accel = 0.2
local vel = Vector3.new(0, 0, 0)
local bg, bv

local function startFly()
	bg = Instance.new("BodyGyro")
	bg.P = 9000
	bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
	bg.CFrame = hrp.CFrame
	bg.Parent = hrp
	
	bv = Instance.new("BodyVelocity")
	bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
	bv.Velocity = Vector3.new(0, 0, 0)
	bv.Parent = hrp
	
	flying = true
	btn.Text = "Fly OFF"
	btn.BackgroundColor3 = Color3.fromRGB(255, 85, 85)
end

local function stopFly()
	flying = false
	if bg then bg:Destroy() end
	if bv then bv:Destroy() end
	vel = Vector3.new(0, 0, 0)
	btn.Text = "Fly ON"
	btn.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
end

btn.MouseButton1Click:Connect(function()
	if flying then
		stopFly()
	else
		startFly()
	end
end)

RunService.RenderStepped:Connect(function()
	if not flying or not bg or not bv then return end
	
	local moveVel = Vector3.new(0, 0, 0)
	local currentSpeed = flySpeed
	
	if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
		currentSpeed = math.min(flySpeed + 30, maxSpeed)
	end
	
	if UIS:IsKeyDown(Enum.KeyCode.W) then
		moveVel = moveVel + cam.CFrame.LookVector * currentSpeed
	end
	if UIS:IsKeyDown(Enum.KeyCode.S) then
		moveVel = moveVel - cam.CFrame.LookVector * currentSpeed
	end
	if UIS:IsKeyDown(Enum.KeyCode.D) then
		moveVel = moveVel + cam.CFrame.RightVector * currentSpeed
	end
	if UIS:IsKeyDown(Enum.KeyCode.A) then
		moveVel = moveVel - cam.CFrame.RightVector * currentSpeed
	end
	if UIS:IsKeyDown(Enum.KeyCode.Space) then
		moveVel = moveVel + Vector3.new(0, currentSpeed, 0)
	end
	if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then
		moveVel = moveVel - Vector3.new(0, currentSpeed, 0)
	end
	
	vel = vel:Lerp(moveVel, accel)
	bv.Velocity = vel
	bg.CFrame = cam.CFrame
	spd.Text = "Speed: " .. math.floor(currentSpeed)
end)

UIS.InputBegan:Connect(function(input, gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.F then
		if flying then stopFly() else startFly() end
	end
end)
