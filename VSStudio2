-- Toggle
--////////////////////////////////////////////////////

local function updateToggle()
    if enabled then
        toggleButton.Text = "ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(50,170,50)
    else
        toggleButton.Text = "OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(170,50,50)

        stopLoop()
    end
end

track(toggleButton.MouseButton1Click:Connect(function()

    enabled = not enabled

    updateToggle()

    if enabled then
        statusLabel.Text = "Listening..."
    else
        statusLabel.Text = "Disabled"
    end

end))

updateToggle()

--////////////////////////////////////////////////////
-- TextChatService Detection
--////////////////////////////////////////////////////

local function handleChatMessage(senderName, message)

    if not enabled then
        return
    end

    if not isCommander(senderName) then
        return
    end

    local lowerMessage =
        string.lower(
            tostring(message)
        )

    if lowerMessage == "-start" then
        startLoop()
        return
    end

    if lowerMessage == ".stop" then
        stopLoop()
        statusLabel.Text = "Stopped"
        return
    end
end
--////////////////////////////////////////////////////
-- Modern TextChatService
--////////////////////////////////////////////////////

local textChannels = TextChatService:WaitForChild("TextChannels", 10)

if textChannels then

    local generalChannel =
        textChannels:FindFirstChild("RBXGeneral")

    if generalChannel then

        track(
            generalChannel.MessageReceived:Connect(function(message)

                if destroyed then
                    return
                end

                local source = message.TextSource

                if not source then
                    return
                end

                local sender =
                    Players:GetPlayerByUserId(
                        source.UserId
                    )

                if not sender then
                    return
                end

                handleChatMessage(
                    sender.Name,
                    message.Text
                )

            end)
        )

    end

end

--////////////////////////////////////////////////////
-- Fallback For Older Chat Systems
--////////////////////////////////////////////////////

local function hookPlayer(playerObj)

    track(
        playerObj.Chatted:Connect(function(message)

            if destroyed then
                return
            end

            handleChatMessage(
                playerObj.Name,
                message
            )

        end)
    )

end

for _, plr in ipairs(Players:GetPlayers()) do
    hookPlayer(plr)
end

track(
    Players.PlayerAdded:Connect(function(plr)
        hookPlayer(plr)
    end)
)

